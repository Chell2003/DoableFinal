@model DoableFinal.ViewModels.StatusReportViewModel

@{
    ViewData["Title"] = "Status Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string PriorityColor(string p) => p switch {
        "High"     => "danger",
        "Critical" => "danger",
        "Medium"   => "warning",
        "Low"      => "info",
        _          => "secondary"
    };

    // Group tasks by category
    var allTasks = Model.CompletedTasks
        .Concat(Model.InProgressTasks)
        .Concat(Model.UpcomingTasks).ToList();

    var taskCategories = allTasks
        .GroupBy(t => string.IsNullOrEmpty(t.Category) ? "Uncategorized" : t.Category)
        .OrderBy(g => g.Key == "Uncategorized" ? "zzz" : g.Key)
        .ToList();
}

<style>
    .report-header-bar {
        background: #1a3060;
        border-radius: 12px;
        padding: 1.5rem 2rem;
        color: white;
        margin-bottom: 1.5rem;
    }
    .stat-tile {
        border-radius: 10px;
        padding: 1.2rem;
        text-align: center;
        border: none;
        height: 100%;
    }
    .stat-tile .num { font-size: 2rem; font-weight: 700; line-height: 1.1; }
    .stat-tile .lbl { font-size: .78rem; text-transform: uppercase; letter-spacing: .05em; opacity: .8; }
    .section-card { border: none; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,.06); margin-bottom: 1.5rem; }
    .section-card .card-header { border-radius: 10px 10px 0 0 !important; }
    .progress-bar-wrap { background: #e9ecef; border-radius: 6px; height: 12px; overflow: hidden; }
    .progress-fill { height: 100%; border-radius: 6px; transition: width .5s ease; }
    .category-chip {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 600;
        background: #e8f4fd;
        color: #0c63b0;
        border: 1px solid #b8daff;
    }
    .category-section-header {
        background: #f8f9fa;
        border-left: 4px solid #0d6efd;
        padding: .5rem 1rem;
        margin: 1rem 0 .5rem;
        border-radius: 0 6px 6px 0;
        font-size: .82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #495057;
    }
    @@media print {
        .no-print { display: none !important; }
        .report-header-bar { background: #1e3a5f !important; -webkit-print-color-adjust: exact; }
    }
</style>

<div class="container-fluid px-4">
    <!-- Header -->
    <div class="report-header-bar no-print">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1">
                    <i class="fas fa-tasks me-2"></i>Status Report
                </h2>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="opacity-90 fw-semibold">@Model.ProjectName</span>
                    @if (!string.IsNullOrEmpty(Model.ProjectCategory))
                    {
                        <span class="badge bg-white text-primary border">
                            <i class="bi bi-tag me-1"></i>@Model.ProjectCategory
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(Model.ProjectStatus))
                    {
                        var sc = Model.ProjectStatus switch {
                            "Completed"   => "success",
                            "In Progress" => "primary",
                            "On Hold"     => "warning",
                            _             => "secondary"
                        };
                        <span class="badge bg-@sc">@Model.ProjectStatus</span>
                    }
                </div>
                <small class="opacity-60">Generated @Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</small>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-light btn-sm" onclick="window.print()">
                    <i class="fas fa-print me-1"></i> Print
                </button>
                <a href="@Url.Action("StatusPrint", new { id = Model.ProjectId })"
                   class="btn btn-outline-light btn-sm" target="_blank">
                    <i class="fas fa-file-pdf me-1"></i> Print View
                </a>
                <a href="@Url.Action("Index")" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>
    </div>

    <!-- Print header (hidden on screen) -->
    <div class="d-none d-print-block mb-3">
        <h2>Status Report — @Model.ProjectName</h2>
        @if (!string.IsNullOrEmpty(Model.ProjectCategory))
        { <p>Category: <strong>@Model.ProjectCategory</strong></p> }
        <p><small>Generated @Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</small></p>
        <hr />
    </div>

    <!-- KPI tiles -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card stat-tile" style="background:#d1fae5; border-left:4px solid #10b981;">
                <div class="num text-success">@Model.CompletedTasks.Count</div>
                <div class="lbl text-success">Completed</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-tile" style="background:#dbeafe; border-left:4px solid #3b82f6;">
                <div class="num text-primary">@Model.InProgressTasks.Count</div>
                <div class="lbl text-primary">In Progress</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-tile" style="background:#fef3c7; border-left:4px solid #f59e0b;">
                <div class="num text-warning">@Model.UpcomingTasks.Count</div>
                <div class="lbl text-warning">Upcoming</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-tile" style="background:#f0fdf4; border-left:4px solid #22c55e;">
                <div class="num">@Math.Round(Model.CompletionPercentage, 0)%</div>
                <div class="lbl">Completion</div>
            </div>
        </div>
    </div>

    <!-- Progress bar -->
    <div class="card section-card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <span class="fw-semibold">Overall Progress</span>
                <span class="fw-bold text-success">@Math.Round(Model.CompletionPercentage, 1)%</span>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-fill bg-success" style="width:@Model.CompletionPercentage%;"></div>
            </div>
            <small class="text-muted mt-1 d-block">
                @Model.CompletedTasks.Count of @Model.TotalTasks tasks completed
            </small>
        </div>
    </div>

    <!-- Tasks by Category -->
    @if (taskCategories.Any())
    {
        <div class="card section-card mb-4">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-tags me-2 text-primary"></i>Tasks by Category</h6>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    @foreach (var cat in taskCategories)
                    {
                        var done = cat.Count(t => t.Status == "Completed");
                        var pct = cat.Count() > 0 ? (int)Math.Round((double)done / cat.Count() * 100) : 0;
                        <div class="col-md-6 col-lg-4">
                            <div class="border rounded p-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="category-chip">@cat.Key</span>
                                    <small class="text-muted">@done / @cat.Count()</small>
                                </div>
                                <div class="progress-bar-wrap" style="height:6px;">
                                    <div class="progress-fill bg-primary" style="width:@pct%;"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Completed Tasks -->
    @if (Model.CompletedTasks.Count > 0)
    {
        <div class="card section-card">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="fas fa-check-circle me-2"></i>Completed Tasks (@Model.CompletedTasks.Count)</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Task</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Due Date</th>
                                <th>Completed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.CompletedTasks.OrderByDescending(t => t.CompletedAt))
                            {
                                <tr>
                                    <td class="fw-semibold">@task.Title</td>
                                    <td>@if (!string.IsNullOrEmpty(task.Category)) { <span class="category-chip">@task.Category</span> } else { <span class="text-muted">—</span> }</td>
                                    <td><span class="badge bg-@PriorityColor(task.Priority)">@task.Priority</span></td>
                                    <td><small>@task.DueDate.ToString("MMM dd, yyyy")</small></td>
                                    <td>
                                        @if (task.CompletedAt.HasValue)
                                        { <small class="text-success">@task.CompletedAt.Value.ToString("MMM dd, yyyy")</small> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- In Progress Tasks -->
    @if (Model.InProgressTasks.Count > 0)
    {
        <div class="card section-card">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="fas fa-spinner me-2"></i>In Progress Tasks (@Model.InProgressTasks.Count)</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Task</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Due Date</th>
                                <th>Schedule</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.InProgressTasks.OrderBy(t => t.DueDate))
                            {
                                var overdue = task.DueDate < DateTime.UtcNow;
                                <tr class="@(overdue ? "table-danger" : "")">
                                    <td class="fw-semibold">@task.Title</td>
                                    <td>@if (!string.IsNullOrEmpty(task.Category)) { <span class="category-chip">@task.Category</span> } else { <span class="text-muted">—</span> }</td>
                                    <td><span class="badge bg-@PriorityColor(task.Priority)">@task.Priority</span></td>
                                    <td><small>@task.DueDate.ToString("MMM dd, yyyy")</small></td>
                                    <td>
                                        @if (overdue)
                                        { <span class="badge bg-danger">Overdue</span> }
                                        else
                                        { <span class="badge bg-success">On Schedule</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Upcoming Tasks -->
    @if (Model.UpcomingTasks.Count > 0)
    {
        <div class="card section-card">
            <div class="card-header bg-warning text-dark">
                <h6 class="mb-0"><i class="fas fa-hourglass-start me-2"></i>Upcoming Tasks (@Model.UpcomingTasks.Count)</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Task</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Due Date</th>
                                <th>Days Until Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.UpcomingTasks.OrderBy(t => t.DueDate))
                            {
                                var days = (int)(task.DueDate - DateTime.UtcNow).TotalDays;
                                var urgency = days < 7 ? "text-danger fw-bold" : days < 14 ? "text-warning" : "text-muted";
                                <tr>
                                    <td class="fw-semibold">@task.Title</td>
                                    <td>@if (!string.IsNullOrEmpty(task.Category)) { <span class="category-chip">@task.Category</span> } else { <span class="text-muted">—</span> }</td>
                                    <td><span class="badge bg-@PriorityColor(task.Priority)">@task.Priority</span></td>
                                    <td><small>@task.DueDate.ToString("MMM dd, yyyy")</small></td>
                                    <td><span class="@urgency">@days days</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.TotalTasks == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-folder-open fa-3x mb-3 d-block opacity-50"></i>
            <h5>No tasks found for this project.</h5>
        </div>
    }
</div>
