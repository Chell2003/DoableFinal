@using DoableFinal.ViewModels
@model ReportFilterViewModel

@{
    ViewData["Title"] = "Reports";
    var grouped = Model.Projects
        .GroupBy(p => string.IsNullOrEmpty(p.Category) ? "Uncategorized" : p.Category)
        .OrderBy(g => g.Key == "Uncategorized" ? "zzz" : g.Key)
        .ToList();
}

<style>
    .report-hero {
        background: #1a3060;
        border-radius: 16px;
        padding: 2rem 2.5rem;
        color: white;
        margin-bottom: 2rem;
    }
    .report-type-card {
        border: none;
        border-radius: 12px;
        transition: transform .2s ease, box-shadow .2s ease;
        height: 100%;
    }
    .report-type-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
    }
    .report-type-card .icon-wrap {
        width: 56px; height: 56px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 1rem;
    }
    .project-selector-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
    }
    .project-selector-card .card-header {
        background: #f8f9fa;
        border-bottom: 1px solid #eee;
        border-radius: 12px 12px 0 0 !important;
        padding: 1rem 1.5rem;
    }
    .report-action-btn {
        border-radius: 8px;
        padding: .55rem 1rem;
        font-size: .875rem;
        font-weight: 500;
        transition: transform .15s ease, box-shadow .15s ease;
    }
    .report-action-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0,0,0,.12);
    }
    #reportActions {
        display: none;
        animation: fadeSlideIn .25s ease;
    }
    @@keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .selected-project-badge {
        background: #e8f4fd;
        border: 1px solid #b8daff;
        border-radius: 8px;
        padding: .5rem 1rem;
        font-size: .875rem;
        color: #0c63b0;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
    }
</style>

<div class="container-fluid px-4">
    <!-- Hero header -->
    <div class="report-hero mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="h3 fw-bold mb-1"><i class="fas fa-chart-bar me-2"></i>My Reports</h1>
                <p class="mb-0 opacity-75">View task and project reports for your assigned work</p>
            </div>
            <div id="selectedProjectBadge" style="display:none;">
                <div class="selected-project-badge">
                    <i class="bi bi-folder-fill"></i>
                    <span id="selectedProjectName">—</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Report type cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card report-type-card shadow-sm">
                <div class="card-body text-center py-3">
                    <div class="icon-wrap bg-primary bg-opacity-10 text-primary">
                        <i class="fas fa-tasks"></i>
                    </div>
                    <h6 class="fw-semibold mb-1">Status Report</h6>
                    <small class="text-muted">Completed, in-progress &amp; upcoming tasks</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card report-type-card shadow-sm">
                <div class="card-body text-center py-3">
                    <div class="icon-wrap bg-info bg-opacity-10 text-info">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h6 class="fw-semibold mb-1">Time Tracking</h6>
                    <small class="text-muted">Time logged per task</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card report-type-card shadow-sm">
                <div class="card-body text-center py-3">
                    <div class="icon-wrap bg-warning bg-opacity-10 text-warning">
                        <i class="fas fa-users"></i>
                    </div>
                    <h6 class="fw-semibold mb-1">Workload</h6>
                    <small class="text-muted">Task assignments &amp; team workload</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card report-type-card shadow-sm">
                <div class="card-body text-center py-3">
                    <div class="icon-wrap bg-success bg-opacity-10 text-success">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                    <h6 class="fw-semibold mb-1">Progress</h6>
                    <small class="text-muted">Completion rate &amp; milestones</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Project selector -->
    <div class="card project-selector-card mb-4">
        <div class="card-header d-flex align-items-center gap-2">
            <i class="bi bi-funnel text-primary"></i>
            <h6 class="mb-0 fw-semibold">Select Project</h6>
        </div>
        <div class="card-body p-4">
            @if (!Model.Projects.Any())
            {
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle me-2"></i> No projects available. You need task assignments to generate reports.
                </div>
            }
            else
            {
                <div class="row g-3 align-items-end">
                    @if (grouped.Count > 1 || (grouped.Count == 1 && grouped[0].Key != "Uncategorized"))
                    {
                        <div class="col-12 col-md-4">
                            <label for="categoryFilter" class="form-label fw-semibold small text-uppercase text-muted">Filter by Category</label>
                            <select id="categoryFilter" class="form-select" onchange="filterProjects()">
                                <option value="">All Categories</option>
                                @foreach (var g in grouped)
                                {
                                    <option value="@g.Key">@g.Key (@g.Count())</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-5">
                            <label for="projectSelect" class="form-label fw-semibold small text-uppercase text-muted">Project</label>
                            <select class="form-select" id="projectSelect" onchange="onProjectChange()">
                                <option value="">— Select a project —</option>
                                @foreach (var g in grouped)
                                {
                                    <optgroup label="@g.Key" data-category="@g.Key">
                                        @foreach (var p in g.OrderBy(x => x.Name))
                                        {
                                            var statusIcon = p.Status switch {
                                                "Completed"   => "✅",
                                                "In Progress" => "🔄",
                                                "On Hold"     => "⏸",
                                                _             => "📋"
                                            };
                                            <option value="@p.Id" data-name="@p.Name" data-category="@g.Key">
                                                @statusIcon @p.Name
                                            </option>
                                        }
                                    </optgroup>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <div class="col-12 col-md-9">
                            <label for="projectSelect" class="form-label fw-semibold small text-uppercase text-muted">Project</label>
                            <select class="form-select" id="projectSelect" onchange="onProjectChange()">
                                <option value="">— Select a project —</option>
                                @foreach (var p in Model.Projects.OrderBy(x => x.Name))
                                {
                                    var statusIcon = p.Status switch {
                                        "Completed"   => "✅",
                                        "In Progress" => "🔄",
                                        "On Hold"     => "⏸",
                                        _             => "📋"
                                    };
                                    <option value="@p.Id" data-name="@p.Name">@statusIcon @p.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="col-12 col-md-3">
                        <button type="button" class="btn btn-primary w-100 report-action-btn"
                                id="quickStatusBtn" onclick="loadReport('Status')" disabled>
                            <i class="fas fa-tasks me-1"></i> View Report
                        </button>
                    </div>
                </div>

                <!-- Report action buttons -->
                <div id="reportActions" class="mt-4 pt-3 border-top">
                    <p class="text-muted small mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Choose a report type for <strong id="actionProjectName">—</strong>
                    </p>
                    <div class="row g-2">
                        <div class="col-6 col-md-3">
                            <button type="button" class="btn btn-primary report-action-btn w-100"
                                    onclick="loadReport('Status')">
                                <i class="fas fa-tasks me-1"></i> Status
                            </button>
                        </div>
                        <div class="col-6 col-md-3">
                            <button type="button" class="btn btn-info text-white report-action-btn w-100"
                                    onclick="showTimeTrackingModal()">
                                <i class="fas fa-clock me-1"></i> Time Tracking
                            </button>
                        </div>
                        <div class="col-6 col-md-3">
                            <button type="button" class="btn btn-warning report-action-btn w-100"
                                    onclick="loadReport('Workload')">
                                <i class="fas fa-users me-1"></i> Workload
                            </button>
                        </div>
                        <div class="col-6 col-md-3">
                            <button type="button" class="btn btn-success report-action-btn w-100"
                                    onclick="loadReport('Progress')">
                                <i class="fas fa-chart-pie me-1"></i> Progress
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Time Tracking Modal -->
<div class="modal fade" id="timeTrackingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold">
                    <i class="fas fa-clock text-info me-2"></i>Time Tracking — Date Range
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="startDate" class="form-label fw-semibold small">Start Date</label>
                    <input type="date" class="form-control" id="startDate"
                           value="@Model.StartDate?.ToString("yyyy-MM-dd")">
                </div>
                <div class="mb-3">
                    <label for="endDate" class="form-label fw-semibold small">End Date</label>
                    <input type="date" class="form-control" id="endDate"
                           value="@Model.EndDate?.ToString("yyyy-MM-dd")">
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="loadTimeTrackingReport()">
                    <i class="fas fa-chart-line me-1"></i> Generate Report
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function filterProjects() {
        const cat = document.getElementById('categoryFilter')?.value;
        const sel = document.getElementById('projectSelect');
        sel.value = '';
        onProjectChange();
        sel.querySelectorAll('optgroup').forEach(og => {
            og.style.display = (!cat || og.dataset.category === cat) ? '' : 'none';
        });
    }

    function onProjectChange() {
        const sel = document.getElementById('projectSelect');
        const chosen = sel.options[sel.selectedIndex];
        const actions = document.getElementById('reportActions');
        const quickBtn = document.getElementById('quickStatusBtn');
        const badge = document.getElementById('selectedProjectBadge');
        const nameBadge = document.getElementById('selectedProjectName');
        const actionName = document.getElementById('actionProjectName');

        if (sel.value) {
            const name = chosen.dataset.name || chosen.text.replace(/^[✅🔄⏸📋]\s*/, '');
            actions.style.display = 'block';
            quickBtn.disabled = false;
            badge.style.display = 'block';
            nameBadge.textContent = name;
            actionName.textContent = name;
        } else {
            actions.style.display = 'none';
            quickBtn.disabled = true;
            badge.style.display = 'none';
        }
    }

    function loadReport(type) {
        const id = document.getElementById('projectSelect').value;
        if (!id) { alert('Please select a project first.'); return; }
        window.location.href = `/Report/${type}/${id}`;
    }

    function showTimeTrackingModal() {
        new bootstrap.Modal(document.getElementById('timeTrackingModal')).show();
    }

    function loadTimeTrackingReport() {
        const id = document.getElementById('projectSelect').value;
        if (!id) { alert('Please select a project first.'); return; }
        const s = document.getElementById('startDate').value;
        const e = document.getElementById('endDate').value;
        window.location.href = `/Report/TimeTracking/${id}?startDate=${s}&endDate=${e}`;
        bootstrap.Modal.getInstance(document.getElementById('timeTrackingModal')).hide();
    }
</script>
