@model IEnumerable<DoableFinal.Models.Project>

@{
    ViewData["Title"] = "Projects";
    var query = Context.Request.Query["q"].ToString();
    var statusFilter = Context.Request.Query["statusFilter"].ToString();
    var fromDate = Context.Request.Query["fromDate"].ToString();
    var toDate = Context.Request.Query["toDate"].ToString();
    var categoryFilter = Context.Request.Query["categoryFilter"].ToString();
    var projectProgress = ViewBag.ProjectProgress as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<style>
    .btn-new-task {
        position: relative;
        overflow: hidden;
        transition: transform .18s ease, box-shadow .18s ease;
    }
    .btn-new-task::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,.18);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform .25s ease;
    }
    .btn-new-task:hover {
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 6px 18px rgba(25,135,84,.38);
    }
    .btn-new-task:hover::after { transform: scaleX(1); }
    .btn-new-task:active { transform: scale(.97); }
</style>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Projects</h1>
            <p class="text-muted small mb-0">Manage all projects in the system</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="CreateTask" class="btn btn-success btn-new-task">
                <i class="bi bi-plus-square me-1"></i> New Task
            </a>
            <a asp-action="CreateProject" class="btn btn-primary">
                <i class="bi bi-folder-plus me-1"></i> Create Project
            </a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-funnel"></i> Filters &amp; Search</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3" role="search" aria-label="Project search and filter">
                <div class="col-md-5">
                    <label for="searchInput" class="form-label">Search</label>
                    <input type="search" id="searchInput" name="q" class="form-control" placeholder="Search by project name or client..." value="@query" aria-label="Search projects" />
                </div>

                <div class="col-md-2">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select id="statusFilter" name="statusFilter" class="form-select">
                        <option value="">All statuses</option>
                        <option value="Not Started" selected="@(statusFilter == "Not Started" ? "selected" : null)">Not Started</option>
                        <option value="In Progress" selected="@(statusFilter == "In Progress" ? "selected" : null)">In Progress</option>
                        <option value="On Hold" selected="@(statusFilter == "On Hold" ? "selected" : null)">On Hold</option>
                        <option value="Completed" selected="@(statusFilter == "Completed" ? "selected" : null)">Completed</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="categoryFilter" class="form-label">Category</label>
                    <input type="text" id="categoryFilter" name="categoryFilter" class="form-control"
                           placeholder="e.g. Additional Feature" value="@categoryFilter" list="catOptions" />
                    <datalist id="catOptions">
                        <option value="Additional Feature"></option>
                        <option value="Bug Fix"></option>
                        <option value="New Module"></option>
                        <option value="Maintenance"></option>
                        <option value="Research"></option>
                        <option value="Client Request"></option>
                        <option value="Internal Project"></option>
                    </datalist>
                </div>

                <div class="col-md-2">
                    <label for="applyBtn" class="form-label">&nbsp;</label>
                    <button id="applyBtn" class="btn btn-primary w-100" type="submit">
                        <i class="bi bi-search"></i> Apply Filters
                    </button>
                </div>

                <div class="col-12">
                    <hr class="my-2" />
                </div>

                <div class="col-md-4">
                    <label for="fromDate" class="form-label"><i class="bi bi-calendar-event"></i> From Date</label>
                    <input type="date" id="fromDate" name="fromDate" class="form-control" value="@fromDate" aria-label="From date" />
                </div>

                <div class="col-md-4">
                    <label for="toDate" class="form-label"><i class="bi bi-calendar-event"></i> To Date</label>
                    <input type="date" id="toDate" name="toDate" class="form-control" value="@toDate" aria-label="To date" />
                </div>

                <div class="col-md-4">
                    <label for="applyDateBtn" class="form-label">&nbsp;</label>
                    <button id="applyDateBtn" class="btn btn-outline-primary w-100" type="submit">
                        <i class="bi bi-calendar3"></i> Apply Date Range
                    </button>
                </div>

                <div class="col-12 text-end">
                    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Projects", "Admin")">
                        <i class="bi bi-x-circle"></i> Reset Filters
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <div class="mb-3">
                        <i class="fas fa-folder-open fa-3x text-muted"></i>
                    </div>
                    <h4>No Projects Found</h4>
                    <p class="text-muted">No projects match your search. Try adjusting your filters or <a asp-action="CreateProject">create a new project</a>.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var project in Model)
            {
                var progress = projectProgress.ContainsKey(project.Id) ? projectProgress[project.Id] : 0;

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@project.Name</h5>

                            @if (!string.IsNullOrEmpty(project.Category))
                            {
                                <p class="mb-2">
                                    <span class="badge bg-light text-secondary border" style="font-size:.75rem;">
                                        <i class="bi bi-tag me-1"></i>@project.Category
                                    </span>
                                </p>
                            }

                            <div class="mb-2">
                                <small class="text-muted">
                                    <i class="bi bi-person me-1"></i>Client:
                                    <strong>@(project.Client != null ? $"{project.Client.FirstName} {project.Client.LastName}" : "—")</strong>
                                </small>
                            </div>
                            <div class="mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-person-badge me-1"></i>Manager:
                                    <strong>@(project.ProjectManager != null ? $"{project.ProjectManager.FirstName} {project.ProjectManager.LastName}" : "—")</strong>
                                </small>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <small class="text-muted">Progress</small>
                                    <small class="text-muted">@progress%</small>
                                </div>
                                <div class="progress" style="height: 5px;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width: @progress%;"
                                         aria-valuenow="@progress"
                                         aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-@(project.Status switch {
                                    "Not Started" => "secondary",
                                    "In Progress" => "primary",
                                    "On Hold" => "warning",
                                    "Completed" => "success",
                                    _ => "secondary"
                                })">@project.Status</span>
                                <small class="text-muted">Due: @(project.EndDate?.ToString("MMM dd, yyyy") ?? "No end date")</small>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">Started: @project.StartDate.ToString("MMM dd, yyyy")</small>
                                <div class="d-flex gap-1">
                                    <a asp-action="EditProject" asp-route-id="@project.Id"
                                       class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (!project.IsArchived && project.Status != "In Progress")
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-warning"
                                                onclick="showArchiveModal(@project.Id, '@Html.Raw(project.Name.Replace("'", "\\'"))')"
                                                title="Archive">
                                            <i class="bi bi-archive"></i>
                                        </button>
                                    }
                                    <a asp-action="ProjectDetails" asp-route-id="@project.Id"
                                       class="btn btn-sm btn-outline-primary">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Archive Modal -->
<div class="modal fade" id="archiveModal" tabindex="-1" aria-labelledby="archiveModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="archiveModalLabel">Archive Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to archive the project "<strong id="projectNameModal"></strong>"?
                <p class="text-muted mt-2 mb-0">Archived projects are still available for reference but cannot be modified.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="archiveForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning">Archive Project</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showArchiveModal(id, name) {
            document.getElementById('projectNameModal').textContent = name;
            document.getElementById('archiveForm').action = `/Admin/ArchiveProject/${id}`;
            new bootstrap.Modal(document.getElementById('archiveModal')).show();
        }
    </script>
}
