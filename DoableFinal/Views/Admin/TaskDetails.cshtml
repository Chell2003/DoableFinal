@model DoableFinal.Models.ProjectTask

@{
    ViewData["Title"] = "Task Details";
    var dateFormat = "MMM dd, yyyy";
    var dateTimeFormat = "MMM dd, yyyy HH:mm";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Task Details</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item">
            <a asp-controller="Admin" asp-action="ProjectDetails" asp-route-id="@Model.ProjectId">
                Project: @Model.Project?.Name
            </a>
        </li>
        <li class="breadcrumb-item active">Task Details</li>
    </ol>

    <div class="row">
        <div>
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center" style="color: white;">
                    <div>
                        <i class="fas fa-tasks me-1"></i>
                        Task Information
                    </div>
                   <div class="d-flex gap-2">

                    <a asp-controller="Admin"
                       asp-action="EditTask"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary btn-sm">
                        <i class="fas fa-edit"></i> Edit Task
                    </a>

                    @if (!Model.IsArchived && Model.Status != "In Progress")
                    {
                        <button type="button"
                                class="btn btn-warning btn-sm"
                                onclick="showArchiveModal(@Model.Id, '@Model.Title')">
                            <i class="fas fa-archive"></i> Archive Task
                        </button>
                    }

                </div>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Title:</div>
                        <div class="col-12 col-md-9">
                            @Model.Title
                            @if (!string.IsNullOrEmpty(Model.ReferenceNumber))
                            {
                                <span class="ms-2" style="background:#e8f0fb;border:1px solid #b8daff;border-radius:6px;padding:3px 10px;font-size:.8rem;font-weight:700;color:#1a3060;font-family:monospace;letter-spacing:.04em;">
                                    <i class="bi bi-hash me-1"></i>@Model.ReferenceNumber
                                </span>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Description:</div>
                        <div class="col-12 col-md-9">@Model.Description</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Project:</div>
                        <div class="col-12 col-md-9">
                            <a asp-controller="Admin" asp-action="ProjectDetails" asp-route-id="@Model.ProjectId">@Model.Project.Name</a>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Assigned To:</div>
                        <div class="col-12 col-md-9">
                            @foreach (var assignment in Model.TaskAssignments)
                            {
                                <span>@assignment.Employee.FirstName</span><br />
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Status:</div>
                        <div class="col-12 col-md-9">
                            <span class="badge bg-@(Model.Status switch {
                                "Not Started" => "secondary",
                                "In Progress" => "primary",
                                "Pending Approval" => "info",
                                "On Hold" => "warning",
                                "Completed" => "success",
                                _ => "secondary"
                            })">@Model.Status</span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Priority:</div>
                        <div class="col-12 col-md-9">
                            <span class="badge bg-@(Model.Priority switch {
                                "Low" => "info",
                                "Medium" => "warning",
                                "High" => "danger",
                                _ => "secondary"
                            })">@Model.Priority</span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Start Date:</div>
                        <div class="col-12 col-md-9">@Model.StartDate.ToString(dateFormat)</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Due Date:</div>
                        <div class="col-12 col-md-9">
                            <span class="@(Model.DueDate < DateTime.Now && Model.Status != "Completed" ? "text-danger" : "")">
                                @Model.DueDate.ToString(dateFormat)
                            </span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3 fw-bold">Created:</div>
                        <div class="col-12 col-md-9">@Model.CreatedAt.ToString(dateTimeFormat)</div>
                    </div>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="row mb-3">
                            <div class="col-md-3 fw-bold">Last Updated:</div>
                            <div class="col-12 col-md-9">@Model.UpdatedAt.Value.ToString(dateTimeFormat)</div>
                        </div>
                    }
                    

                    @if (!string.IsNullOrEmpty(Model.ProofFilePath))
                    {
                        <div class="row mb-3">
                            <div class="col-md-3 fw-bold">Task Proof:</div>
                            <div class="col-12 col-md-9">
                                <div class="card">
                                    <div class="card-body">
                                        <div>
                                            <a href="@Url.Content(Model.ProofFilePath)" class="btn btn-secondary btn-sm" target="_blank">
                                                <i class="fas fa-download"></i> View Submitted Proof
                                            </a>
                                        </div>
                                        @if (Model.IsConfirmed && Model.CompletedAt.HasValue)
                                        {
                                            <div class="mt-3 text-muted small">
                                                <i class="fas fa-check-circle text-success"></i>
                                                Completed on @Model.CompletedAt.Value.ToString(dateTimeFormat)
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="modal fade"
     id="archiveTaskModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Archive Task
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                Are you sure you want to archive:

                <strong id="archiveTaskName"></strong>?

                <p class="text-muted mt-2 mb-0">
                    Archived tasks remain viewable but can no longer be edited.
                </p>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <form id="archiveTaskForm"
                      method="post">

                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="btn btn-warning">
                        Archive Task
                    </button>

                </form>

            </div>

        </div>
    </div>

</div>

            @* Use shared Task Timeline partial (matches Project Manager) *@
            @await Html.PartialAsync("_TaskTimeline", Model)
        </div>
    </div>
</div>
@section Scripts {

<script>

function showArchiveModal(id, title)
{
    document.getElementById("archiveTaskName").textContent = title;

    document.getElementById("archiveTaskForm").action =
        '@Url.Action("ArchiveTask","Admin")/' + id;

    new bootstrap.Modal(
        document.getElementById("archiveTaskModal")
    ).show();
}

</script>

}
