@model DoableFinal.ViewModels.CreateProjectViewModel

@{
    ViewData["Title"] = "Create Project";
}

<style>
    /* Stack Name + Category vertically on mobile */
    @@media (max-width: 767.98px) {
        .form-name-category > [class*="col-"] {
            width: 100% !important;
        }
        .form-name-category .mb-0 {
            margin-bottom: .75rem !important;
        }
    }

    /* Green button animation */
    .btn-new-task {
        position: relative;
        overflow: hidden;
        transition: transform .18s ease, box-shadow .18s ease;
    }
    .btn-new-task::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,.18);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform .25s ease;
    }
    .btn-new-task:hover {
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 6px 18px rgba(25,135,84,.38);
    }
    .btn-new-task:hover::after { transform: scaleX(1); }
    .btn-new-task:active { transform: scale(.97); }
</style>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3">Create Project</h1>
            <p class="text-muted">Create a new project and assign team members</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <form asp-action="CreateProject" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row g-3 form-name-category">
                            <div class="col-12 col-md-8">
                                <div class="mb-0">
                                    <label asp-for="Name" class="form-label fw-semibold"></label>
                                    <div class="position-relative">
                                        <input asp-for="Name" class="form-control" id="projectNameInput" autocomplete="off" />
                                        <div id="projectNameSuggestions" class="list-group position-absolute z-3" style="display:none; max-height:200px; overflow-y:auto; width:100%;"></div>
                                    </div>
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 col-md-4">
                                <div class="mb-0">
                                    <label asp-for="Category" class="form-label fw-semibold">Category</label>
                                    <select asp-for="Category" class="form-select" id="categorySelect">
                                        <option value="">-- Select Category --</option>
                                        <option value="Additional Feature">Additional Feature</option>
                                        <option value="Bug Fix">Bug Fix</option>
                                        <option value="New Module">New Module</option>
                                        <option value="Maintenance">Maintenance</option>
                                        <option value="Research">Research</option>
                                        <option value="Client Request">Client Request</option>
                                        <option value="Internal Project">Internal Project</option>
                                        <option value="Client Onboarding">Client Onboarding</option>
                                        <option value="Other">Other (specify)</option>
                                    </select>
                                    <input type="text" id="categoryCustom" name="Category" class="form-control mt-2" placeholder="Enter custom category…" maxlength="100" style="display:none;" />
                                    <span asp-validation-for="Category" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="StartDate" class="form-label fw-semibold"></label>
                                    <input asp-for="StartDate" class="form-control" id="StartDate" type="date" />
                                    <span asp-validation-for="StartDate" class="text-danger"></span>
                                    <small class="text-info"><i class="bi bi-info-circle"></i> Setting today's date will automatically set status to <strong>In Progress</strong>.</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="EndDate" class="form-label fw-semibold"></label>
                                    <input asp-for="EndDate" class="form-control" id="EndDate" type="date" />
                                    <span asp-validation-for="EndDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Status" class="form-label fw-semibold"></label>
                                    <select asp-for="Status" class="form-select" id="StatusSelect">
                                        <option value="Not Started">Not Started</option>
                                        <option value="In Progress">In Progress</option>
                                        <option value="On Hold">On Hold</option>
                                        <option value="Completed">Completed</option>
                                    </select>
                                    <span asp-validation-for="Status" class="text-danger"></span>
                                    <small id="statusHint" class="text-muted"></small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ClientId" class="form-label fw-semibold">Client</label>
                                    <select asp-for="ClientId" asp-items="Model.Clients" class="form-select select2-client">
                                        <option value="">-- Select Client --</option>
                                    </select>
                                    <span asp-validation-for="ClientId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="ProjectManagerId" class="form-label fw-semibold">Project Manager</label>
                                    <select asp-for="ProjectManagerId" asp-items="Model.ProjectManagers" class="form-select select2-pm">
                                        <option value="">-- Select Project Manager --</option>
                                    </select>
                                    <span asp-validation-for="ProjectManagerId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        @if (Model.AvailableTickets != null && Model.AvailableTickets.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Attach Tickets (optional)</label>
                                <select name="SelectedTicketIds" class="form-select" multiple asp-items="Model.AvailableTickets">
                                </select>
                                <small class="text-muted">Hold Ctrl/Cmd to select multiple tickets</small>
                            </div>
                        }

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-folder-plus"></i> Create Project
                            </button>
                            <a asp-action="Projects" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            const today = new Date().toISOString().split('T')[0];
            $("#StartDate").attr('min', today);
            $("#EndDate").attr('min', today);
            $("#StartDate").val(today);

            // Initialize Select2 for Client and PM for searchable dropdowns
            $('.select2-client, .select2-pm').select2({ width: '100%' });

            // Category: show custom text input when "Other" is selected
            $('#categorySelect').on('change', function () {
                var custom = $('#categoryCustom');
                if ($(this).val() === 'Other') {
                    $(this).removeAttr('name');          // don't post the select
                    custom.attr('name', 'Category').show().focus();
                } else {
                    $(this).attr('name', 'Category');    // post the select value
                    custom.removeAttr('name').hide().val('');
                }
            });

            // On page load restore state if model was invalid and returned "Other"
            (function () {
                var sel = $('#categorySelect');
                var val = sel.val();
                if (val === 'Other' || (val === '' && '@Model?.Category' !== '' && !sel.find('option[value="@Model?.Category"]').length)) {
                    sel.val('Other').trigger('change');
                    $('#categoryCustom').val('@Model?.Category');
                }
            })();

            // Auto-update status based on StartDate
            function checkAutoStatus() {
                const startVal = $("#StartDate").val();
                const statusSelect = $("#StatusSelect");
                if (startVal === today) {
                    statusSelect.val("In Progress");
                    $("#statusHint").html('<i class="bi bi-lightning-fill text-warning"></i> Auto-set to <strong>In Progress</strong> because start date is today.');
                } else if (startVal > today) {
                    if (statusSelect.val() === "In Progress") statusSelect.val("Not Started");
                    $("#statusHint").text('');
                }
            }

            checkAutoStatus();
            $("#StartDate").on('change', function () {
                const startDate = $(this).val();
                $("#EndDate").attr('min', startDate);
                if ($("#EndDate").val() < startDate) {
                    $("#EndDate").val(startDate);
                }
                checkAutoStatus();
            });

            // Project name suggestions (typeable field with autocomplete)
            const existingNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                (ViewBag.ExistingProjectNames as List<string>) ?? new List<string>()
            ));

            $("#projectNameInput").on('input', function () {
                const val = $(this).val().toLowerCase();
                const suggestions = $("#projectNameSuggestions");
                suggestions.empty().hide();
                if (val.length < 1 || existingNames.length === 0) return;
                const matches = existingNames.filter(n => n.toLowerCase().includes(val));
                if (matches.length === 0) return;
                matches.forEach(name => {
                    suggestions.append(`<button type="button" class="list-group-item list-group-item-action">${name}</button>`);
                });
                suggestions.show();
            });
            $(document).on('click', '#projectNameSuggestions button', function () {
                $("#projectNameInput").val($(this).text());
                $("#projectNameSuggestions").hide();
            });
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#projectNameInput, #projectNameSuggestions').length) {
                    $("#projectNameSuggestions").hide();
                }
            });
        });
    </script>
}
