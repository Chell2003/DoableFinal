@model DoableFinal.ViewModels.ContentPageViewModel
@{
    ViewData["Title"] = "Edit Content";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Edit: @Model.DisplayName</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="ContentMS">Content Management</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>

    @if (TempData["ContentMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["ContentMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="SaveContent" asp-controller="Admin" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="key" value="@Model.Key" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Title <small class="text-muted fw-normal">(plain text, HTML tags will be stripped)</small></label>
                    <input type="text" name="titleHtml" id="titleHtmlInput" class="form-control" value="@System.Text.RegularExpressions.Regex.Replace(Model.TitleHtml ?? "", "<[^>]*>", "")" />
                    <small class="text-muted">HTML tags are automatically removed on save.</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Body <small class="text-muted fw-normal">(plain text, HTML tags will be stripped)</small></label>
                    <textarea name="bodyHtml" id="bodyHtmlInput" class="form-control" rows="6">@System.Text.RegularExpressions.Regex.Replace(Model.BodyHtml ?? "", "<[^>]*>", "")</textarea>
                    <small class="text-muted">HTML tags are automatically removed on save.</small>
                </div>

                @if (Model.Key == "Index" || !string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Image</label>
                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <div class="mb-2">
                                <img src="@Model.ImagePath" alt="image" style="max-width:300px; height:auto; border-radius:8px;" />
                            </div>
                        }
                        <label class="form-label">Replace Image (optional)</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="ContentMS" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Strip HTML tags from inputs before form submit
        document.querySelector('form').addEventListener('submit', function () {
            const stripTags = (str) => str.replace(/<[^>]*>/g, '');
            document.getElementById('titleHtmlInput').value = stripTags(document.getElementById('titleHtmlInput').value);
            document.getElementById('bodyHtmlInput').value = stripTags(document.getElementById('bodyHtmlInput').value);
        });
    </script>
}
