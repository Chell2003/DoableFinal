@using DoableFinal.Models
@{
    ViewData["Title"] = "Admin Dashboard";
    var taskBreakdown = ViewBag.TaskStatusBreakdown;
    var projectsWithProgress = ViewBag.ProjectsWithProgress as IEnumerable<dynamic> ?? new List<dynamic>();
    var employeeWorkload = ViewBag.EmployeeWorkload as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-3">
        <div class="col">
            <h1 class="h3 mb-0">Admin Dashboard</h1>
            <p class="text-muted">System Overview &amp; Monitoring</p>
        </div>
        <div class="col-auto d-flex align-items-center gap-2">
            <a asp-action="CreateProject" class="btn btn-primary btn-sm"><i class="bi bi-folder-plus me-1"></i>New Project</a>
            <a asp-action="CreateTask" class="btn btn-success btn-sm"><i class="bi bi-plus-square me-1"></i>New Task</a>
        </div>
    </div>

    <!-- KPI Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-folder"></i></div>
                <div class="stat-value">@ViewBag.TotalProjects</div>
                <div class="stat-label">Total Projects</div>
                <small class="text-success"><i class="bi bi-arrow-up-right"></i> @ViewBag.InProgressProjects in progress</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-list-task"></i></div>
                <div class="stat-value">@ViewBag.TotalTasks</div>
                <div class="stat-label">Total Tasks</div>
                <small class="text-success"><i class="bi bi-check-circle"></i> @ViewBag.CompletedTasks completed</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-people"></i></div>
                <div class="stat-value">@ViewBag.TotalUsers</div>
                <div class="stat-label">Total Users</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card" style="border-left: 4px solid #dc3545;">
                <div class="stat-icon text-danger"><i class="bi bi-clock-history"></i></div>
                <div class="stat-value text-danger">@ViewBag.OverdueTasks</div>
                <div class="stat-label">Overdue Tasks</div>
                <small class="text-muted">Need attention</small>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-3 mb-4">
        <div class="col-md-5">
            <div class="card h-100">
                <div class="card-header bg-white">
                    <h6 class="card-title mb-0"><i class="bi bi-pie-chart me-2 text-primary"></i>Task Status Breakdown</h6>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="taskStatusChart" style="max-height:220px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header bg-white">
                    <h6 class="card-title mb-0"><i class="bi bi-bar-chart me-2 text-success"></i>Project Progress Overview</h6>
                </div>
                <div class="card-body" style="max-height:260px; overflow-y:auto;">
                    @foreach (var item in projectsWithProgress.Take(8))
                    {
                        var statusColor = item.Project.Status == "Completed" ? "success" :
                                          item.Project.Status == "In Progress" ? "primary" :
                                          item.Project.Status == "On Hold" ? "warning" : "secondary";
                        <div class="mb-2">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <a asp-action="ProjectDetails" asp-route-id="@item.Project.Id" class="text-decoration-none small fw-semibold text-truncate" style="max-width:60%;">@item.Project.Name</a>
                                <span class="d-flex align-items-center gap-2">
                                    <span class="badge bg-@statusColor">@item.Project.Status</span>
                                    <small class="text-muted">@item.ProgressPercent%</small>
                                </span>
                            </div>
                            <div class="progress" style="height:8px;">
                                <div class="progress-bar bg-@statusColor" role="progressbar" style="width:@item.ProgressPercent%;" aria-valuenow="@item.ProgressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <small class="text-muted">@item.CompletedTasks / @item.TotalTasks tasks done</small>
                        </div>
                    }
                    @if (!projectsWithProgress.Any())
                    {
                        <p class="text-muted text-center py-3">No active projects</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Overview + Recent Tasks -->
    <div class="row g-3 mb-4">
        <!-- All Projects Overview -->
        <div class="col-md-7">
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="card-title mb-0"><i class="bi bi-folder2-open me-2 text-primary"></i>All Projects</h6>
                    <a asp-action="Projects" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Project</th>
                                    <th>Category</th>
                                    <th>Manager</th>
                                    <th>Status</th>
                                    <th>Progress</th>
                                    <th>Due</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in projectsWithProgress)
                                {
                                    var statusColor = item.Project.Status == "Completed" ? "success" :
                                                      item.Project.Status == "In Progress" ? "primary" :
                                                      item.Project.Status == "On Hold" ? "warning" : "secondary";
                                    <tr>
                                        <td>
                                            <a asp-action="ProjectDetails" asp-route-id="@item.Project.Id" class="text-decoration-none fw-semibold">@item.Project.Name</a>
                                        </td>
                                        <td><small class="text-muted">@(string.IsNullOrEmpty((string)item.Project.Category) ? "—" : item.Project.Category)</small></td>
                                        <td><small>@(item.Project.ProjectManager != null ? $"{item.Project.ProjectManager.FirstName} {item.Project.ProjectManager.LastName}" : "—")</small></td>
                                        <td><span class="badge bg-@statusColor">@item.Project.Status</span></td>
                                        <td style="min-width:80px;">
                                            <div class="progress" style="height:6px;">
                                                <div class="progress-bar bg-@statusColor" style="width:@item.ProgressPercent%;"></div>
                                            </div>
                                            <small class="text-muted">@item.ProgressPercent%</small>
                                        </td>
                                        <td><small>@{ DateTime? endDate = (DateTime?)item.Project.EndDate; }@(endDate.HasValue ? endDate.Value.ToString("MMM dd") : "—")</small></td>
                                    </tr>
                                }
                                @if (!projectsWithProgress.Any())
                                {
                                    <tr><td colspan="6" class="text-center text-muted py-3">No active projects</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Tasks -->
        <div class="col-md-5">
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="card-title mb-0"><i class="bi bi-list-check me-2 text-success"></i>Recent Tasks</h6>
                    <a asp-action="Tasks" class="btn btn-sm btn-outline-success">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Task</th>
                                    <th>Project</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in ViewBag.RecentTasks ?? new List<ProjectTask>())
                                {
                                    var priorityColor = task.Priority == "High" ? "danger" : task.Priority == "Medium" ? "warning" : "secondary";
                                    var statusColor2 = task.Status == "Completed" ? "success" : task.Status == "In Progress" ? "primary" : task.Status == "On Hold" ? "warning" : "secondary";
                                    <tr>
                                        <td><a asp-action="TaskDetails" asp-route-id="@task.Id" class="text-decoration-none small">@task.Title</a></td>
                                        <td><small class="text-muted">@(task.Project?.Name ?? "—")</small></td>
                                        <td><span class="badge bg-@priorityColor">@task.Priority</span></td>
                                        <td><span class="badge bg-@statusColor2">@task.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Employee Workload + Recent Users -->
    <div class="row g-3 mb-4">
        <!-- Employee Workload -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="card-title mb-0"><i class="bi bi-person-lines-fill me-2 text-warning"></i>Employee Workload Monitor</h6>
                    <a asp-action="Users" class="btn btn-sm btn-outline-secondary">Manage Users</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Employee</th>
                                    <th>Position</th>
                                    <th>Total Tasks</th>
                                    <th>In Progress</th>
                                    <th>Completed</th>
                                    <th>Overdue</th>
                                    <th>Workload</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emp in employeeWorkload)
                                {
                                    var wlColor = emp.WorkloadLevel == "High" ? "danger" : emp.WorkloadLevel == "Medium" ? "warning" : emp.WorkloadLevel == "Low" ? "info" : "secondary";
                                    <tr>
                                        <td class="fw-semibold small">@emp.Name</td>
                                        <td><small class="text-muted">@emp.Position</small></td>
                                        <td class="text-center">@emp.TotalTasks</td>
                                        <td class="text-center"><span class="badge bg-primary">@emp.InProgressTasks</span></td>
                                        <td class="text-center"><span class="badge bg-success">@emp.CompletedTasks</span></td>
                                        <td class="text-center">
                                            @if (emp.OverdueTasks > 0)
                                            {
                                                <span class="badge bg-danger">@emp.OverdueTasks</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-@wlColor">@emp.WorkloadLevel</span>
                                        </td>
                                    </tr>
                                }
                                @if (!employeeWorkload.Any())
                                {
                                    <tr><td colspan="7" class="text-center text-muted py-3">No employees found</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Users -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="card-title mb-0"><i class="bi bi-people me-2 text-info"></i>Recent Users</h6>
                    <a asp-action="Users" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Role</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in ViewBag.RecentUsers ?? new List<ApplicationUser>())
                            {
                                <tr>
                                    <td class="small">@user.FirstName @user.LastName</td>
                                    <td><small class="text-muted">@user.Role</small></td>
                                    <td>
                                        @if (user.IsActive)
                                        { <span class="badge bg-success">Active</span> }
                                        else
                                        { <span class="badge bg-danger">Inactive</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('taskStatusChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Not Started', 'In Progress', 'Completed', 'On Hold', 'Overdue'],
                datasets: [{
                    data: [
                        @taskBreakdown?.NotStarted ?? 0,
                        @taskBreakdown?.InProgress ?? 0,
                        @taskBreakdown?.Completed ?? 0,
                        @taskBreakdown?.OnHold ?? 0,
                        @taskBreakdown?.Overdue ?? 0
                    ],
                    backgroundColor: ['#6c757d', '#0d6efd', '#198754', '#ffc107', '#dc3545'],
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } }
                },
                cutout: '65%'
            }
        });
    </script>
}
