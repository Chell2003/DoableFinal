@model DoableFinal.ViewModels.StatusReportViewModel
@{
    ViewData["Title"] = "Status Report";
    Layout = null;

    string PC(string p) => p switch {
        "High" or "Critical" => "danger",
        "Medium"             => "warning",
        "Low"                => "info",
        _                    => "muted"
    };

    var allTasks = Model.CompletedTasks
        .Concat(Model.InProgressTasks)
        .Concat(Model.UpcomingTasks).ToList();

    var cats = allTasks
        .GroupBy(t => string.IsNullOrEmpty(t.Category) ? "Uncategorized" : t.Category)
        .OrderBy(g => g.Key == "Uncategorized" ? "zzz" : g.Key)
        .ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Status Report — @Model.ProjectName</title>
<link href="/css/reports-print.css" rel="stylesheet"/>
</head>
<body>
<div class="rpt-page">

  <!-- Cover -->
  <div class="rpt-cover">
    <div class="rpt-cover-left">
      <div class="rpt-report-type">Project Status Report</div>
      <div class="rpt-title">@Model.ProjectName</div>
      <div class="rpt-meta">
        <span><strong>Category</strong></span>
        <span>@(string.IsNullOrEmpty(Model.ProjectCategory) ? "—" : Model.ProjectCategory)</span>
        <span><strong>Status</strong></span>
        <span>@(string.IsNullOrEmpty(Model.ProjectStatus) ? "—" : Model.ProjectStatus)</span>
        <span><strong>Generated</strong></span>
        <span>@Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</span>
        <span><strong>Completion</strong></span>
        <span>@Math.Round(Model.CompletionPercentage, 1)%</span>
      </div>
    </div>
    <img src="/images/logo-combined2.png" alt="Doable" class="rpt-logo"/>
  </div>

  <div class="rpt-watermark-bar">
    <span>Doable Project Management System</span>
    <span>CONFIDENTIAL</span>
  </div>

  <!-- KPI -->
  <div class="rpt-kpi-grid cols-4">
    <div class="rpt-kpi green">
      <div class="rpt-kpi-val">@Model.CompletedTasks.Count</div>
      <div class="rpt-kpi-lbl">Completed</div>
    </div>
    <div class="rpt-kpi blue">
      <div class="rpt-kpi-val">@Model.InProgressTasks.Count</div>
      <div class="rpt-kpi-lbl">In Progress</div>
    </div>
    <div class="rpt-kpi yellow">
      <div class="rpt-kpi-val">@Model.UpcomingTasks.Count</div>
      <div class="rpt-kpi-lbl">Upcoming</div>
    </div>
    <div class="rpt-kpi teal">
      <div class="rpt-kpi-val">@Model.TotalTasks</div>
      <div class="rpt-kpi-lbl">Total Tasks</div>
    </div>
  </div>

  <!-- Overall Progress -->
  <div class="rpt-section">
    <div class="rpt-section-head blue">
      <div class="rpt-sec-icon">📊</div>
      <h3>Overall Progress</h3>
      <span class="rpt-count">@Math.Round(Model.CompletionPercentage, 1)% Complete</span>
    </div>
    <div class="rpt-progress-wrap">
      <div class="rpt-progress-fill" style="width:@Model.CompletionPercentage%">
        @Math.Round(Model.CompletionPercentage, 0)%
      </div>
    </div>
    <p style="font-size:8.5pt;color:#64748b;margin-top:4px;">
      @Model.CompletedTasks.Count of @Model.TotalTasks tasks completed
    </p>
  </div>

  <!-- Category Breakdown -->
  @if (cats.Any())
  {
    <div class="rpt-section">
      <div class="rpt-section-head teal">
        <div class="rpt-sec-icon">🏷</div>
        <h3>Tasks by Category</h3>
      </div>
      <div class="rpt-cat-grid">
        @foreach (var cat in cats)
        {
          var done  = cat.Count(t => t.Status == "Completed");
          var total = cat.Count();
          var pct   = total > 0 ? (int)Math.Round((double)done / total * 100) : 0;
          <div class="rpt-cat-card">
            <div class="rpt-cat-name">@cat.Key</div>
            <div class="rpt-cat-stat">@done / @total tasks &nbsp;·&nbsp; @pct%</div>
            <div class="rpt-mini-progress-wrap">
              <div class="rpt-mini-progress-fill" style="width:@pct%"></div>
            </div>
          </div>
        }
      </div>
    </div>
  }

  <!-- Completed Tasks -->
  @if (Model.CompletedTasks.Count > 0)
  {
    <div class="rpt-section">
      <div class="rpt-section-head green">
        <div class="rpt-sec-icon">✅</div>
        <h3>Completed Tasks</h3>
        <span class="rpt-count">@Model.CompletedTasks.Count</span>
      </div>
      <table class="rpt-table">
        <thead><tr>
          <th style="width:40%">Task</th>
          <th>Category</th>
          <th>Priority</th>
          <th>Due Date</th>
          <th>Completed</th>
        </tr></thead>
        <tbody>
          @foreach (var t in Model.CompletedTasks.OrderByDescending(x => x.CompletedAt))
          {
            <tr>
              <td><strong>@t.Title</strong></td>
              <td><span class="rpt-badge primary">@(string.IsNullOrEmpty(t.Category) ? "—" : t.Category)</span></td>
              <td><span class="rpt-badge @PC(t.Priority)">@t.Priority</span></td>
              <td>@t.DueDate.ToString("MMM dd, yyyy")</td>
              <td>@(t.CompletedAt?.ToString("MMM dd, yyyy") ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- In Progress Tasks -->
  @if (Model.InProgressTasks.Count > 0)
  {
    <div class="rpt-section">
      <div class="rpt-section-head blue">
        <div class="rpt-sec-icon">🔄</div>
        <h3>In Progress Tasks</h3>
        <span class="rpt-count">@Model.InProgressTasks.Count</span>
      </div>
      <table class="rpt-table">
        <thead><tr>
          <th style="width:40%">Task</th>
          <th>Category</th>
          <th>Priority</th>
          <th>Due Date</th>
          <th>Schedule</th>
        </tr></thead>
        <tbody>
          @foreach (var t in Model.InProgressTasks.OrderBy(x => x.DueDate))
          {
            var overdue = t.DueDate < DateTime.UtcNow;
            <tr class="@(overdue ? "overdue" : "")">
              <td><strong>@t.Title</strong></td>
              <td><span class="rpt-badge primary">@(string.IsNullOrEmpty(t.Category) ? "—" : t.Category)</span></td>
              <td><span class="rpt-badge @PC(t.Priority)">@t.Priority</span></td>
              <td>@t.DueDate.ToString("MMM dd, yyyy")</td>
              <td>
                @if (overdue) { <span class="rpt-badge danger">Overdue</span> }
                else { <span class="rpt-badge success">On Schedule</span> }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- Upcoming Tasks -->
  @if (Model.UpcomingTasks.Count > 0)
  {
    <div class="rpt-section">
      <div class="rpt-section-head yellow">
        <div class="rpt-sec-icon">📅</div>
        <h3>Upcoming Tasks</h3>
        <span class="rpt-count">@Model.UpcomingTasks.Count</span>
      </div>
      <table class="rpt-table">
        <thead><tr>
          <th style="width:40%">Task</th>
          <th>Category</th>
          <th>Priority</th>
          <th>Due Date</th>
          <th>Days Until Due</th>
        </tr></thead>
        <tbody>
          @foreach (var t in Model.UpcomingTasks.OrderBy(x => x.DueDate))
          {
            var days = (int)(t.DueDate - DateTime.UtcNow).TotalDays;
            var urgency = days < 7 ? "danger" : days < 14 ? "warning" : "muted";
            <tr>
              <td><strong>@t.Title</strong></td>
              <td><span class="rpt-badge primary">@(string.IsNullOrEmpty(t.Category) ? "—" : t.Category)</span></td>
              <td><span class="rpt-badge @PC(t.Priority)">@t.Priority</span></td>
              <td>@t.DueDate.ToString("MMM dd, yyyy")</td>
              <td><span class="rpt-badge @urgency">@days days</span></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- Footer -->
  <div class="rpt-footer">
    <div><strong>Doable</strong> Project Management System</div>
    <div>Generated @Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</div>
  </div>

</div>
<script>window.onload = function(){ window.print(); }</script>
</body>
</html>
