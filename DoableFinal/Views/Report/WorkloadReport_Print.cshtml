@model DoableFinal.ViewModels.WorkloadReportViewModel
@{
    ViewData["Title"] = "Workload Report";
    Layout = null;

    string PC(string p) => p switch {
        "High" or "Critical" => "danger",
        "Medium"             => "warning",
        "Low"                => "info",
        _                    => "muted"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>Workload Report — @Model.ProjectName</title>
<link href="/css/reports-print.css" rel="stylesheet"/>
</head>
<body>
<div class="rpt-page">

  <!-- Cover -->
  <div class="rpt-cover">
    <div class="rpt-cover-left">
      <div class="rpt-report-type">Workload Report</div>
      <div class="rpt-title">@Model.ProjectName</div>
      <div class="rpt-meta">
        <span><strong>Generated</strong></span>
        <span>@Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</span>
        <span><strong>Team Members</strong></span>
        <span>@Model.EmployeeWorkloads.Count</span>
      </div>
    </div>
    <img src="/images/logo-combined2.png" alt="Doable" class="rpt-logo"/>
  </div>

  <div class="rpt-watermark-bar">
    <span>Doable Project Management System</span>
    <span>CONFIDENTIAL</span>
  </div>

  <!-- KPI -->
  <div class="rpt-kpi-grid cols-4">
    <div class="rpt-kpi blue">
      <div class="rpt-kpi-val">@Model.EmployeeWorkloads.Count</div>
      <div class="rpt-kpi-lbl">Team Members</div>
    </div>
    <div class="rpt-kpi teal">
      <div class="rpt-kpi-val">@Math.Round(Model.AverageTasksPerEmployee, 1)</div>
      <div class="rpt-kpi-lbl">Avg Tasks / Person</div>
    </div>
    <div class="rpt-kpi green">
      <div class="rpt-kpi-val" style="font-size:13pt;">@(Model.LeastLoadedEmployee ?? "—")</div>
      <div class="rpt-kpi-lbl">Least Loaded</div>
    </div>
    <div class="rpt-kpi red">
      <div class="rpt-kpi-val" style="font-size:13pt;">@(Model.MostLoadedEmployee ?? "—")</div>
      <div class="rpt-kpi-lbl">Most Loaded</div>
    </div>
  </div>

  <!-- Alerts -->
  @if (Model.OverallocationAlerts.Any())
  {
    <div class="rpt-section">
      <div class="rpt-section-head red">
        <div class="rpt-sec-icon">⚠️</div>
        <h3>Over-allocation Alerts</h3>
        <span class="rpt-count">@Model.OverallocationAlerts.Count</span>
      </div>
      @foreach (var a in Model.OverallocationAlerts)
      {
        var ac = a.SeverityLevel == "High" ? "danger" : "warning";
        <div class="rpt-alert @ac">
          <strong>@a.EmployeeName</strong> &mdash;
          <span class="rpt-badge @ac">@a.SeverityLevel Priority</span>
          &nbsp;·&nbsp; @a.TaskCount tasks assigned, @a.OverdueTaskCount overdue<br/>
          <span style="font-size:8.5pt;color:#64748b;">@a.Recommendation</span>
        </div>
      }
    </div>
  }

  <!-- Summary Table -->
  <div class="rpt-section">
    <div class="rpt-section-head blue">
      <div class="rpt-sec-icon">👥</div>
      <h3>Team Workload Summary</h3>
    </div>
    <table class="rpt-table">
      <thead><tr>
        <th>Employee</th>
        <th style="text-align:center">Assigned</th>
        <th style="text-align:center">Completed</th>
        <th style="text-align:center">In Progress</th>
        <th style="text-align:center">Overdue</th>
        <th style="text-align:center">Completion %</th>
      </tr></thead>
      <tbody>
        @foreach (var w in Model.EmployeeWorkloads.OrderByDescending(x => x.AssignedTaskCount))
        {
          var pct = w.AssignedTaskCount > 0
            ? (int)Math.Round((double)w.CompletedTaskCount / w.AssignedTaskCount * 100) : 0;
          <tr>
            <td><strong>@w.EmployeeName</strong></td>
            <td style="text-align:center">@w.AssignedTaskCount</td>
            <td style="text-align:center"><span class="rpt-badge success">@w.CompletedTaskCount</span></td>
            <td style="text-align:center"><span class="rpt-badge primary">@w.InProgressTaskCount</span></td>
            <td style="text-align:center">
              @if (w.OverdueTaskCount > 0)
              { <span class="rpt-badge danger">@w.OverdueTaskCount</span> }
              else
              { <span class="rpt-badge muted">0</span> }
            </td>
            <td style="text-align:center"><span class="rpt-badge @(pct >= 75 ? "success" : pct >= 40 ? "warning" : "danger")">@pct%</span></td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  <!-- Per-Employee Detail -->
  @foreach (var w in Model.EmployeeWorkloads)
  {
    <div class="rpt-section">
      <div class="rpt-section-head teal">
        <div class="rpt-sec-icon">👤</div>
        <h3>@w.EmployeeName</h3>
        <span class="rpt-count">@w.AssignedTaskCount tasks</span>
      </div>
      @if (!w.Tasks.Any())
      {
        <p style="font-size:9pt;color:#64748b;font-style:italic;">No tasks assigned.</p>
      }
      else
      {
        <table class="rpt-table">
          <thead><tr>
            <th style="width:45%">Task</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Due Date</th>
          </tr></thead>
          <tbody>
            @foreach (var t in w.Tasks.OrderBy(x => x.DueDate))
            {
              <tr class="@(t.IsOverdue ? "overdue" : "")">
                <td>
                  @t.TaskTitle
                  @if (t.IsOverdue)
                  { <span class="rpt-badge danger" style="margin-left:4px">Overdue</span> }
                </td>
                <td><span class="rpt-badge @(t.Status == "Completed" ? "success" : t.Status == "In Progress" ? "primary" : "muted")">@t.Status</span></td>
                <td><span class="rpt-badge @PC(t.Priority)">@t.Priority</span></td>
                <td>@t.DueDate.ToString("MMM dd, yyyy")</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>
  }

  <div class="rpt-footer">
    <div><strong>Doable</strong> Project Management System</div>
    <div>Generated @Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</div>
  </div>

</div>
<script>window.onload = function(){ window.print(); }</script>
</body>
</html>
