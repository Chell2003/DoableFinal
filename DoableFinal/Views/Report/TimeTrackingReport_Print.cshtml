@model DoableFinal.ViewModels.TimeTrackingReportViewModel
@{
    ViewData["Title"] = "Time Tracking Report";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>Time Tracking Report — @Model.ProjectName</title>
<link href="/css/reports-print.css" rel="stylesheet"/>
</head>
<body>
<div class="rpt-page">

  <!-- Cover -->
  <div class="rpt-cover">
    <div class="rpt-cover-left">
      <div class="rpt-report-type">Time Tracking Report</div>
      <div class="rpt-title">@Model.ProjectName</div>
      <div class="rpt-meta">
        <span><strong>Period</strong></span>
        <span>@(Model.StartDate?.ToString("MMM dd, yyyy") ?? "All time") – @(Model.EndDate?.ToString("MMM dd, yyyy") ?? "Now")</span>
        <span><strong>Total Hours</strong></span>
        <span>@Math.Round(Model.TotalHours, 1) hrs</span>
        <span><strong>Generated</strong></span>
        <span>@Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</span>
      </div>
    </div>
    <img src="/images/logo-combined2.png" alt="Doable" class="rpt-logo"/>
  </div>

  <div class="rpt-watermark-bar">
    <span>Doable Project Management System</span>
    <span>CONFIDENTIAL</span>
  </div>

  <!-- KPI -->
  <div class="rpt-kpi-grid cols-4">
    <div class="rpt-kpi blue">
      <div class="rpt-kpi-val">@Math.Round(Model.TotalHours, 1)</div>
      <div class="rpt-kpi-lbl">Total Hours</div>
    </div>
    <div class="rpt-kpi teal">
      <div class="rpt-kpi-val">@Model.TaskTimes.Count</div>
      <div class="rpt-kpi-lbl">Tasks Tracked</div>
    </div>
    <div class="rpt-kpi green">
      <div class="rpt-kpi-val">@Model.EmployeeTimes.Count</div>
      <div class="rpt-kpi-lbl">Contributors</div>
    </div>
    <div class="rpt-kpi yellow">
      <div class="rpt-kpi-val">@(Model.EmployeeTimes.Any() ? Math.Round(Model.TotalHours / Model.EmployeeTimes.Count, 1) : 0)</div>
      <div class="rpt-kpi-lbl">Avg Hrs / Person</div>
    </div>
  </div>

  <!-- By Employee -->
  @if (Model.EmployeeTimes.Any())
  {
    <div class="rpt-section">
      <div class="rpt-section-head blue">
        <div class="rpt-sec-icon">👥</div>
        <h3>Hours by Employee</h3>
      </div>
      <table class="rpt-table">
        <thead><tr>
          <th>Employee</th>
          <th style="text-align:center">Total Hours</th>
          <th style="text-align:center">Tasks</th>
          <th style="text-align:center">Avg Hrs / Task</th>
          <th style="text-align:right;width:30%">Distribution</th>
        </tr></thead>
        <tbody>
          @foreach (var e in Model.EmployeeTimes.OrderByDescending(x => x.TotalHours))
          {
            var pct = Model.TotalHours > 0 ? (int)Math.Round((double)e.TotalHours / (double)Model.TotalHours * 100) : 0;
            <tr>
              <td><strong>@e.EmployeeName</strong></td>
              <td style="text-align:center">@Math.Round(e.TotalHours, 1) hrs</td>
              <td style="text-align:center">@e.TaskCount</td>
              <td style="text-align:center">@Math.Round(e.AverageHoursPerTask, 1) hrs</td>
              <td>
                <div style="display:flex;align-items:center;gap:6px;">
                  <div class="rpt-mini-progress-wrap" style="flex:1;height:8px;">
                    <div class="rpt-mini-progress-fill" style="width:@pct%"></div>
                  </div>
                  <span style="font-size:8pt;color:#64748b;min-width:28px;">@pct%</span>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- By Task -->
  @if (Model.TaskTimes.Any())
  {
    <div class="rpt-section">
      <div class="rpt-section-head teal">
        <div class="rpt-sec-icon">📋</div>
        <h3>Hours by Task</h3>
      </div>
      <table class="rpt-table">
        <thead><tr>
          <th style="width:50%">Task</th>
          <th>Status</th>
          <th style="text-align:right">Hours Logged</th>
        </tr></thead>
        <tbody>
          @foreach (var t in Model.TaskTimes.OrderByDescending(x => x.Hours))
          {
            var sc = t.Status == "Completed" ? "success" : t.Status == "In Progress" ? "primary" : "muted";
            <tr>
              <td><strong>@t.TaskTitle</strong></td>
              <td><span class="rpt-badge @sc">@t.Status</span></td>
              <td style="text-align:right;font-weight:600;">@Math.Round(t.Hours, 1) hrs</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <!-- Weekly Breakdown -->
  @if (Model.WeeklyBreakdown.Any())
  {
    <div class="rpt-section">
      <div class="rpt-section-head green">
        <div class="rpt-sec-icon">📆</div>
        <h3>Weekly Breakdown</h3>
      </div>
      <table class="rpt-table">
        <thead><tr>
          <th>Week</th>
          <th style="text-align:center">Tasks</th>
          <th style="text-align:right">Hours</th>
        </tr></thead>
        <tbody>
          @foreach (var w in Model.WeeklyBreakdown.OrderBy(x => x.WeekStartDate))
          {
            <tr>
              <td>@w.WeekStartDate.ToString("MMM dd") – @w.WeekEndDate.ToString("MMM dd, yyyy")</td>
              <td style="text-align:center">@w.TaskCount</td>
              <td style="text-align:right;font-weight:600;">@Math.Round(w.Hours, 1) hrs</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <div class="rpt-footer">
    <div><strong>Doable</strong> Project Management System</div>
    <div>Generated @Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</div>
  </div>

</div>
<script>window.onload = function(){ window.print(); }</script>
</body>
</html>
