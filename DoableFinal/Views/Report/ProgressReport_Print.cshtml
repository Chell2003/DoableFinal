@model DoableFinal.ViewModels.ProgressReportViewModel
@{
    ViewData["Title"] = "Progress Report";
    Layout = null;

    string HealthColor(string h) => h?.ToLower() switch {
        "green"    => "success",
        "yellow"   => "warning",
        "red"      => "danger",
        "on track" => "success",
        "at risk"  => "warning",
        "delayed"  => "danger",
        "adequate" => "success",
        "good"     => "success",
        "fair"     => "warning",
        "poor"     => "danger",
        _          => "muted"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>Progress Report — @Model.ProjectName</title>
<link href="/css/reports-print.css" rel="stylesheet"/>
</head>
<body>
<div class="rpt-page">

  <!-- Cover -->
  <div class="rpt-cover">
    <div class="rpt-cover-left">
      <div class="rpt-report-type">Project Progress Report</div>
      <div class="rpt-title">@Model.ProjectName</div>
      <div class="rpt-meta">
        <span><strong>Status</strong></span>
        <span>@(Model.ProjectStatus ?? "—")</span>
        <span><strong>Start Date</strong></span>
        <span>@Model.ProjectStartDate.ToString("MMMM dd, yyyy")</span>
        <span><strong>Expected End</strong></span>
        <span>@(Model.ProjectExpectedEndDate?.ToString("MMMM dd, yyyy") ?? Model.ProjectEndDate?.ToString("MMMM dd, yyyy") ?? "Not set")</span>
        <span><strong>Generated</strong></span>
        <span>@Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</span>
      </div>
    </div>
    <img src="/images/logo-combined2.png" alt="Doable" class="rpt-logo"/>
  </div>

  <div class="rpt-watermark-bar">
    <span>Doable Project Management System</span>
    <span>CONFIDENTIAL</span>
  </div>

  <!-- KPI -->
  <div class="rpt-kpi-grid cols-4">
    <div class="rpt-kpi @(Model.CompletionPercentage >= 75 ? "green" : Model.CompletionPercentage >= 40 ? "yellow" : "red")">
      <div class="rpt-kpi-val">@Math.Round(Model.CompletionPercentage, 0)%</div>
      <div class="rpt-kpi-lbl">Completion</div>
    </div>
    <div class="rpt-kpi green">
      <div class="rpt-kpi-val">@Model.TaskBreakdown.CompletedTasks</div>
      <div class="rpt-kpi-lbl">Completed</div>
    </div>
    <div class="rpt-kpi blue">
      <div class="rpt-kpi-val">@Model.TaskBreakdown.InProgressTasks</div>
      <div class="rpt-kpi-lbl">In Progress</div>
    </div>
    <div class="rpt-kpi red">
      <div class="rpt-kpi-val">@Model.TaskBreakdown.OverdueTasks</div>
      <div class="rpt-kpi-lbl">Overdue</div>
    </div>
  </div>

  <!-- Progress Bar -->
  <div class="rpt-section">
    <div class="rpt-section-head blue">
      <div class="rpt-sec-icon">📊</div>
      <h3>Overall Progress</h3>
      <span class="rpt-count">@Math.Round(Model.CompletionPercentage, 1)% Complete</span>
    </div>
    <div class="rpt-progress-wrap">
      <div class="rpt-progress-fill" style="width:@Model.CompletionPercentage%">
        @Math.Round(Model.CompletionPercentage, 0)%
      </div>
    </div>
    <p style="font-size:8.5pt;color:#64748b;margin-top:6px;">
      @Model.TaskBreakdown.CompletedTasks of @Model.TaskBreakdown.TotalTasks tasks completed
      &nbsp;·&nbsp; @Model.TaskBreakdown.NotStartedTasks not started
      &nbsp;·&nbsp; @Model.TaskBreakdown.OverdueTasks overdue
    </p>
  </div>

  <!-- Health Indicators -->
  <div class="rpt-section">
    <div class="rpt-section-head @HealthColor(Model.HealthIndicator.OverallHealth)">
      <div class="rpt-sec-icon">🏥</div>
      <h3>Project Health</h3>
      <span class="rpt-count rpt-badge @HealthColor(Model.HealthIndicator.OverallHealth)">@(Model.HealthIndicator.OverallHealth ?? "—")</span>
    </div>
    <div class="rpt-kpi-grid cols-3" style="margin-bottom:12px;">
      <div class="rpt-kpi @HealthColor(Model.HealthIndicator.ScheduleHealth)">
        <div class="rpt-kpi-val" style="font-size:13pt;">@(Model.HealthIndicator.ScheduleHealth ?? "—")</div>
        <div class="rpt-kpi-lbl">Schedule</div>
      </div>
      <div class="rpt-kpi @HealthColor(Model.HealthIndicator.ResourceHealth)">
        <div class="rpt-kpi-val" style="font-size:13pt;">@(Model.HealthIndicator.ResourceHealth ?? "—")</div>
        <div class="rpt-kpi-lbl">Resources</div>
      </div>
      <div class="rpt-kpi @HealthColor(Model.HealthIndicator.QualityHealth)">
        <div class="rpt-kpi-val" style="font-size:13pt;">@(Model.HealthIndicator.QualityHealth ?? "—")</div>
        <div class="rpt-kpi-lbl">Quality</div>
      </div>
    </div>

    @if (Model.HealthIndicator.Achievements.Any() || Model.HealthIndicator.Risks.Any())
    {
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:4px;">
        @if (Model.HealthIndicator.Achievements.Any())
        {
          <div>
            <div style="font-size:8pt;font-weight:700;text-transform:uppercase;color:#16a34a;margin-bottom:6px;">✅ Achievements</div>
            @foreach (var a in Model.HealthIndicator.Achievements)
            {
              <div style="font-size:8.5pt;padding:3px 0;border-bottom:1px solid #e2e8f0;">@a</div>
            }
          </div>
        }
        @if (Model.HealthIndicator.Risks.Any())
        {
          <div>
            <div style="font-size:8pt;font-weight:700;text-transform:uppercase;color:#dc2626;margin-bottom:6px;">⚠️ Risks</div>
            @foreach (var r in Model.HealthIndicator.Risks)
            {
              <div style="font-size:8.5pt;padding:3px 0;border-bottom:1px solid #e2e8f0;">@r</div>
            }
          </div>
        }
      </div>
    }
  </div>

  <!-- Milestones -->
  @if (Model.Milestones.Any())
  {
    <div class="rpt-section">
      <div class="rpt-section-head teal">
        <div class="rpt-sec-icon">🏁</div>
        <h3>Milestones</h3>
        <span class="rpt-count">@Model.Milestones.Count</span>
      </div>
      <table class="rpt-table">
        <thead><tr>
          <th>#</th>
          <th style="width:40%">Milestone</th>
          <th>Target Date</th>
          <th>Completed</th>
          <th style="text-align:center">Status</th>
        </tr></thead>
        <tbody>
          @foreach (var m in Model.Milestones.OrderBy(x => x.MilestoneIndex))
          {
            var mc = m.Status switch {
              "Completed" => "success",
              "On Track"  => "primary",
              "At Risk"   => "warning",
              "Delayed"   => "danger",
              _           => "muted"
            };
            <tr>
              <td style="color:#64748b;font-size:8pt;">@m.MilestoneIndex</td>
              <td>
                <strong>@m.Title</strong>
                @if (!string.IsNullOrEmpty(m.Description))
                { <br/><span style="font-size:8pt;color:#64748b;">@m.Description</span> }
              </td>
              <td>@m.TargetDate.ToString("MMM dd, yyyy")</td>
              <td>@(m.CompletedDate?.ToString("MMM dd, yyyy") ?? "—")</td>
              <td style="text-align:center"><span class="rpt-badge @mc">@m.Status</span></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  <div class="rpt-footer">
    <div><strong>Doable</strong> Project Management System</div>
    <div>Generated @Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</div>
  </div>

</div>
<script>window.onload = function(){ window.print(); }</script>
</body>
</html>
