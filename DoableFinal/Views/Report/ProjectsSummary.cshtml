@model List<DoableFinal.ViewModels.ProjectCategoryReportGroup>

@{
    ViewData["Title"] = "Projects Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var fromDate      = ViewBag.FromDate as string ?? "";
    var toDate        = ViewBag.ToDate   as string ?? "";
    var fromDisplay   = ViewBag.FromDateDisplay as string ?? "";
    var toDisplay     = ViewBag.ToDateDisplay   as string ?? "";
    var selectedCat   = ViewBag.SelectedCategory as string;
    var allCategories = ViewBag.AllCategories as List<string> ?? new List<string>();
    var totalProjects = (int)(ViewBag.TotalProjects ?? 0);

    // Grand totals
    var grandTasks       = Model.Sum(g => g.TotalTasks);
    var grandCompleted   = Model.Sum(g => g.CompletedTasks);
    var grandInProgress  = Model.Sum(g => g.InProgressTasks);
    var grandNotStarted  = Model.Sum(g => g.NotStartedTasks);
    var grandAvg         = Model.Any() ? (int)Math.Round(Model.Average(g => (double)g.AvgProgress)) : 0;
}

<style>
    /* ── Page ─────────────────────────────── */
    .rpt-page { font-family: 'Segoe UI', Arial, sans-serif; color: #222; }

    /* ── Breadcrumb ──────────────────────── */
    .rpt-bc { font-size: .78rem; color: #888; margin-bottom: 6px; }
    .rpt-bc a { color: #888; text-decoration: none; }
    .rpt-bc a:hover { text-decoration: underline; }

    /* ── Page title row ──────────────────── */
    .rpt-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }
    .rpt-title { font-size: 1.35rem; font-weight: 700; color: #1a1a2e; margin: 0; }
    .rpt-print-btn {
        background: #fff;
        border: 1px solid #ccc;
        border-radius: 5px;
        padding: 5px 10px;
        cursor: pointer;
        font-size: .82rem;
        color: #444;
        display: flex; align-items: center; gap: 5px;
    }
    .rpt-print-btn:hover { background: #f5f5f5; }

    /* ── Filter panel ────────────────────── */
    .filter-panel {
        border: 1px solid #ddd;
        border-radius: 4px;
        background: #f9f9f9;
        margin-bottom: 18px;
    }
    .filter-panel .fp-head {
        padding: 8px 14px;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #555;
        border-bottom: 1px solid #ddd;
    }
    .filter-panel .fp-body {
        padding: 14px 16px;
        display: flex;
        align-items: flex-end;
        gap: 12px;
        flex-wrap: wrap;
    }
    .filter-panel .fp-field label {
        display: block;
        font-size: .78rem;
        font-weight: 600;
        color: #444;
        margin-bottom: 4px;
    }
    .filter-panel .fp-field input,
    .filter-panel .fp-field select {
        border: 1px solid #ccc;
        border-radius: 4px;
        padding: 6px 10px;
        font-size: .85rem;
        color: #222;
        background: #fff;
        height: 34px;
        min-width: 160px;
    }
    .generate-btn {
        background: #1a73e8;
        color: #fff;
        border: none;
        border-radius: 4px;
        padding: 0 20px;
        height: 34px;
        font-size: .85rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
    }
    .generate-btn:hover { background: #1558c0; }

    /* ── Report section ──────────────────── */
    .report-section {
        border: 1px solid #ddd;
        border-radius: 4px;
        background: #fff;
    }
    .report-section .rs-head {
        padding: 8px 14px;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #555;
        border-bottom: 1px solid #eee;
    }
    .report-section .rs-body { padding: 22px 24px 18px; }

    /* ── Report inner title ──────────────── */
    .report-inner-title { font-size: 1.4rem; font-weight: 800; margin: 0 0 2px; color: #111; }
    .report-date-range  { font-size: .82rem; color: #666; margin-bottom: 18px; }

    /* ── Table ───────────────────────────── */
    .rpt-table { width: 100%; border-collapse: collapse; font-size: .84rem; }
    .rpt-table th {
        background: #f1f1f1;
        border: 1px solid #ddd;
        padding: 7px 10px;
        text-align: right;
        font-weight: 700;
        font-size: .78rem;
        color: #333;
        white-space: nowrap;
    }
    .rpt-table th:first-child { text-align: left; }
    .rpt-table td {
        border: 1px solid #e8e8e8;
        padding: 6px 10px;
        text-align: right;
        color: #222;
    }
    .rpt-table td:first-child { text-align: left; }

    /* Category header row */
    .rpt-table tr.cat-year-row td {
        background: #f7f7f7;
        font-weight: 700;
        color: #222;
        font-size: .82rem;
    }
    /* Active rows (has data) — first-col link */
    .rpt-table tr.has-data td:first-child a {
        color: #1a73e8;
        text-decoration: none;
        font-weight: 600;
    }
    .rpt-table tr.has-data td:first-child a:hover { text-decoration: underline; }
    /* Inactive rows */
    .rpt-table tr.no-data td { color: #aaa; }

    /* Total row */
    .rpt-table tr.total-row td {
        background: #f1f1f1;
        font-weight: 800;
        border-top: 2px solid #bbb;
        color: #111;
    }

    /* Progress bar inside cell */
    .inline-bar {
        display: inline-block;
        width: 60px;
        height: 7px;
        background: #e0e0e0;
        border-radius: 4px;
        overflow: hidden;
        vertical-align: middle;
        margin-right: 5px;
    }
    .inline-bar .fill { height: 100%; border-radius: 4px; background: #1a73e8; }

    /* Status badge */
    .s-badge {
        display: inline-block;
        padding: 1px 7px;
        border-radius: 10px;
        font-size: .72rem;
        font-weight: 700;
        color: #fff;
    }

    @@media print {
        .no-print { display: none !important; }
        .filter-panel { display: none !important; }
        body { font-size: 10pt; }
    }
</style>

<div class="rpt-page container-fluid px-4">

    <!-- Breadcrumb -->
    <div class="rpt-bc">
        <a href="@Url.Action("Index")">Reports</a> / Projects Report
    </div>

    <!-- Title + print -->
    <div class="rpt-title-row">
        <h1 class="rpt-title">PROJECTS REPORT</h1>
        <button class="rpt-print-btn no-print" onclick="window.print()">
            🖨 Print
        </button>
    </div>

    <!-- Filter panel -->
    <div class="filter-panel no-print">
        <div class="fp-head">Filter</div>
        <form method="get" asp-action="ProjectsSummary">
            <div class="fp-body">
                <div class="fp-field">
                    <label>From</label>
                    <input type="date" name="fromDate" value="@fromDate" />
                </div>
                <div class="fp-field">
                    <label>To</label>
                    <input type="date" name="toDate" value="@toDate" />
                </div>
                @if (allCategories.Any())
                {
                    <div class="fp-field">
                        <label>Category</label>
                        <select name="category">
                            <option value="">All Categories</option>
                            @foreach (var c in allCategories)
                            {
                                <option value="@c" selected="@(selectedCat == c ? "selected" : null)">@c</option>
                            }
                        </select>
                    </div>
                }
                <button type="submit" class="generate-btn">Generate Report</button>
                @if (!string.IsNullOrEmpty(selectedCat) || !string.IsNullOrEmpty(fromDate))
                {
                    <a href="@Url.Action("ProjectsSummary")" style="font-size:.8rem; color:#888; align-self:center;">✕ Reset</a>
                }
            </div>
        </form>
    </div>

    <!-- Report output -->
    <div class="report-section">
        <div class="rs-head">Report</div>
        <div class="rs-body">

            <div class="report-inner-title">
                @(string.IsNullOrEmpty(selectedCat) ? "ALL PROJECTS" : selectedCat.ToUpper())
            </div>
            <div class="report-date-range">
                @fromDisplay.ToUpper() — @toDisplay.ToUpper()
                @if (!string.IsNullOrEmpty(selectedCat))
                {
                    <span style="margin-left:8px; color:#1a73e8; font-weight:600;">· @selectedCat</span>
                }
            </div>

            @if (!Model.Any())
            {
                <div style="color:#888; padding:2rem 0; text-align:center;">
                    No projects found for the selected filters.
                </div>
            }
            else
            {
                <table class="rpt-table">
                    <thead>
                        <tr>
                            <th style="width:32%;">Project</th>
                            <th>Client</th>
                            <th>Status</th>
                            <th>Start</th>
                            <th>Due</th>
                            <th>Total Tasks</th>
                            <th>Completed</th>
                            <th>In Progress</th>
                            <th>Not Started</th>
                            <th>Progress</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in Model)
                        {
                            <!-- Category header row -->
                            <tr class="cat-year-row">
                                <td colspan="10">📁 @group.Category</td>
                            </tr>

                            @foreach (var p in group.Projects)
                            {
                                var hasData = p.TotalTasks > 0;
                                var rowClass = hasData ? "has-data" : "no-data";
                                var statusColor = p.Status switch {
                                    "Completed"   => "#10b981",
                                    "In Progress" => "#3b82f6",
                                    "On Hold"     => "#f59e0b",
                                    _             => "#9ca3af"
                                };

                                <tr class="@rowClass">
                                    <td>
                                        @if (hasData)
                                        {
                                            <a asp-controller="Report" asp-action="Status" asp-route-id="@p.Id">@p.Name</a>
                                        }
                                        else
                                        {
                                            @p.Name
                                        }
                                    </td>
                                    <td>@p.ClientName</td>
                                    <td>
                                        <span class="s-badge" style="background:@statusColor;">@p.Status</span>
                                    </td>
                                    <td>@p.StartDate.ToString("MMM dd, yyyy")</td>
                                    <td>@(p.EndDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                    <td>@p.TotalTasks</td>
                                    <td style="color:#10b981; font-weight:@(hasData?"700":"400");">@p.CompletedTasks</td>
                                    <td style="color:#3b82f6; font-weight:@(hasData?"700":"400");">@p.InProgressTasks</td>
                                    <td>@p.NotStartedTasks</td>
                                    <td>
                                        <div class="inline-bar">
                                            <div class="fill" style="width:@p.Progress%;"></div>
                                        </div>
                                        @p.Progress%
                                    </td>
                                </tr>
                            }

                            <!-- Category subtotal -->
                            <tr class="total-row">
                                <td style="text-align:left;">Subtotal — @group.Category</td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td>@group.TotalTasks</td>
                                <td style="color:#10b981;">@group.CompletedTasks</td>
                                <td style="color:#3b82f6;">@group.InProgressTasks</td>
                                <td>@group.NotStartedTasks</td>
                                <td>@group.AvgProgress%</td>
                            </tr>
                        }

                        <!-- Grand total -->
                        <tr class="total-row">
                            <td style="text-align:left;">TOTAL</td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td>@grandTasks</td>
                            <td style="color:#10b981;">@grandCompleted</td>
                            <td style="color:#3b82f6;">@grandInProgress</td>
                            <td>@grandNotStarted</td>
                            <td>@grandAvg%</td>
                        </tr>
                    </tbody>
                </table>
            }

        </div>
    </div>

</div>
