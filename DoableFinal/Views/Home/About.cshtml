@{
    ViewData["Title"] = "About Us";

    var sections = ViewBag.Sections as List<DoableFinal.Models.HomePageSection> ?? new List<DoableFinal.Models.HomePageSection>();

    var heroTitle      = sections?.FirstOrDefault(s => s.SectionKey == "about-hero-title")?.Content      ?? "About QONNEC";
    var heroBody       = sections?.FirstOrDefault(s => s.SectionKey == "about-hero-body")?.Content       ?? "We're committed to excellence";
    var storyTitle     = sections?.FirstOrDefault(s => s.SectionKey == "about-story-title")?.Content     ?? "Our Story";
    var storyIntro     = sections?.FirstOrDefault(s => s.SectionKey == "about-story-intro")?.Content     ?? "";
    var storyContent   = sections?.FirstOrDefault(s => s.SectionKey == "about-story-content")?.Content   ?? "";
    var missionTitle   = sections?.FirstOrDefault(s => s.SectionKey == "about-mission-title")?.Content   ?? "Our Mission";
    var missionContent = sections?.FirstOrDefault(s => s.SectionKey == "about-mission-content")?.Content ?? "";
    var valuesTitle    = sections?.FirstOrDefault(s => s.SectionKey == "about-values-title")?.Content    ?? "Our Core Values";
    var value1Title    = sections?.FirstOrDefault(s => s.SectionKey == "about-value-1-title")?.Content   ?? "Innovation";
    var value1Body     = sections?.FirstOrDefault(s => s.SectionKey == "about-value-1-body")?.Content    ?? "";
    var value2Title    = sections?.FirstOrDefault(s => s.SectionKey == "about-value-2-title")?.Content   ?? "Collaboration";
    var value2Body     = sections?.FirstOrDefault(s => s.SectionKey == "about-value-2-body")?.Content    ?? "";
    var value3Title    = sections?.FirstOrDefault(s => s.SectionKey == "about-value-3-title")?.Content   ?? "Integrity";
    var value3Body     = sections?.FirstOrDefault(s => s.SectionKey == "about-value-3-body")?.Content    ?? "";
}

<style>
    /* =============================================
       ABOUT PAGE — #347deb theme (matches Index)
       ============================================= */

    /* ---------- Keyframes ---------- */
    @@keyframes heroFadeUp {
        from { opacity: 0; transform: translateY(40px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes heroFloat {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-10px); }
    }

    @@keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.25); }
        50%       { box-shadow: 0 0 22px 8px rgba(255, 255, 255, 0.12); }
    }

    @@keyframes shimmerMove {
        0%   { background-position: -200% center; }
        100% { background-position:  200% center; }
    }

    @@keyframes orbDrift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33%       { transform: translate(18px, -12px) scale(1.04); }
        66%       { transform: translate(-10px, 8px) scale(0.97); }
    }

    @@keyframes ctaPulse {
        0%, 100% { box-shadow: 0 4px 20px rgba(52, 125, 235, 0.30); }
        50%       { box-shadow: 0 8px 36px rgba(52, 125, 235, 0.52); }
    }

    .landing-header {
        box-shadow: 0 2px 16px rgba(52, 125, 235, 0.08) !important;
        border-bottom: 1px solid rgba(52, 125, 235, 0.10) !important;
    }

    .landing-header .navbar-brand img {
        transition: transform 0.2s;
    }

    .landing-header .navbar-brand img:hover {
        transform: scale(1.04);
    }

    .landing-header .nav-link.text-dark {
        font-size: 0.88rem;
        font-weight: 500;
        color: #2d3a55 !important;
        padding: 0.4rem 0.9rem;
        border-radius: 8px;
        transition: background 0.18s, color 0.18s;
        position: relative;
    }

    .landing-header .nav-link.text-dark::after {
        content: '';
        position: absolute;
        bottom: 2px;
        left: 50%;
        transform: translateX(-50%) scaleX(0);
        width: 60%;
        height: 2px;
        background: #347deb;
        border-radius: 2px;
        transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .landing-header .nav-link.text-dark:hover {
        color: #347deb !important;
        background: rgba(52, 125, 235, 0.07);
    }

    .landing-header .nav-link.text-dark:hover::after {
        transform: translateX(-50%) scaleX(1);
    }

    /* ---------- Hero Section (identical to Index) ---------- */
    .hero-section {
        background: linear-gradient(135deg, #0f2660 0%, #1a3f80 30%, #2360c8 65%, #347deb 100%) !important;
        position: relative;
        overflow: hidden;
        min-height: 480px;
        display: flex;
        align-items: center;
    }

    .hero-section::before,
    .hero-section::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }

    .hero-section::before {
        width: 420px; height: 420px;
        top: -120px; right: -100px;
        background: rgba(255, 255, 255, 0.05);
        animation: orbDrift 9s ease-in-out infinite;
    }

    .hero-section::after {
        width: 280px; height: 280px;
        bottom: -80px; left: -60px;
        background: rgba(255, 255, 255, 0.04);
        animation: orbDrift 12s ease-in-out infinite reverse;
    }

    .hero-section .container::after {
        content: '';
        display: block;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
        background-size: 200% auto;
        animation: shimmerMove 3s linear infinite;
        margin-top: 2rem;
        border-radius: 2px;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: .72rem;
        font-weight: 500;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.75);
        margin-bottom: 20px;
        animation: heroFadeUp .6s cubic-bezier(.22,1,.36,1) .05s both;
    }

    .hero-eyebrow span {
        display: inline-block;
        width: 28px; height: 1px;
        background: rgba(255, 255, 255, 0.6);
    }

    .hero-title-anim {
        animation: heroFadeUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
    }

    .hero-section h1 {
        text-shadow: 0 2px 16px rgba(10, 30, 80, 0.25);
    }

    .hero-body-anim {
        animation: heroFadeUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.3s both;
    }

    .hero-section .lead {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.7;
        max-width: 600px;
        margin: 0 auto 1.5rem;
    }

    /* Hero Stats */
    .hero-stats-anim {
        animation: heroFadeUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.5s both;
    }

    .hero-stats {
        display: flex;
        justify-content: center;
        gap: 48px;
        flex-wrap: wrap;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.10);
        position: relative;
    }

    .hero-stat-num {
        font-family: 'League Spartan', sans-serif;
        font-size: 2.2rem;
        font-weight: 700;
        color: #fff;
        line-height: 1;
    }

    .hero-stat-label {
        font-size: .7rem;
        font-weight: 500;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.65);
        margin-top: 6px;
    }

    /* ---------- Scroll Reveal (identical to Index) ---------- */
    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.10s; }
    .reveal-delay-2 { transition-delay: 0.22s; }
    .reveal-delay-3 { transition-delay: 0.34s; }

    /* ---------- Section Label ---------- */
    .section-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: .7rem;
        font-weight: 500;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: #347deb;
        margin-bottom: 14px;
    }

    .section-label::before {
        content: '';
        display: inline-block;
        width: 22px; height: 2px;
        background: #347deb;
        border-radius: 1px;
    }

    /* ---------- Section Headings (matches Index) ---------- */
    .section-heading-wrap {
        text-align: center;
        margin-bottom: 3rem;
    }

    .section-heading {
        font-size: 1.9rem;
        font-weight: 700;
        color: #1a3f80;
        letter-spacing: -0.4px;
        position: relative;
        display: inline-block;
    }

    .section-heading::after {
        content: '';
        position: absolute;
        left: 50%;
        bottom: -8px;
        transform: translateX(-50%) scaleX(0);
        width: 55%;
        height: 3px;
        background: linear-gradient(90deg, #347deb, #60aaff);
        border-radius: 2px;
        transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.3s;
    }

    .section-heading.visible::after {
        transform: translateX(-50%) scaleX(1);
    }

    /* ---------- Story Section ---------- */
    .about-story {
        background: #ffffff;
        padding: 5rem 0;
    }

    .story-inner {
        position: relative;
    }

    .story-deco {
        font-size: 14rem;
        line-height: .8;
        color: rgba(52, 125, 235, 0.05);
        position: absolute;
        top: -20px; right: -10px;
        pointer-events: none;
        user-select: none;
        font-weight: 900;
    }

    .story-heading {
        font-size: 1.9rem;
        font-weight: 700;
        color: #1a3f80;
        letter-spacing: -0.4px;
        margin-bottom: 1.5rem;
    }

    .story-intro-text {
        font-size: 1.1rem;
        color: #0d1117;
        line-height: 1.78;
        border-left: 3px solid #347deb;
        padding-left: 20px;
        margin-bottom: 1.5rem;
        border-radius: 0;
    }

    .story-body-text {
        font-size: .95rem;
        font-weight: 300;
        color: #4a5568;
        line-height: 1.9;
    }

    .story-body-text p {
        margin-bottom: 1.4rem;
    }

    /* ---------- Mission Section ---------- */
    .about-mission {
        background: #f4f7fd;
        padding: 5rem 0;
        position: relative;
        overflow: hidden;
    }

    .about-mission::before {
        content: '';
        position: absolute;
        top: 0; right: 0;
        width: 40%; height: 100%;
        background: linear-gradient(135deg, transparent 45%, rgba(52, 125, 235, 0.04) 45%);
        pointer-events: none;
    }

    .mission-card {
        background: #fff;
        border-radius: 18px;
        padding: 48px 52px;
        border-left: 5px solid #347deb;
        border-top: none; border-right: none; border-bottom: none;
        border-radius: 0 18px 18px 18px;
        box-shadow: 0 4px 40px rgba(52, 125, 235, 0.10);
        position: relative;
        overflow: hidden;
    }

    .mission-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, #1a3f80, #347deb, #60aaff);
        background-size: 200% auto;
        animation: shimmerMove 3.5s linear infinite;
    }

    .mission-card::after {
        content: '';
        position: absolute;
        bottom: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(52, 125, 235, 0.04);
        pointer-events: none;
    }

    .mission-heading {
        font-size: 1.7rem;
        font-weight: 700;
        color: #1a3f80;
        margin-bottom: 1rem;
        letter-spacing: -0.3px;
    }

    .mission-text {
        font-size: 1rem;
        font-weight: 300;
        color: #6b84b0;
        line-height: 1.88;
        margin: 0;
    }

    /* ---------- Values Section (matches Index feature cards exactly) ---------- */
    .about-values {
        background: #ffffff;
        padding: 5rem 0;
    }

    .feature-card {
        border-radius: 18px !important;
        border: 1px solid rgba(52, 125, 235, 0.08) !important;
        background: #fff;
        box-shadow: 0 2px 18px rgba(52, 125, 235, 0.08) !important;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.3s ease;
        cursor: default;
        position: relative;
        overflow: hidden;
    }

    .feature-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, #1a3f80, #347deb, #60aaff);
        background-size: 200% auto;
        animation: shimmerMove 3.5s linear infinite;
        border-radius: 18px 18px 0 0;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .feature-card:hover::before {
        opacity: 1;
    }

    .feature-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 18px 44px rgba(52, 125, 235, 0.16) !important;
    }

    .feature-card .card-body {
        padding: 2.2rem 1.5rem 2rem;
    }

    .value-number {
        font-size: 3.5rem;
        font-weight: 900;
        color: rgba(52, 125, 235, 0.07);
        line-height: 1;
        margin-bottom: 0.5rem;
        transition: color 0.3s;
    }

    .feature-card:hover .value-number {
        color: rgba(52, 125, 235, 0.14);
    }

    .feature-card h3.h5 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1a3f80;
        margin-bottom: 0.6rem;
    }

    .feature-card p {
        font-size: 0.88rem;
        color: #6b84b0;
        line-height: 1.65;
        margin: 0;
    }

    /* ---------- CTA Section (identical to Index) ---------- */
    .bg-light.py-5 {
        background: linear-gradient(160deg, #eef3fc 0%, #f8faff 50%, #e6eef9 100%) !important;
        padding: 5rem 0;
        position: relative;
        overflow: hidden;
    }

    .bg-light.py-5::before {
        content: '';
        position: absolute;
        top: -80px; right: -80px;
        width: 300px; height: 300px;
        border-radius: 50%;
        background: rgba(52, 125, 235, 0.06);
        pointer-events: none;
    }

    .bg-light.py-5 h2 {
        font-size: 1.9rem;
        font-weight: 700;
        color: #1a3f80;
        letter-spacing: -0.3px;
    }

    .bg-light.py-5 .lead {
        font-size: 1rem;
        color: #6b84b0;
        max-width: 540px;
        margin: 0 auto 1.5rem;
        line-height: 1.7;
    }

    .cta-btn,
    .bg-light.py-5 .btn-primary {
        background: linear-gradient(135deg, #347deb, #1a3f80);
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 700;
        padding: 0.8rem 2.2rem;
        letter-spacing: 0.2px;
        animation: ctaPulse 2.8s ease-in-out infinite;
        transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.25s ease, background 0.2s;
    }

    .cta-btn:hover,
    .bg-light.py-5 .btn-primary:hover {
        background: linear-gradient(135deg, #1f62cc, #12317a);
        border: none;
        transform: translateY(-4px) scale(1.05);
        box-shadow: 0 12px 36px rgba(52, 125, 235, 0.45) !important;
    }

    /* ---------- Admin Edit Banner (matches Index) ---------- */
    .alert-info {
        background: rgba(52, 125, 235, 0.09);
        border: 1px solid rgba(52, 125, 235, 0.20);
        border-radius: 0;
        color: #1a3f80;
        font-size: 0.88rem;
        text-align: center;
    }

    .alert-info .btn-primary {
        background: linear-gradient(135deg, #347deb, #1a3f80);
        border: none;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.35rem 0.9rem;
        animation: none;
        box-shadow: none;
        transition: transform 0.15s, box-shadow 0.15s;
    }

    .alert-info .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(52, 125, 235, 0.30);
    }

    /* ---------- Responsive ---------- */
    @@media (max-width: 768px) {
        .hero-section {
            min-height: auto;
            padding: 3.5rem 0;
            text-align: center;
        }

        .hero-section h1 {
            font-size: 3rem !important;
        }

        .hero-section .lead {
            font-size: 0.95rem;
        }

        .hero-stats {
            gap: 28px;
        }

        .story-deco {
            display: none;
        }

        .mission-card {
            padding: 28px 24px;
        }

        .section-heading {
            font-size: 1.5rem;
        }

        .feature-card .card-body {
            padding: 1.6rem 1.2rem;
        }

        .bg-light.py-5 h2 {
            font-size: 1.5rem;
        }
    }
</style>

@if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("ProjectManager")))
{
    <div class="alert alert-info mb-0">
        <a asp-controller="Admin" asp-action="ManageAboutPage" class="btn btn-sm btn-primary">
            <i class="bi bi-pencil-square me-1"></i> Edit About Content
        </a>
    </div>
}

<!-- Hero Section -->
<section class="hero-section bg-primary text-white py-5 d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <div class="hero-eyebrow"><span></span> Who We Are <span></span></div>
                <div class="hero-title-anim">
                    <h1 class="display-4 fw-bold mb-4" style="font-family:'League Spartan', sans-serif; letter-spacing:-3px; font-size:4.5rem">
                        @Html.Raw(heroTitle)
                    </h1>
                </div>
                <div class="hero-body-anim">
                    <p class="lead mb-4">@Html.Raw(heroBody)</p>
                </div>
                <div class="hero-stats-anim">
                    <div class="hero-stats">
                        <div>
                            <div class="hero-stat-num">10K+</div>
                            <div class="hero-stat-label">Users</div>
                        </div>
                        <div>
                            <div class="hero-stat-num">500+</div>
                            <div class="hero-stat-label">Teams</div>
                        </div>
                        <div>
                            <div class="hero-stat-num">99%</div>
                            <div class="hero-stat-label">Uptime</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Story Section -->
<section class="about-story">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="story-inner">
                    <span class="story-deco" aria-hidden="true">"</span>
                    <div class="section-label reveal">Our Journey</div>
                    <h2 class="story-heading reveal reveal-delay-1">@Html.Raw(storyTitle)</h2>
                    @if (!string.IsNullOrEmpty(storyIntro?.ToString()))
                    {
                        <p class="story-intro-text reveal reveal-delay-2">@Html.Raw(storyIntro)</p>
                    }
                    <div class="story-body-text reveal reveal-delay-2">
                        @Html.Raw(storyContent)
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission Section -->
<section class="about-mission">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="section-label reveal">What Drives Us</div>
                <div class="mission-card reveal reveal-delay-1">
                    <h2 class="mission-heading">@Html.Raw(missionTitle)</h2>
                    <p class="mission-text">@Html.Raw(missionContent)</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="about-values" id="values">
    <div class="container">
        <div class="section-heading-wrap mb-5 reveal text-center">
            <div class="section-label" style="justify-content: center; margin-bottom: 10px;">What We Stand For</div>
            <h2 class="section-heading">@Html.Raw(valuesTitle)</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4 reveal reveal-delay-1">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="value-number">01</div>
                        <h3 class="h5">@Html.Raw(value1Title)</h3>
                        <p>@Html.Raw(value1Body)</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 reveal reveal-delay-2">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="value-number">02</div>
                        <h3 class="h5">@Html.Raw(value2Title)</h3>
                        <p>@Html.Raw(value2Body)</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 reveal reveal-delay-3">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="value-number">03</div>
                        <h3 class="h5">@Html.Raw(value3Title)</h3>
                        <p>@Html.Raw(value3Body)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="bg-light py-5">
    <div class="container text-center">
        <h2 class="mb-4 reveal">Ready to Get Started?</h2>
        <p class="lead mb-4 reveal reveal-delay-1">Join thousands of teams already using our platform to manage their projects.</p>
        <div class="reveal reveal-delay-2">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg cta-btn">Create Free Account</a>
        </div>
    </div>
</section>

<script>
    (function () {
        const targets = document.querySelectorAll('.reveal');
        if (!targets.length) return;

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        const heading = entry.target.querySelector('.section-heading');
                        if (heading) heading.classList.add('visible');
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.15 }
        );

        targets.forEach((el) => observer.observe(el));
    })();
</script>
