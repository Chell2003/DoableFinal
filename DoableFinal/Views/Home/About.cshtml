@{
    ViewData["Title"] = "About Us";

    var sections = ViewBag.Sections as List<DoableFinal.Models.HomePageSection> ?? new List<DoableFinal.Models.HomePageSection>();

    var heroTitle    = sections?.FirstOrDefault(s => s.SectionKey == "about-hero-title")?.Content    ?? "About Doable";
    var heroBody     = sections?.FirstOrDefault(s => s.SectionKey == "about-hero-body")?.Content     ?? "We're committed to excellence";
    var storyTitle   = sections?.FirstOrDefault(s => s.SectionKey == "about-story-title")?.Content   ?? "Our Story";
    var storyIntro   = sections?.FirstOrDefault(s => s.SectionKey == "about-story-intro")?.Content   ?? "";
    var storyContent = sections?.FirstOrDefault(s => s.SectionKey == "about-story-content")?.Content ?? "";
    var missionTitle   = sections?.FirstOrDefault(s => s.SectionKey == "about-mission-title")?.Content   ?? "Our Mission";
    var missionContent = sections?.FirstOrDefault(s => s.SectionKey == "about-mission-content")?.Content ?? "";
    var valuesTitle  = sections?.FirstOrDefault(s => s.SectionKey == "about-values-title")?.Content  ?? "Our Core Values";
    var value1Title  = sections?.FirstOrDefault(s => s.SectionKey == "about-value-1-title")?.Content ?? "Innovation";
    var value1Body   = sections?.FirstOrDefault(s => s.SectionKey == "about-value-1-body")?.Content  ?? "";
    var value2Title  = sections?.FirstOrDefault(s => s.SectionKey == "about-value-2-title")?.Content ?? "Collaboration";
    var value2Body   = sections?.FirstOrDefault(s => s.SectionKey == "about-value-2-body")?.Content  ?? "";
    var value3Title  = sections?.FirstOrDefault(s => s.SectionKey == "about-value-3-title")?.Content ?? "Integrity";
    var value3Body   = sections?.FirstOrDefault(s => s.SectionKey == "about-value-3-body")?.Content  ?? "";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">

<style>
/* ── Design tokens ── */
:root {
    --brand:      #0d6efd;
    --brand-dark: #0a58ca;
    --ink:        #0d1117;
    --ink-soft:   #4a5568;
    --surface:    #f8f9fa;
    --white:      #ffffff;
    --rule:       rgba(13,110,253,.15);
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body:    'DM Sans', sans-serif;
}

.about-page * { box-sizing: border-box; }
.about-page { font-family: var(--font-body); color: var(--ink); }

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
.about-hero {
    position: relative;
    background: var(--brand);
    overflow: hidden;
    padding: 100px 0 90px;
}
.about-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.08) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
}
.about-hero::after {
    content: '';
    position: absolute;
    top: -120px; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(255,255,255,.12) 0%, transparent 70%);
    pointer-events: none;
}
.about-hero .container { position: relative; z-index: 1; }

.hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: rgba(255,255,255,.75);
    margin-bottom: 20px;
    animation: heroFadeUp .6s cubic-bezier(.22,1,.36,1) .05s both;
}
.hero-eyebrow span {
    display: inline-block;
    width: 28px; height: 1px;
    background: rgba(255,255,255,.6);
}
.about-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 900;
    line-height: 1.08;
    color: var(--white);
    margin-bottom: 24px;
    animation: heroFadeUp .75s cubic-bezier(.22,1,.36,1) .15s both;
}
.about-hero .hero-lead {
    font-size: 1.1rem;
    font-weight: 300;
    color: rgba(255,255,255,.85);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.8;
    animation: heroFadeUp .75s cubic-bezier(.22,1,.36,1) .28s both;
}
.hero-stats {
    display: flex;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
    margin-top: 60px;
    padding-top: 44px;
    border-top: 1px solid rgba(255,255,255,.08);
    animation: heroFadeUp .75s cubic-bezier(.22,1,.36,1) .42s both;
}
.hero-stat-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
}
.hero-stat-label {
    font-size: .7rem;
    font-weight: 500;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.65);
    margin-top: 6px;
}

/* ══════════════════════════════════════
   SHARED SECTION LABEL
══════════════════════════════════════ */
.section-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: .7rem;
    font-weight: 500;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 14px;
}
.section-label::before {
    content: '';
    display: inline-block;
    width: 22px; height: 2px;
    background: var(--brand);
    border-radius: 1px;
}

/* ══════════════════════════════════════
   STORY
══════════════════════════════════════ */
.about-story { padding: 96px 0; background: var(--white); }

.story-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: 28px;
}
.story-intro-text {
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.78;
    border-left: 3px solid var(--brand);
    padding-left: 20px;
    margin-bottom: 24px;
}
.story-body-text {
    font-size: 1rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.9;
    text-align: justify;
}
.story-body-text p { margin-bottom: 1.4rem; }
.story-deco {
    font-family: var(--font-display);
    font-size: 14rem;
    line-height: .8;
    color: rgba(13,110,253,.05);
    position: absolute;
    top: -20px; right: -10px;
    pointer-events: none;
    user-select: none;
    font-weight: 900;
}

/* ══════════════════════════════════════
   MISSION
══════════════════════════════════════ */
.about-mission {
    padding: 96px 0;
    background: var(--surface);
    position: relative;
    overflow: hidden;
}
.about-mission::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 40%; height: 100%;
    background: linear-gradient(135deg, transparent 45%, rgba(13,110,253,.04) 45%);
    pointer-events: none;
}
.mission-card {
    background: var(--white);
    border-radius: 16px;
    padding: 48px 52px;
    box-shadow: 0 4px 40px rgba(13,17,23,.07);
    border-left: 5px solid var(--brand);
    position: relative;
    overflow: hidden;
}
.mission-card::after {
    content: '';
    position: absolute;
    bottom: -60px; right: -60px;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: rgba(13,110,253,.04);
    pointer-events: none;
}
.mission-heading {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 18px;
}
.mission-text {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.88;
    margin: 0;
}

/* ══════════════════════════════════════
   VALUES
══════════════════════════════════════ */
.about-values { padding: 96px 0; background: var(--white); }

.values-heading-wrap { text-align: center; margin-bottom: 56px; }
.values-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--ink);
    position: relative;
    display: inline-block;
}
.values-heading::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -10px;
    transform: translateX(-50%) scaleX(0);
    width: 50%;
    height: 3px;
    background: rgba(255,255,255,.6);
    border-radius: 2px;
    transition: transform .55s cubic-bezier(.22,1,.36,1) .3s;
}
.values-heading.visible::after { transform: translateX(-50%) scaleX(1); }

.value-card {
    background: var(--white);
    border-radius: 16px;
    padding: 40px 36px;
    height: 100%;
    border: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
    transition: transform .3s cubic-bezier(.34,1.56,.64,1),
                box-shadow .3s ease,
                border-color .3s ease;
}
.value-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, var(--brand), var(--brand-dark));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .4s cubic-bezier(.22,1,.36,1);
}
.value-card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 20px 50px rgba(13,110,253,.12);
    border-color: transparent;
}
.value-card:hover::before { transform: scaleX(1); }
.value-number {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 900;
    color: rgba(13,110,253,.07);
    line-height: 1;
    margin-bottom: 12px;
    transition: color .3s;
}
.value-card:hover .value-number { color: rgba(13,110,253,.14); }
.value-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--brand);
    margin-bottom: 14px;
}
.value-body {
    font-size: .95rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.8;
    margin: 0;
}

/* ══════════════════════════════════════
   SCROLL REVEAL
══════════════════════════════════════ */
.reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity .65s cubic-bezier(.22,1,.36,1),
                transform .65s cubic-bezier(.22,1,.36,1);
}
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-delay-1 { transition-delay: .12s; }
.reveal-delay-2 { transition-delay: .24s; }
.reveal-delay-3 { transition-delay: .36s; }

@@keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
}
</style>

<div class="about-page">

@if (User.IsInRole("Admin") || User.IsInRole("ProjectManager"))
{
    <div class="alert alert-info mb-0 rounded-0">
        <div class="container">
            <a href="@Url.Action("ManageAboutPage", "Admin")" class="btn btn-primary btn-sm">
                <i class="bi bi-pencil-square me-1"></i> Edit About Content
            </a>
        </div>
    </div>
}

<!-- ── HERO ── -->
<section class="about-hero">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <div class="hero-eyebrow"><span></span> Who We Are <span></span></div>
                <h1>@Html.Raw(heroTitle)</h1>
                <p class="hero-lead">@Html.Raw(heroBody)</p>
                <div class="hero-stats">
                    <div>
                        <div class="hero-stat-num">10K+</div>
                        <div class="hero-stat-label">Users</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">500+</div>
                        <div class="hero-stat-label">Teams</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">99%</div>
                        <div class="hero-stat-label">Uptime</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── STORY ── -->
<section class="about-story">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9" style="position:relative;">
                <span class="story-deco" aria-hidden="true">"</span>
                <div class="section-label reveal">Our Journey</div>
                <h2 class="story-heading reveal reveal-delay-1">@Html.Raw(storyTitle)</h2>
                @if (!string.IsNullOrEmpty(storyIntro?.ToString()))
                {
                    <p class="story-intro-text reveal reveal-delay-2">@Html.Raw(storyIntro)</p>
                }
                <div class="story-body-text reveal reveal-delay-2">
                    @Html.Raw(storyContent)
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── MISSION ── -->
<section class="about-mission">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="section-label reveal">What Drives Us</div>
                <div class="mission-card reveal reveal-delay-1">
                    <h2 class="mission-heading">@Html.Raw(missionTitle)</h2>
                    <p class="mission-text">@Html.Raw(missionContent)</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── VALUES ── -->
<section class="about-values">
    <div class="container">
        <div class="values-heading-wrap reveal">
            <div class="section-label" style="justify-content:center; margin-bottom:10px;">What We Stand For</div>
            <h2 class="values-heading">@Html.Raw(valuesTitle)</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 reveal reveal-delay-1">
                <div class="value-card">
                    <div class="value-number">01</div>
                    <div class="value-title">@Html.Raw(value1Title)</div>
                    <p class="value-body">@Html.Raw(value1Body)</p>
                </div>
            </div>
            <div class="col-lg-4 reveal reveal-delay-2">
                <div class="value-card">
                    <div class="value-number">02</div>
                    <div class="value-title">@Html.Raw(value2Title)</div>
                    <p class="value-body">@Html.Raw(value2Body)</p>
                </div>
            </div>
            <div class="col-lg-4 reveal reveal-delay-3">
                <div class="value-card">
                    <div class="value-number">03</div>
                    <div class="value-title">@Html.Raw(value3Title)</div>
                    <p class="value-body">@Html.Raw(value3Body)</p>
                </div>
            </div>
        </div>
    </div>
</section>

</div><!-- /about-page -->

<script>
(function () {
    const targets = document.querySelectorAll('.reveal, .values-heading');
    if (!targets.length) return;
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.12 });
    targets.forEach(el => observer.observe(el));
})();
</script>
