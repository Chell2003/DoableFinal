@model DoableFinal.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card text-center">

                    <div class="auth-icon">
                        <i class="bi bi-lock"></i>
                    </div>

                    <h2 class="auth-title">Reset Password</h2>
                    <p class="auth-subtitle">
                        Enter your new password below.
                    </p>

                    <form asp-action="ResetPassword" method="post">

                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="Code" />

                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                        <!-- Password -->
                        <div class="form-group mb-3 text-start">
                            <label asp-for="Password" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="Password" type="password" id="Password" class="form-control" />
                                <button type="button" class="btn-toggle" onclick="togglePassword('Password', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Confirm -->
                        <div class="form-group mb-3 text-start">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" type="password" id="ConfirmPassword" class="form-control" />
                                <button type="button" class="btn-toggle" onclick="togglePassword('ConfirmPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn-auth">
                            Reset Password
                        </button>
                    </form>

                    <div class="auth-footer mt-3">
                        <a asp-action="Login">Back to Login</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}