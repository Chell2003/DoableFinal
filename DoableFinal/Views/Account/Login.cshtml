@model DoableFinal.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<style>
    /* =============================================
       LOGIN PAGE — #347deb theme (matches Index)
       ============================================= */

    @@keyframes heroFadeUp {
        from { opacity: 0; transform: translateY(40px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes shimmerMove {
        0%   { background-position: -200% center; }
        100% { background-position:  200% center; }
    }

    @@keyframes orbDrift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33%       { transform: translate(18px, -12px) scale(1.04); }
        66%       { transform: translate(-10px, 8px) scale(0.97); }
    }

    @@keyframes ctaPulse {
        0%, 100% { box-shadow: 0 4px 20px rgba(52, 125, 235, 0.30); }
        50%       { box-shadow: 0 8px 36px rgba(52, 125, 235, 0.52); }
    }

    .landing-header {
        box-shadow: 0 2px 16px rgba(52, 125, 235, 0.08) !important;
        border-bottom: 1px solid rgba(52, 125, 235, 0.10) !important;
    }

    .landing-header .navbar-brand img {
        transition: transform 0.2s;
    }

    .landing-header .navbar-brand img:hover {
        transform: scale(1.04);
    }

    .landing-header .nav-link.text-dark {
        font-size: 0.88rem;
        font-weight: 500;
        color: #2d3a55 !important;
        padding: 0.4rem 0.9rem;
        border-radius: 8px;
        transition: background 0.18s, color 0.18s;
        position: relative;
    }

    .landing-header .nav-link.text-dark::after {
        content: '';
        position: absolute;
        bottom: 2px;
        left: 50%;
        transform: translateX(-50%) scaleX(0);
        width: 60%;
        height: 2px;
        background: #347deb;
        border-radius: 2px;
        transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .landing-header .nav-link.text-dark:hover {
        color: #347deb !important;
        background: rgba(52, 125, 235, 0.07);
    }

    .landing-header .nav-link.text-dark:hover::after {
        transform: translateX(-50%) scaleX(1);
    }

    /* ---------- Page wrapper ---------- */
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(160deg, #eef3fc 0%, #f8faff 50%, #e6eef9 100%);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding: 3rem 0;
    }

    .auth-page::before {
        content: '';
        position: absolute;
        width: 420px; height: 420px;
        top: -140px; right: -100px;
        border-radius: 50%;
        background: rgba(52, 125, 235, 0.07);
        animation: orbDrift 9s ease-in-out infinite;
        pointer-events: none;
    }

    .auth-page::after {
        content: '';
        position: absolute;
        width: 280px; height: 280px;
        bottom: -80px; left: -60px;
        border-radius: 50%;
        background: rgba(52, 125, 235, 0.05);
        animation: orbDrift 12s ease-in-out infinite reverse;
        pointer-events: none;
    }

    /* ---------- Card ---------- */
    .auth-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid rgba(52, 125, 235, 0.10);
        box-shadow: 0 4px 40px rgba(52, 125, 235, 0.10);
        padding: 3rem 3rem 2.4rem;
        position: relative;
        overflow: hidden;
        animation: heroFadeUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
    }

    .auth-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, #0f2660, #347deb, #60aaff);
        background-size: 200% auto;
        animation: shimmerMove 3s linear infinite;
    }

    /* ---------- Brand mark at top ---------- */
    .auth-brand {
        font-family: 'League Spartan', sans-serif;
        font-size: 1.6rem;
        font-weight: 900;
        letter-spacing: -2px;
        color: #1a3f80;
        margin-bottom: 0.2rem;
    }

    /* ---------- Page title ---------- */
    .auth-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a3f80;
        letter-spacing: -0.4px;
        margin-bottom: 0.2rem;
    }

    .auth-subtitle {
        font-size: 0.88rem;
        color: #6b84b0;
        margin-bottom: 2rem;
    }

    /* ---------- Form controls ---------- */
    .form-label {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: #1a3f80;
        margin-bottom: 5px;
    }

    .form-control {
        border: 1px solid rgba(52, 125, 235, 0.20);
        border-radius: 10px;
        padding: 11px 14px;
        font-size: .95rem;
        color: #0d1117;
        background: #f4f7fd;
        transition: border-color .25s, box-shadow .25s, background .25s;
    }

    .form-control:focus {
        border-color: #347deb;
        box-shadow: 0 0 0 3px rgba(52, 125, 235, 0.12);
        background: #fff;
        outline: none;
    }

    .input-group .form-control {
        border-right: none;
        border-radius: 10px 0 0 10px;
    }

    .input-group .btn-outline-secondary {
        border: 1px solid rgba(52, 125, 235, 0.20);
        border-left: none;
        border-radius: 0 10px 10px 0;
        background: #f4f7fd;
        color: #6b84b0;
        transition: background .2s, color .2s;
    }

    .input-group .btn-outline-secondary:hover {
        background: rgba(52, 125, 235, 0.10);
        color: #347deb;
    }

    .input-group:focus-within .btn-outline-secondary {
        border-color: #347deb;
        background: #fff;
    }

    /* ---------- Remember me ---------- */
    .form-check-input:checked {
        background-color: #347deb;
        border-color: #347deb;
    }

    .form-check-input:focus {
        box-shadow: 0 0 0 3px rgba(52, 125, 235, 0.12);
        border-color: #347deb;
    }

    .form-check-label {
        font-size: 0.88rem;
        color: #6b84b0;
    }

    /* ---------- Submit button ---------- */
    .btn-auth {
        background: linear-gradient(135deg, #347deb, #1a3f80);
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 700;
        padding: 0.78rem 2.2rem;
        color: #fff;
        letter-spacing: 0.2px;
        width: 100%;
        animation: ctaPulse 2.8s ease-in-out infinite;
        transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.25s ease, background 0.2s;
    }

    .btn-auth:hover {
        background: linear-gradient(135deg, #1f62cc, #12317a);
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 12px 36px rgba(52, 125, 235, 0.40) !important;
        color: #fff;
    }

    /* ---------- Footer link ---------- */
    .auth-footer {
        font-size: 0.88rem;
        color: #6b84b0;
    }

    .auth-footer a {
        color: #347deb;
        font-weight: 700;
        text-decoration: none;
        transition: color .2s;
    }

    .auth-footer a:hover {
        color: #1a3f80;
    }

    /* ---------- Responsive ---------- */
    @@media (max-width: 576px) {
        .auth-card {
            padding: 2rem 1.4rem 1.8rem;
        }
    }
</style>

<div class="auth-page">
    <div class="container position-relative" style="z-index:1;">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5">
                <div class="auth-card">
                    <div class="text-center mb-4">
                        <div class="auth-brand">QONNEC</div>
                        <h2 class="auth-title">Welcome back</h2>
                        <p class="auth-subtitle">Sign in to your account to continue</p>
                    </div>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="Password" class="form-control" id="passwordInput" placeholder="Your password" />
                                <button type="button" class="btn btn-outline-secondary" tabindex="-1" onclick="togglePasswordVisibility()">
                                    <i class="bi bi-eye" id="togglePasswordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                            </div>
                        </div>

                        <button type="submit" class="btn-auth">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                        </button>
                    </form>

                    <div class="text-center mt-4 auth-footer">
                        Don't have an account? <a asp-action="Register">Register here</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePasswordVisibility() {
            var input = document.getElementById('passwordInput');
            var icon = document.getElementById('togglePasswordIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}
