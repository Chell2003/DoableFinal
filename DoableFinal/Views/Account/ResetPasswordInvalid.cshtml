@{
    ViewData["Title"] = "Reset Link Expired";
    var email = TempData["ResetEmail"] as string;
}

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="auth-card text-center">

                    <div class="auth-icon">
                        <i class="bi bi-exclamation-circle"></i>
                    </div>

                    <h2 class="auth-title">Link Expired</h2>

                    @if (TempData["ResetError"] != null)
                    {
                        <div class="text-danger mb-2">
                            @TempData["ResetError"]
                        </div>
                    }

                    <p class="auth-subtitle">
                        This reset link is invalid or expired.
                    </p>

                    <form asp-action="ResendResetLink" method="post">
                        <input type="hidden" name="email" value="@email" />
                        <button type="submit" class="btn-auth mt-2">
                            Send New Link
                        </button>
                    </form>

                    <div class="auth-footer mt-3">
                        <a asp-action="Login">Back to Login</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>