@{
    ViewData["Title"] = "Password Reset Confirmation";
}

<div class="auth-page">
    <div class="container position-relative" style="z-index:1;">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5">
                <div class="auth-card text-center">
                    <div class="auth-brand mb-3">QONNEC</div>
                    <h2 class="auth-title">Password Reset Successful</h2>
                    <p class="auth-subtitle">Your password has been reset. You may now <a asp-action="Login">sign in</a> with your new password.</p>
                </div>
            </div>
        </div>
    </div>
</div>
