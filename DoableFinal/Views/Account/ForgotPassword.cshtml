@model DoableFinal.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    /* =============================================
       FORGOT PASSWORD PAGE — #347deb theme
    ============================================= */

    @@keyframes authFadeUp {
        from { opacity: 0; transform: translateY(32px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes authOrbDrift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33%       { transform: translate(20px, -14px) scale(1.04); }
        66%       { transform: translate(-12px, 8px) scale(0.97); }
    }

    @@keyframes authShimmer {
        0%   { background-position: -200% center; }
        100% { background-position:  200% center; }
    }

    @@keyframes authBrandPop {
        from { opacity: 0; transform: scale(0.80) translateY(-8px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    @@keyframes authInputFocus {
        from { box-shadow: 0 0 0 0 rgba(52, 125, 235, 0.35); }
        to   { box-shadow: 0 0 0 4px rgba(52, 125, 235, 0.15); }
    }

    /* Page background */
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f2660 0%, #1a3f80 35%, #2360c8 70%, #347deb 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
        position: relative;
        overflow: hidden;
    }

    /* Decorative orbs */
    .auth-page::before {
        content: '';
        position: absolute;
        width: 480px; height: 480px;
        top: -160px; right: -140px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.055);
        animation: authOrbDrift 10s ease-in-out infinite;
        pointer-events: none;
    }

    .auth-page::after {
        content: '';
        position: absolute;
        width: 320px; height: 320px;
        bottom: -100px; left: -100px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.040);
        animation: authOrbDrift 14s ease-in-out infinite reverse;
        pointer-events: none;
    }

    /* Card */
    .auth-card {
        background: #fff;
        border-radius: 22px;
        padding: 2.6rem 2.2rem 2rem;
        box-shadow: 0 24px 64px rgba(10, 30, 90, 0.22),
                    0 4px 20px rgba(10, 30, 90, 0.10);
        position: relative;
        overflow: hidden;
        animation: authFadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    /* Shimmer top stripe */
    .auth-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, #1a3f80, #347deb, #60aaff, #347deb, #1a3f80);
        background-size: 200% auto;
        animation: authShimmer 3s linear infinite;
        border-radius: 22px 22px 0 0;
    }

    /* Brand */
    .auth-brand {
        font-family: 'League Spartan', 'DM Serif Display', serif;
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -2px;
        color: #1a3f80;
        animation: authBrandPop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s both;
        display: inline-block;
    }

    /* Title */
    .auth-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1a3f80;
        margin: 0.5rem 0 0.35rem;
        letter-spacing: -0.3px;
        animation: authFadeUp 0.5s ease 0.18s both;
    }

    /* Subtitle */
    .auth-subtitle {
        font-size: 0.86rem;
        color: #6b84b0;
        line-height: 1.6;
        margin-bottom: 0.25rem;
        animation: authFadeUp 0.5s ease 0.24s both;
    }

    /* Form label */
    .form-label {
        font-size: 0.78rem;
        font-weight: 700;
        color: #1a3f80;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.35rem;
        display: block;
    }

    /* Input */
    .form-control {
        border: 1.5px solid rgba(52, 125, 235, 0.20);
        border-radius: 10px;
        font-size: 0.9rem;
        color: #2d3a55;
        padding: 0.58rem 0.9rem;
        background: #f8faff;
        width: 100%;
        transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s;
        font-family: inherit;
    }

    .form-control:focus {
        border-color: #347deb;
        box-shadow: 0 0 0 3px rgba(52, 125, 235, 0.15);
        background: #fff;
        outline: none;
        animation: authInputFocus 0.3s ease;
    }

    .form-control::placeholder {
        color: #a0b0cc;
        font-size: 0.88rem;
    }

    /* Submit button */
    .btn-auth {
        display: block;
        width: 100%;
        padding: 0.72rem 1rem;
        background: linear-gradient(135deg, #347deb, #1a3f80);
        color: #fff;
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.2px;
        border: none;
        border-radius: 11px;
        cursor: pointer;
        box-shadow: 0 4px 18px rgba(52, 125, 235, 0.35);
        transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.18s ease,
                    background 0.18s;
        margin-top: 0.5rem;
        text-decoration: none;
        text-align: center;
        font-family: inherit;
    }

    .btn-auth:hover {
        background: linear-gradient(135deg, #1f62cc, #12317a);
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(52, 125, 235, 0.42);
        color: #fff;
        text-decoration: none;
    }

    .btn-auth:active {
        transform: scale(0.97);
    }

    /* Footer link */
    .auth-footer a {
        font-size: 0.85rem;
        color: #347deb;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.15s;
    }

    .auth-footer a:hover {
        color: #1a3f80;
        text-decoration: underline;
    }

    /* Validation */
    .text-danger {
        font-size: 0.80rem;
        color: #d9534f;
    }
</style>

<div class="auth-page">
    <div class="container position-relative" style="z-index:1;">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5">
                <div class="auth-card">
                    <div class="text-center mb-4">
                        <div class="auth-brand">QONNEC</div>
                        <h2 class="auth-title">Forgot your password?</h2>
                        <p class="auth-subtitle">Enter your email address and we'll send you a link to reset your password.</p>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn-auth">Send Reset Link</button>
                    </form>

                    <div class="text-center mt-4 auth-footer">
                        <a asp-action="Login">Back to Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}       