@model DoableFinal.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<style>
    /* =============================================
       REGISTER PAGE — #347deb theme (matches Index)
       ============================================= */

    @@keyframes heroFadeUp {
        from { opacity: 0; transform: translateY(40px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes shimmerMove {
        0%   { background-position: -200% center; }
        100% { background-position:  200% center; }
    }

    @@keyframes orbDrift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33%       { transform: translate(18px, -12px) scale(1.04); }
        66%       { transform: translate(-10px, 8px) scale(0.97); }
    }

    @@keyframes ctaPulse {
        0%, 100% { box-shadow: 0 4px 20px rgba(52, 125, 235, 0.30); }
        50%       { box-shadow: 0 8px 36px rgba(52, 125, 235, 0.52); }
    }

    .landing-header {
        box-shadow: 0 2px 16px rgba(52, 125, 235, 0.08) !important;
        border-bottom: 1px solid rgba(52, 125, 235, 0.10) !important;
    }

    .landing-header .navbar-brand img {
        transition: transform 0.2s;
    }

    .landing-header .navbar-brand img:hover {
        transform: scale(1.04);
    }

    .landing-header .nav-link.text-dark {
        font-size: 0.88rem;
        font-weight: 500;
        color: #2d3a55 !important;
        padding: 0.4rem 0.9rem;
        border-radius: 8px;
        transition: background 0.18s, color 0.18s;
        position: relative;
    }

    .landing-header .nav-link.text-dark::after {
        content: '';
        position: absolute;
        bottom: 2px;
        left: 50%;
        transform: translateX(-50%) scaleX(0);
        width: 60%;
        height: 2px;
        background: #347deb;
        border-radius: 2px;
        transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .landing-header .nav-link.text-dark:hover {
        color: #347deb !important;
        background: rgba(52, 125, 235, 0.07);
    }

    .landing-header .nav-link.text-dark:hover::after {
        transform: translateX(-50%) scaleX(1);
    }


    /* ---------- Page wrapper ---------- */
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(160deg, #eef3fc 0%, #f8faff 50%, #e6eef9 100%);
        position: relative;
        overflow: hidden;
        padding: 3rem 0 4rem;
    }

    .auth-page::before {
        content: '';
        position: absolute;
        width: 420px; height: 420px;
        top: -140px; right: -100px;
        border-radius: 50%;
        background: rgba(52, 125, 235, 0.07);
        animation: orbDrift 9s ease-in-out infinite;
        pointer-events: none;
    }

    .auth-page::after {
        content: '';
        position: absolute;
        width: 280px; height: 280px;
        bottom: -80px; left: -60px;
        border-radius: 50%;
        background: rgba(52, 125, 235, 0.05);
        animation: orbDrift 12s ease-in-out infinite reverse;
        pointer-events: none;
    }

    /* ---------- Card ---------- */
    .auth-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid rgba(52, 125, 235, 0.10);
        box-shadow: 0 4px 40px rgba(52, 125, 235, 0.10);
        padding: 2.8rem 2.8rem 2.4rem;
        position: relative;
        overflow: hidden;
        animation: heroFadeUp 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
    }

    .auth-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, #0f2660, #347deb, #60aaff);
        background-size: 200% auto;
        animation: shimmerMove 3s linear infinite;
    }

    /* ---------- Page title ---------- */
    .auth-title {
        font-family: 'League Spartan', sans-serif;
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: -1.5px;
        color: #1a3f80;
        margin-bottom: 0.25rem;
    }

    .auth-subtitle {
        font-size: 0.88rem;
        color: #6b84b0;
        margin-bottom: 2rem;
    }

    /* ---------- Section headings inside form ---------- */
    .form-section-title {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: #347deb;
        background: rgba(52, 125, 235, 0.08);
        border: 1px solid rgba(52, 125, 235, 0.20);
        border-radius: 20px;
        padding: 4px 12px;
        display: inline-block;
        margin-bottom: 1rem;
    }

    /* ---------- Form controls ---------- */
    .form-label {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: #1a3f80;
        margin-bottom: 5px;
    }

    .form-control,
    .form-select {
        border: 1px solid rgba(52, 125, 235, 0.20);
        border-radius: 10px;
        padding: 11px 14px;
        font-size: .93rem;
        color: #0d1117;
        background: #f4f7fd;
        transition: border-color .25s, box-shadow .25s, background .25s;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #347deb;
        box-shadow: 0 0 0 3px rgba(52, 125, 235, 0.12);
        background: #fff;
        outline: none;
    }

    .input-group .form-control {
        border-right: none;
        border-radius: 10px 0 0 10px;
    }

    .input-group .btn-outline-secondary {
        border: 1px solid rgba(52, 125, 235, 0.20);
        border-left: none;
        border-radius: 0 10px 10px 0;
        background: #f4f7fd;
        color: #6b84b0;
        transition: background .2s, color .2s;
    }

    .input-group .btn-outline-secondary:hover {
        background: rgba(52, 125, 235, 0.10);
        color: #347deb;
    }

    .input-group:focus-within .btn-outline-secondary {
        border-color: #347deb;
        background: #fff;
    }

    /* ---------- Divider between columns ---------- */
    .col-divider {
        border-left: 1px solid rgba(52, 125, 235, 0.10);
    }

    /* ---------- Submit button ---------- */
    .btn-auth {
        background: linear-gradient(135deg, #347deb, #1a3f80);
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 700;
        padding: 0.78rem 2.2rem;
        color: #fff;
        letter-spacing: 0.2px;
        width: 100%;
        animation: ctaPulse 2.8s ease-in-out infinite;
        transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.25s ease, background 0.2s;
    }

    .btn-auth:hover {
        background: linear-gradient(135deg, #1f62cc, #12317a);
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 12px 36px rgba(52, 125, 235, 0.40) !important;
        color: #fff;
    }

    /* ---------- Footer link ---------- */
    .auth-footer {
        font-size: 0.88rem;
        color: #6b84b0;
    }

    .auth-footer a {
        color: #347deb;
        font-weight: 700;
        text-decoration: none;
        transition: color .2s;
    }

    .auth-footer a:hover {
        color: #1a3f80;
    }

    /* ---------- Validation ---------- */
    .text-danger.small,
    span.text-danger {
        font-size: 0.78rem;
    }

    /* ---------- Responsive ---------- */
    @@media (max-width: 768px) {
        .auth-card {
            padding: 2rem 1.4rem 1.8rem;
        }

        .col-divider {
            border-left: none;
            border-top: 1px solid rgba(52, 125, 235, 0.10);
            padding-top: 1.5rem;
            margin-top: 0.5rem;
        }
    }
</style>

<div class="auth-page">
    <div class="container position-relative" style="z-index:1;">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-9">
                <div class="auth-card">
                    <div class="text-center mb-4">
                        <h2 class="auth-title">Create Account</h2>
                        <p class="auth-subtitle">Fill in your details to get started with QONNEC</p>
                    </div>

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="row g-4">

                            <!-- Personal Information -->
                            <div class="col-md-6">
                                <div class="form-section-title">Personal Information</div>

                                <div class="form-group mb-3">
                                    <label asp-for="FirstName" class="form-label"></label>
                                    <input asp-for="FirstName" class="form-control" placeholder="Juan" />
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="LastName" class="form-label"></label>
                                    <input asp-for="LastName" class="form-control" placeholder="dela Cruz" />
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Email" class="form-label"></label>
                                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="MobileNumber" class="form-label"></label>
                                    <input asp-for="MobileNumber" class="form-control" placeholder="09XXXXXXXXX" />
                                    <span asp-validation-for="MobileNumber" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Birthday" class="form-label"></label>
                                    <input asp-for="Birthday" class="form-control" type="date" max="@DateTime.Today.AddYears(-18).ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="Birthday" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Company Information -->
                            <div class="col-md-6 col-divider ps-md-4">
                                <div class="form-section-title">Company Information</div>

                                <div class="form-group mb-3">
                                    <label asp-for="CompanyName" class="form-label"></label>
                                    <input asp-for="CompanyName" class="form-control" placeholder="Acme Corp." />
                                    <span asp-validation-for="CompanyName" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="CompanyAddress" class="form-label"></label>
                                    <input asp-for="CompanyAddress" class="form-control" placeholder="123 Business St." />
                                    <span asp-validation-for="CompanyAddress" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="TinNumber" class="form-label"></label>
                                    <input asp-for="TinNumber" class="form-control" placeholder="123-456-789 or 123-456-789-012" />
                                    <span asp-validation-for="TinNumber" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="CompanyType" class="form-label"></label>
                                    <select asp-for="CompanyType" class="form-select">
                                        <option value="">Select Company Type</option>
                                        <option value="Sole Proprietorship">Sole Proprietorship</option>
                                        <option value="Partnership">Partnership</option>
                                        <option value="Corporation">Corporation</option>
                                    </select>
                                    <span asp-validation-for="CompanyType" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Divider -->
                        <hr style="border-color: rgba(52,125,235,.10); margin: 1.8rem 0;">

                        <div class="row g-4">

                            <!-- Account Security -->
                            <div class="col-md-6">
                                <div class="form-section-title">Account Security</div>

                                <div class="form-group mb-3">
                                    <label asp-for="Password" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="Password" type="password" class="form-control" id="Password" placeholder="Min. 8 characters" />
                                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('Password', this)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="ConfirmPassword" type="password" class="form-control" id="ConfirmPassword" placeholder="Repeat password" />
                                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('ConfirmPassword', this)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Position -->
                            <div class="col-md-6 col-divider ps-md-4">
                                <div class="form-section-title">Position</div>

                                <div class="form-group mb-3">
                                    <label asp-for="Designation" class="form-label"></label>
                                    <input asp-for="Designation" class="form-control" placeholder="e.g. Project Manager" />
                                    <span asp-validation-for="Designation" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn-auth">
                                <i class="bi bi-person-check me-2"></i>Create Account
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-4 auth-footer">
                        Already have an account? <a asp-action="Login">Login here</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(function () {
            $('form[asp-action="Register"]').on('submit', function (e) {
                var bday = $('#Birthday').val();
                if (!bday) return;
                var birth = new Date(bday);
                var today = new Date();
                var age = today.getFullYear() - birth.getFullYear();
                var m = today.getMonth() - birth.getMonth();
                if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
                if (age < 18) {
                    e.preventDefault();
                    $('#Birthday').siblings('span.text-danger').text('You must be at least 18 years old to register.');
                    $('#Birthday').addClass('is-invalid');
                    return false;
                }
            });
        });
    </script>

    <script>
        function togglePassword(fieldId, button) {
            const input = document.getElementById(fieldId);
            const icon = button.querySelector("i");
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
    </script>
}
