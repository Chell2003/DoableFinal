@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<style>
    /* =============================================
       FORGOT PASSWORD CONFIRMATION — #347deb theme
    ============================================= */

    @@keyframes authFadeUp {
        from { opacity: 0; transform: translateY(32px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes authOrbDrift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33%       { transform: translate(20px, -14px) scale(1.04); }
        66%       { transform: translate(-12px, 8px) scale(0.97); }
    }

    @@keyframes authShimmer {
        0%   { background-position: -200% center; }
        100% { background-position:  200% center; }
    }

    @@keyframes authBrandPop {
        from { opacity: 0; transform: scale(0.80) translateY(-8px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    @@keyframes iconCheckIn {
        0%   { opacity: 0; transform: scale(0.5) rotate(-20deg); }
        60%  { transform: scale(1.12) rotate(4deg); }
        100% { opacity: 1; transform: scale(1) rotate(0deg); }
    }

    /* Page background */
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f2660 0%, #1a3f80 35%, #2360c8 70%, #347deb 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
        position: relative;
        overflow: hidden;
    }

    .auth-page::before {
        content: '';
        position: absolute;
        width: 480px; height: 480px;
        top: -160px; right: -140px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.055);
        animation: authOrbDrift 10s ease-in-out infinite;
        pointer-events: none;
    }

    .auth-page::after {
        content: '';
        position: absolute;
        width: 320px; height: 320px;
        bottom: -100px; left: -100px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.040);
        animation: authOrbDrift 14s ease-in-out infinite reverse;
        pointer-events: none;
    }

    /* Card */
    .auth-card {
        background: #fff;
        border-radius: 22px;
        padding: 2.8rem 2.2rem 2.2rem;
        box-shadow: 0 24px 64px rgba(10, 30, 90, 0.22),
                    0 4px 20px rgba(10, 30, 90, 0.10);
        position: relative;
        overflow: hidden;
        animation: authFadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    /* Shimmer top stripe */
    .auth-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, #1a3f80, #347deb, #60aaff, #347deb, #1a3f80);
        background-size: 200% auto;
        animation: authShimmer 3s linear infinite;
        border-radius: 22px 22px 0 0;
    }

    /* Success icon */
    .auth-success-icon {
        width: 68px; height: 68px;
        border-radius: 50%;
        background: rgba(52, 125, 235, 0.10);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.2rem;
        animation: iconCheckIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
    }

    .auth-success-icon i {
        font-size: 2rem;
        color: #347deb;
    }

    /* Brand */
    .auth-brand {
        font-family: 'League Spartan', 'DM Serif Display', serif;
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -2px;
        color: #1a3f80;
        animation: authBrandPop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s both;
        display: inline-block;
    }

    /* Title */
    .auth-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1a3f80;
        margin: 0.5rem 0 0.35rem;
        letter-spacing: -0.3px;
        animation: authFadeUp 0.5s ease 0.22s both;
    }

    /* Subtitle */
    .auth-subtitle {
        font-size: 0.86rem;
        color: #6b84b0;
        line-height: 1.65;
        margin: 0 auto 0.5rem;
        max-width: 320px;
        animation: authFadeUp 0.5s ease 0.30s both;
    }

    /* Back to login button */
    .btn-auth {
        display: inline-block;
        padding: 0.72rem 2rem;
        background: linear-gradient(135deg, #347deb, #1a3f80);
        color: #fff;
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.2px;
        border: none;
        border-radius: 11px;
        cursor: pointer;
        box-shadow: 0 4px 18px rgba(52, 125, 235, 0.35);
        transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.18s ease,
                    background 0.18s;
        text-decoration: none;
        text-align: center;
        font-family: inherit;
        animation: authFadeUp 0.5s ease 0.38s both;
    }

    .btn-auth:hover {
        background: linear-gradient(135deg, #1f62cc, #12317a);
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(52, 125, 235, 0.42);
        color: #fff;
        text-decoration: none;
    }

    .btn-auth:active {
        transform: scale(0.97);
    }
</style>

<div class="auth-page">
    <div class="container position-relative" style="z-index:1;">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5">
                <div class="auth-card text-center">

                    <div class="auth-success-icon">
                        <i class="bi bi-envelope-check"></i>
                    </div>

                    <div class="auth-brand mb-2">QONNEC</div>
                    <h2 class="auth-title">Check your email</h2>
                    <p class="auth-subtitle">If an account with that email exists, a password reset link has been sent. Please check your inbox.</p>
                    <a asp-action="Login" class="btn-auth mt-3">Back to Login</a>

                </div>
            </div>
        </div>
    </div>
</div>
