@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Rendering
@inject UserManager<DoableFinal.Models.ApplicationUser> UserManager
@inject IHttpContextAccessor HttpContextAccessor

@{
    string IsActive(string controller, string action = "Index") {
        var routeData = ViewContext.RouteData;
        var currentController = routeData.Values["controller"]?.ToString();
        var currentAction = routeData.Values["action"]?.ToString();
        return currentController == controller && currentAction == action ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Qonnec</title>
    <link href="~/css/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/client-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    @RenderSection("Styles", required: false)

    <style>
        /* =============================================
           DESIGN TOKENS
        ============================================= */
        :root {
            --sb-w: 248px;
            --sb-grad-a: #0a1f5c;
            --sb-grad-b: #163a8f;
            --sb-grad-c: #2055c8;
            --sb-grad-d: #347deb;
            --sb-text: rgba(255,255,255,0.72);
            --sb-text-active: #ffffff;
            --sb-hover-bg: rgba(255,255,255,0.10);
            --sb-active-bg: rgba(255,255,255,0.16);
            --sb-border: rgba(255,255,255,0.10);
            --sb-orb-a: rgba(255,255,255,0.055);
            --sb-orb-b: rgba(255,255,255,0.040);

            --topbar-h: 58px;
            --accent: #347deb;
            --accent-dark: #1a3f80;
            --body-bg: #f4f7fd;
            --text-1: #0d1117;
            --text-2: #4b5563;
            --text-3: #9ca3af;

            --r-sm: 8px;
            --r-md: 12px;
            --r-lg: 16px;

            --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
            --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
            --t: 0.2s ease;
            --font: 'DM Sans', system-ui, sans-serif;
        }

        /* =============================================
           KEYFRAMES
        ============================================= */

        /* Sidebar slides in */
        @keyframes sidebarIn {
            from { transform: translateX(-100%); opacity: 0; }
            to   { transform: translateX(0);     opacity: 1; }
        }

        /* Logo appears */
        @keyframes logoIn {
            from { opacity: 0; transform: scale(0.82) translateY(-4px); }
            to   { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* User card rises */
        @keyframes userCardIn {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Nav items cascade in from left */
        @keyframes navItemIn {
            from { opacity: 0; transform: translateX(-18px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        /* Topbar drops from top */
        @keyframes topbarIn {
            from { opacity: 0; transform: translateY(-100%); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Page content rises */
        @keyframes pageIn {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Alert slide in */
        @keyframes alertIn {
            from { opacity: 0; transform: translateY(-10px) scaleY(0.92); }
            to   { opacity: 1; transform: translateY(0) scaleY(1); }
        }

        /* Card entrance */
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Shimmer sweep */
        @keyframes shimmer {
            0%   { background-position: -250% center; }
            100% { background-position:  250% center; }
        }

        /* Floating orbs */
        @keyframes orbDrift {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33%       { transform: translate(12px, -8px) scale(1.03); }
            66%       { transform: translate(-8px, 5px) scale(0.97); }
        }

        /* Icon bounce on hover */
        @keyframes iconBounce {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            30%       { transform: translateY(-4px) rotate(-7deg); }
            65%       { transform: translateY(2px) rotate(4deg); }
        }

        /* Badge bounce */
        @keyframes badgeBounce {
            0%, 100% { transform: scale(1); }
            40%       { transform: scale(1.28) translateY(-4px); }
            70%       { transform: scale(0.93) translateY(1px); }
        }

        /* Active indicator pulse */
        @keyframes activePulse {
            0%   { box-shadow: 0 0 0 0 rgba(255,255,255,0.6); }
            70%  { box-shadow: 0 0 0 8px rgba(255,255,255,0); }
            100% { box-shadow: 0 0 0 0 rgba(255,255,255,0); }
        }

        /* Ripple out */
        @keyframes rippleOut {
            from { transform: scale(0); opacity: 0.45; }
            to   { transform: scale(6); opacity: 0; }
        }

        /* Page title words reveal */
        @keyframes wordReveal {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Spin */
        @keyframes spin { to { transform: rotate(360deg); } }

        /* =============================================
           RESET & BASE
        ============================================= */
        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: var(--font);
            font-size: 14.5px;
            font-weight: 400;
            background: var(--body-bg);
            color: var(--text-1);
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* =============================================
           SIDEBAR
        ============================================= */
        #sidebar {
            width: var(--sb-w);
            min-height: 100vh;
            background: linear-gradient(175deg,
                var(--sb-grad-a)  0%,
                var(--sb-grad-b) 35%,
                var(--sb-grad-c) 70%,
                var(--sb-grad-d) 100%
            );
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0;
            z-index: 1000;
            overflow: hidden;
            /* Entry animation */
            animation: sidebarIn 0.42s var(--ease-spring) both;
        }

        /* ── Floating orb A (top-right) ── */
        #sidebar::before {
            content: '';
            position: absolute;
            width: 280px; height: 280px;
            top: -90px; right: -90px;
            border-radius: 50%;
            background: var(--sb-orb-a);
            animation: orbDrift 9s ease-in-out infinite;
            pointer-events: none;
        }

        /* ── Floating orb B (bottom-left) ── */
        #sidebar::after {
            content: '';
            position: absolute;
            width: 200px; height: 200px;
            bottom: 50px; left: -70px;
            border-radius: 50%;
            background: var(--sb-orb-b);
            animation: orbDrift 13s ease-in-out infinite reverse;
            pointer-events: none;
        }

        /* ── Shimmer accent bar ── */
        .sidebar-shimmer {
            height: 3px;
            flex-shrink: 0;
            background: linear-gradient(90deg,
                transparent,
                rgba(255,255,255,0.55),
                rgba(255,255,255,0.85),
                rgba(255,255,255,0.55),
                transparent
            );
            background-size: 250% auto;
            animation: shimmer 2.8s linear infinite;
            position: relative;
            z-index: 2;
        }

        /* ── Logo header ── */
        .sidebar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.25rem 1.25rem 0.9rem;
            position: relative;
            z-index: 2;
        }

        .logo-container {
            display: flex;
            align-items: center;
        }

        .logo-img {
            max-height: 34px;
            width: auto;
            filter: brightness(0) invert(1);
            opacity: 0.92;
            animation: logoIn 0.5s var(--ease-bounce) 0.14s both;
            transition: opacity var(--t), transform var(--t);
        }

        .logo-img:hover {
            opacity: 1;
            transform: scale(1.04);
        }

        .logo-text {
            font-family: 'DM Serif Display', serif;
            font-size: 1.45rem;
            font-weight: 400;
            letter-spacing: -1px;
            color: #fff;
        }

        .btn-sidebar-toggle {
            display: none;
            background: rgba(255,255,255,0.10);
            border: 1px solid rgba(255,255,255,0.15);
            color: #fff;
            font-size: 1.15rem;
            padding: 5px 9px;
            border-radius: var(--r-sm);
            cursor: pointer;
            transition: background var(--t), transform 0.15s ease;
        }

        .btn-sidebar-toggle:hover {
            background: rgba(255,255,255,0.18);
            transform: scale(1.05);
        }

        #sidebarCollapse:hover { transform: rotate(90deg) scale(1.05); }

        /* ── User card ── */
        .sidebar-user {
            margin: 0 0.9rem 0.4rem;
            padding: 0.7rem 0.95rem;
            background: rgba(255,255,255,0.08);
            border-radius: var(--r-md);
            border: 1px solid var(--sb-border);
            position: relative;
            z-index: 2;
            animation: userCardIn 0.42s ease 0.30s both;
            transition: background var(--t), border-color var(--t);
        }

        .sidebar-user:hover {
            background: rgba(255,255,255,0.12);
            border-color: rgba(255,255,255,0.18);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 9px;
            color: var(--sb-text-active);
            font-size: 0.875rem;
            font-weight: 500;
        }

        .user-info .bi {
            font-size: 1.25rem;
            color: rgba(255,255,255,0.78);
            flex-shrink: 0;
            transition: transform 0.3s var(--ease-bounce);
        }

        .sidebar-user:hover .user-info .bi {
            transform: scale(1.12);
        }

        .user-name {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ── Nav menu ── */
        .nav-menu {
            flex: 1;
            padding: 0.4rem 0.65rem;
            margin: 0;
            list-style: none;
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .nav-menu::-webkit-scrollbar { width: 3px; }
        .nav-menu::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 3px; }

        .nav-item { margin-bottom: 2px; }

        .nav-item.mt-auto {
            margin-top: auto;
            padding-top: 0.5rem;
            border-top: 1px solid var(--sb-border);
        }

        /* Staggered entrance */
        .nav-menu .nav-item:nth-child(1) { animation: navItemIn 0.35s ease 0.32s both; }
        .nav-menu .nav-item:nth-child(2) { animation: navItemIn 0.35s ease 0.38s both; }
        .nav-menu .nav-item:nth-child(3) { animation: navItemIn 0.35s ease 0.44s both; }
        .nav-menu .nav-item:nth-child(4) { animation: navItemIn 0.35s ease 0.50s both; }
        .nav-menu .nav-item:nth-child(5) { animation: navItemIn 0.35s ease 0.56s both; }
        .nav-menu .nav-item:nth-child(6) { animation: navItemIn 0.35s ease 0.62s both; }
        .nav-menu .nav-item:nth-child(7) { animation: navItemIn 0.35s ease 0.68s both; }

        /* Nav links */
        .nav-link {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 0.62rem 0.95rem;
            border-radius: var(--r-sm);
            color: var(--sb-text) !important;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none !important;
            position: relative;
            overflow: hidden;
            transition: background var(--t), color var(--t), transform var(--t);
        }

        .nav-link .bi {
            font-size: 1.05rem;
            flex-shrink: 0;
            transition: color var(--t);
        }

        .nav-link:hover {
            background: var(--sb-hover-bg);
            color: var(--sb-text-active) !important;
            transform: translateX(4px);
        }

        .nav-link:hover .bi {
            animation: iconBounce 0.38s ease;
        }

        /* Active state */
        .nav-link.active {
            background: var(--sb-active-bg);
            color: var(--sb-text-active) !important;
            font-weight: 600;
            box-shadow: 0 2px 14px rgba(0,0,0,0.14);
        }

        .nav-link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 20%; bottom: 20%;
            width: 3px;
            background: rgba(255,255,255,0.88);
            border-radius: 0 3px 3px 0;
            animation: activePulse 2.2s ease-out 0.8s 2;
        }

        /* Ripple */
        .nav-ripple {
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.28);
            width: 8px; height: 8px;
            pointer-events: none;
            animation: rippleOut 0.55s ease-out forwards;
        }

        /* Logout link */
        .nav-item.mt-auto .nav-link {
            color: rgba(255,200,200,0.70) !important;
        }

        .nav-item.mt-auto .nav-link:hover {
            background: rgba(255,100,100,0.12);
            color: rgba(255,180,180,0.95) !important;
        }

        /* Bottom shimmer bar */
        .sidebar-footer-shimmer {
            height: 2px;
            flex-shrink: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
            background-size: 200% auto;
            animation: shimmer 4s linear infinite;
            position: relative;
            z-index: 2;
        }

        /* =============================================
           CONTENT AREA
        ============================================= */
        #content {
            margin-left: var(--sb-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            transition: margin-left 0.3s var(--ease-spring);
        }

        /* =============================================
           TOPBAR
        ============================================= */
        .top-navbar {
            background: #fff;
            border-bottom: 1px solid rgba(52,125,235,0.09);
            box-shadow: 0 2px 18px rgba(52,125,235,0.06);
            padding: 0 1.5rem;
            height: var(--topbar-h);
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            animation: topbarIn 0.38s var(--ease-spring) 0.18s both;
        }

        .top-navbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .top-page-title {
            font-family: var(--font);
            font-size: 15px;
            font-weight: 600;
            letter-spacing: -0.02em;
            color: var(--accent-dark);
        }

        .top-navbar-right .navbar-nav {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 6px;
            list-style: none;
            margin: 0; padding: 0;
        }

        /* =============================================
           MAIN CONTENT
        ============================================= */
        .content-wrapper {
            flex: 1;
            padding: 1.8rem;
            background: var(--body-bg);
            animation: pageIn 0.44s var(--ease-spring) 0.22s both;
        }

        /* =============================================
           MOBILE
        ============================================= */
        @media (max-width: 767px) {
            #sidebar {
                transform: translateX(-100%);
                animation: none;
            }

            #sidebar.active {
                transform: translateX(0);
                animation: sidebarIn 0.34s var(--ease-spring) both;
                box-shadow: 6px 0 36px rgba(10,31,92,0.30);
            }

            #content { margin-left: 0; }

            .btn-sidebar-toggle { display: block; }

            .content-wrapper { padding: 1.2rem; }
        }

        /* =============================================
           COMPONENTS
        ============================================= */

        /* Cards */
        .card {
            border: 1px solid rgba(52,125,235,0.09);
            border-radius: var(--r-lg);
            box-shadow: none;
            animation: cardIn 0.42s var(--ease-spring) both;
        }

        .card:nth-child(1) { animation-delay: 0.10s; }
        .card:nth-child(2) { animation-delay: 0.18s; }
        .card:nth-child(3) { animation-delay: 0.26s; }
        .card:nth-child(4) { animation-delay: 0.34s; }
        .card:nth-child(5) { animation-delay: 0.42s; }

        .card-header {
            background: transparent;
            border-bottom: 1px solid rgba(52,125,235,0.07);
            padding: 16px 20px;
            font-weight: 600;
            font-size: 14.5px;
            color: var(--accent-dark);
        }

        .card-body { padding: 20px; }

        /* Alerts */
        .alert {
            border-radius: var(--r-md);
            border: none;
            font-size: 14px;
            padding: 12px 16px;
            animation: alertIn 0.3s var(--ease-spring) both;
            transform-origin: top center;
        }

        /* Buttons */
        .btn {
            font-family: var(--font);
            font-weight: 500;
            border-radius: var(--r-sm);
            font-size: 13.5px;
            padding: 7px 16px;
            transition: all 0.15s ease, transform 0.1s ease;
        }

        .btn:active { transform: scale(0.96); }

        .btn-primary {
            background: var(--accent);
            border-color: var(--accent);
        }

        .btn-primary:hover {
            background: #1a6fda;
            border-color: #1a6fda;
        }

        /* Tables */
        .table { font-size: 13.5px; }

        .table th {
            font-weight: 600;
            font-size: 11.5px;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: var(--accent-dark);
            border-bottom-width: 1px;
        }

        /* Form controls */
        .form-control, .form-select {
            border-radius: var(--r-sm);
            border-color: rgba(52,125,235,0.15);
            font-size: 14px;
            font-family: var(--font);
            transition: border-color var(--t), box-shadow var(--t);
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(52,125,235,0.12);
        }

        /* Badges */
        .badge {
            animation: badgeBounce 0.55s var(--ease-bounce) 1.1s both;
            display: inline-block;
        }

        /* Page transition overlay */
        #page-transition-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255,255,255,0);
            pointer-events: none;
            z-index: 9999;
            transition: background 0.18s ease;
        }

        /* Spin utility */
        .spin { animation: spin 0.8s linear infinite; display: inline-block; }

        /* Reduced motion */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body>
    <div class="wrapper client-dashboard">

        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-shimmer"></div>

            <div class="sidebar-header">
                <div class="logo-container">
                    <img src="~/images/logo-combined2.png" alt="Qonnec" class="logo-img"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                    <span class="logo-text" style="display:none;">QONNEC</span>
                </div>
                <button id="sidebarCollapse" class="btn-sidebar-toggle d-md-none">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="sidebar-user">
                @{
                    var currentUser = await UserManager.GetUserAsync(HttpContextAccessor.HttpContext.User);
                    var displayName = currentUser?.FirstName ?? User.Identity?.Name ?? "Guest";
                    var initials = (currentUser?.FirstName?.Length > 0 ? currentUser.FirstName[0].ToString() : "") +
                                   (currentUser?.LastName?.Length  > 0 ? currentUser.LastName[0].ToString()  : "");
                }
                <div class="user-info">
                    <i class="bi bi-person-circle"></i>
                    <span class="user-name">@displayName</span>
                </div>
            </div>

            <ul class="list-unstyled nav-menu">
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Index" class="nav-link @IsActive("Client", "Index")">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Projects" class="nav-link @IsActive("Client", "Projects")">
                        <i class="bi bi-folder2-open"></i>
                        <span>Projects</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Notifications" class="nav-link @IsActive("Client", "Notifications")">
                        <i class="bi bi-bell"></i>
                        <span>Notifications</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Tickets" class="nav-link @IsActive("Client", "Tickets")">
                        <i class="bi bi-ticket-perforated"></i>
                        <span>Tickets</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Profile" class="nav-link @IsActive("Client", "Profile")">
                        <i class="bi bi-person-badge"></i>
                        <span>Profile</span>
                    </a>
                </li>
                <li class="nav-item mt-auto">
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                        <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit()" class="nav-link">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </form>
                </li>
            </ul>

            <div class="sidebar-footer-shimmer"></div>
        </nav>

        <!-- Page Content -->
        <div id="content">

            <!-- Top Navbar -->
            <nav class="top-navbar">
                <div class="top-navbar-left">
                    <button id="sidebarCollapseShow" class="btn-sidebar-toggle d-md-none">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="top-page-title" id="pageTitle">@ViewData["Title"]</span>
                </div>
                <div class="top-navbar-right">
                    <ul class="navbar-nav">
                        @if (User.IsInRole("Client"))
                        {
                            @await Html.PartialAsync("_MessagesBadge")
                            @await Html.PartialAsync("_NotificationsBadge")
                        }
                    </ul>
                </div>
            </nav>

            <!-- Main Content -->
            <main role="main" class="content-wrapper">
                @await Html.PartialAsync("_Alerts")
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {

            // ── Sidebar toggle ──────────────────────────────────
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').removeClass('active');
            });

            $('#sidebarCollapseShow').on('click', function () {
                $('#sidebar').addClass('active');
            });

            // Close sidebar on outside click (mobile)
            $(document).on('click', function (e) {
                if ($(window).width() < 768 &&
                    !$(e.target).closest('#sidebar, #sidebarCollapseShow').length) {
                    $('#sidebar').removeClass('active');
                }
            });

            // ── Ripple effect on nav link clicks ───────────────
            $('.nav-menu .nav-link').on('click', function (e) {
                var $link = $(this);
                var offset = $link.offset();
                var $r = $('<span class="nav-ripple">').css({
                    left: e.pageX - offset.left - 4,
                    top:  e.pageY - offset.top  - 4
                });
                $link.append($r);
                setTimeout(function () { $r.remove(); }, 600);
            });

            // ── Page transition fade ────────────────────────────
            var $overlay = $('<div id="page-transition-overlay">').appendTo('body');
            $(document).on('click', 'a[href]', function (e) {
                var href = $(this).attr('href');
                var skip = /^(https?:\/\/|javascript:|#|mailto:)/.test(href)
                           || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey;
                if (!skip && href && href !== window.location.href) {
                    e.preventDefault();
                    $overlay.css({
                        background: 'rgba(244,247,253,0.75)',
                        transition: 'background 0.18s ease'
                    });
                    setTimeout(function () { window.location.href = href; }, 170);
                }
            });

            // ── Page title word-by-word reveal ─────────────────
            var $title = $('#pageTitle');
            var raw = $title.text().trim();
            if (raw) {
                $title.html(
                    raw.split(' ').map(function (w, i) {
                        var d = (0.30 + i * 0.07) + 's';
                        return '<span style="display:inline-block;opacity:0;transform:translateY(8px);' +
                               'transition:opacity .28s ease ' + d + ',transform .28s ease ' + d + '">' +
                               w + '&nbsp;</span>';
                    }).join('')
                );
                setTimeout(function () {
                    $title.find('span').css({ opacity: 1, transform: 'translateY(0)' });
                }, 40);
            }

            // ── Badge bounce on dynamic insertion ──────────────
            var observer = new MutationObserver(function (mutations) {
                mutations.forEach(function (m) {
                    $(m.addedNodes).find('.badge').addBack('.badge').each(function () {
                        var $b = $(this);
                        $b.css('animation', 'none');
                        requestAnimationFrame(function () {
                            $b.css('animation', 'badgeBounce .55s cubic-bezier(.34,1.56,.64,1) both');
                        });
                    });
                });
            });
            observer.observe(document.body, { childList: true, subtree: true });

        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
