@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Rendering
@inject UserManager<DoableFinal.Models.ApplicationUser> UserManager
@inject IHttpContextAccessor HttpContextAccessor

@{
    string IsActive(string controller, string action = "Index") {
        var routeData = ViewContext.RouteData;
        var currentController = routeData.Values["controller"]?.ToString();
        var currentAction = routeData.Values["action"]?.ToString();
        return currentController == controller && currentAction == action ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Qonnec</title>
    <link href="~/css/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/client-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@700;900&display=swap">
    @RenderSection("Styles", required: false)

    <style>
        /* =============================================
           _ClientLayout — #347deb theme (matches Index)
           ============================================= */

        @* ---------- Keyframes ---------- *@
        @@keyframes shimmerMove {
            0%   { background-position: -200% center; }
            100% { background-position:  200% center; }
        }

        @@keyframes orbDrift {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33%       { transform: translate(10px, -6px) scale(1.02); }
            66%       { transform: translate(-6px, 4px) scale(0.98); }
        }

        /* ---------- Reset / Base ---------- */
        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'DM Sans', system-ui, sans-serif;
            background: #f4f7fd;
            color: #0d1117;
        }

        /* ---------- Layout Wrapper ---------- */
        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ---------- Sidebar ---------- */
        #sidebar {
            width: 240px;
            min-height: 100vh;
            background: linear-gradient(175deg, #0f2660 0%, #1a3f80 35%, #2360c8 70%, #347deb 100%);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0;
            z-index: 1000;
            transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            overflow: hidden;
        }

        /* Orb decorations */
        #sidebar::before {
            content: '';
            position: absolute;
            width: 260px; height: 260px;
            top: -80px; right: -80px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            animation: orbDrift 9s ease-in-out infinite;
            pointer-events: none;
        }

        #sidebar::after {
            content: '';
            position: absolute;
            width: 180px; height: 180px;
            bottom: 60px; left: -60px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            animation: orbDrift 12s ease-in-out infinite reverse;
            pointer-events: none;
        }

        /* Shimmer line at top */
        .sidebar-shimmer {
            height: 3px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.45), transparent);
            background-size: 200% auto;
            animation: shimmerMove 3s linear infinite;
            flex-shrink: 0;
        }

        /* ---------- Sidebar Header (Logo) ---------- */
        .sidebar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.4rem 1.4rem 1rem;
            position: relative;
            z-index: 1;
        }

        .logo-container {
            display: flex;
            align-items: center;
        }

        .logo-img {
            max-height: 36px;
            width: auto;
            filter: brightness(0) invert(1);
            opacity: 0.92;
        }

        /* Fallback text logo if image is missing */
        .logo-text {
            font-family: 'League Spartan', sans-serif;
            font-size: 1.5rem;
            font-weight: 900;
            letter-spacing: -2px;
            color: #fff;
        }

        /* ---------- Sidebar User ---------- */
        .sidebar-user {
            margin: 0 1rem 0.5rem;
            padding: 0.75rem 1rem;
            background: rgba(255,255,255,0.08);
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.10);
            position: relative;
            z-index: 1;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            color: rgba(255,255,255,0.90);
            font-size: 0.88rem;
            font-weight: 500;
        }

        .user-info .bi {
            font-size: 1.3rem;
            color: rgba(255,255,255,0.75);
            flex-shrink: 0;
        }

        .user-name {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ---------- Nav Menu ---------- */
        .nav-menu {
            flex: 1;
            padding: 0.5rem 0.75rem;
            margin: 0;
            list-style: none;
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
        }

        .nav-item {
            margin-bottom: 2px;
        }

        .nav-item.mt-auto {
            margin-top: auto;
            padding-top: 0.5rem;
            border-top: 1px solid rgba(255,255,255,0.10);
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 0.65rem 1rem;
            border-radius: 10px;
            color: rgba(255,255,255,0.78) !important;
            font-size: 0.875rem;
            font-weight: 500;
            text-decoration: none !important;
            transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
            position: relative;
        }

        .nav-link .bi {
            font-size: 1.05rem;
            flex-shrink: 0;
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .nav-link:hover {
            background: rgba(255,255,255,0.12);
            color: #fff !important;
            transform: translateX(3px);
        }

        .nav-link:hover .bi {
            transform: scale(1.15);
        }

        .nav-link.active {
            background: rgba(255,255,255,0.18);
            color: #fff !important;
            font-weight: 700;
            box-shadow: 0 2px 12px rgba(0,0,0,0.15);
        }

        .nav-link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 20%; bottom: 20%;
            width: 3px;
            background: rgba(255,255,255,0.90);
            border-radius: 0 3px 3px 0;
        }

        .nav-link.active .bi {
            transform: scale(1.1);
        }

        /* ---------- Sidebar bottom shimmer ---------- */
        .sidebar-footer-shimmer {
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.20), transparent);
            background-size: 200% auto;
            animation: shimmerMove 4s linear infinite;
            flex-shrink: 0;
            margin-top: auto;
        }

        /* ---------- Page Content ---------- */
        #content {
            margin-left: 240px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            transition: margin-left 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        }

        /* ---------- Top Navbar ---------- */
        .top-navbar {
            background: #fff;
            border-bottom: 1px solid rgba(52, 125, 235, 0.10);
            box-shadow: 0 2px 16px rgba(52, 125, 235, 0.07);
            padding: 0 1.5rem;
            height: 58px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .top-navbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .top-page-title {
            font-family: 'League Spartan', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #1a3f80;
        }

        .btn-sidebar-toggle {
            display: none;
            background: none;
            border: none;
            color: #1a3f80;
            font-size: 1.3rem;
            padding: 4px 8px;
            border-radius: 8px;
            transition: background 0.2s;
            cursor: pointer;
        }

        .btn-sidebar-toggle:hover {
            background: rgba(52, 125, 235, 0.08);
        }

        .top-navbar-right .navbar-nav {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 6px;
            list-style: none;
            margin: 0; padding: 0;
        }

        /* ---------- Main Content ---------- */
        .content-wrapper {
            flex: 1;
            padding: 1.8rem;
            background: #f4f7fd;
        }

        /* ---------- Mobile ---------- */
        @@media (max-width: 767px) {
            #sidebar {
                transform: translateX(-100%);
            }

            #sidebar.active {
                transform: translateX(0);
            }

            #content {
                margin-left: 0;
            }

            .btn-sidebar-toggle {
                display: block;
            }

            .content-wrapper {
                padding: 1.2rem;
            }
        }
    </style>
</head>
<body>
    <div class="wrapper client-dashboard">

        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-shimmer"></div>

            <div class="sidebar-header">
                <div class="logo-container">
                    <img src="~/images/logo-combined2.png" alt="Qonnec" class="logo-img"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                    <span class="logo-text" style="display:none;">QONNEC</span>
                </div>
                <button id="sidebarCollapse" class="btn-sidebar-toggle d-md-none">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="sidebar-user">
                @{
                    var currentUser = await UserManager.GetUserAsync(HttpContextAccessor.HttpContext.User);
                    var displayName = currentUser?.FirstName ?? User.Identity?.Name ?? "Guest";
                    var initials = (currentUser?.FirstName?.Length > 0 ? currentUser.FirstName[0].ToString() : "") +
                                   (currentUser?.LastName?.Length  > 0 ? currentUser.LastName[0].ToString()  : "");
                }
                <div class="user-info">
                    <i class="bi bi-person-circle"></i>
                    <span class="user-name">@displayName</span>
                </div>
            </div>

            <ul class="list-unstyled nav-menu">
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Index" class="nav-link @IsActive("Client", "Index")">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Projects" class="nav-link @IsActive("Client", "Projects")">
                        <i class="bi bi-folder"></i>
                        <span>Projects</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Notifications" class="nav-link @IsActive("Client", "Notifications")">
                        <i class="bi bi-bell"></i>
                        <span>Notifications</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Tickets" class="nav-link @IsActive("Client", "Tickets")">
                        <i class="bi bi-ticket-perforated"></i>
                        <span>Tickets</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Client" asp-action="Profile" class="nav-link @IsActive("Client", "Profile")">
                        <i class="bi bi-person"></i>
                        <span>Profile</span>
                    </a>
                </li>
                <li class="nav-item mt-auto">
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                        <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit()" class="nav-link">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </form>
                </li>
            </ul>

            <div class="sidebar-footer-shimmer"></div>
        </nav>

        <!-- Page Content -->
        <div id="content">

            <!-- Top Navbar -->
            <nav class="top-navbar">
                <div class="top-navbar-left">
                    <button id="sidebarCollapseShow" class="btn-sidebar-toggle d-md-none">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="top-page-title">@ViewData["Title"]</span>
                </div>
                <div class="top-navbar-right">
                    <ul class="navbar-nav">
                        @if (User.IsInRole("Client"))
                        {
                            @await Html.PartialAsync("_MessagesBadge")
                            @await Html.PartialAsync("_NotificationsBadge")
                        }
                    </ul>
                </div>
            </nav>

            <!-- Main Content -->
            <main role="main" class="content-wrapper">
                @await Html.PartialAsync("_Alerts")
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').removeClass('active');
            });
            $('#sidebarCollapseShow').on('click', function () {
                $('#sidebar').addClass('active');
            });

            // Close sidebar on outside click (mobile)
            $(document).on('click', function (e) {
                if ($(window).width() < 768) {
                    if (!$(e.target).closest('#sidebar, #sidebarCollapseShow').length) {
                        $('#sidebar').removeClass('active');
                    }
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
