@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project Management System</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Shared System CSS -->
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-projects.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reports-print-media.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/header-dropdown.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" />
     <link rel="stylesheet" href="~/css/client-theme.css" asp-append-version="true" /> 
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Charts -->
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.41.0/dist/apexcharts.min.js"></script>

    <script src="~/js/scripts.js"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="client-theme">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="wrapper">

            <!-- Sidebar -->
            <div class="sidebar-shimmer"></div>

            <nav id="sidebar" class="sidebar">

                <div class="sidebar-header bg-white border-bottom">
                    <a class="navbar-brand">
                        <img src="~/images/logo-combined2.png" alt="Qonnec" height="40">
                    </a>

                    <button id="sidebarCollapse" class="btn btn-link d-md-none">
                        <i class="bi bi-x"></i>
                    </button>
                </div>

                <div class="sidebar-user">
                    <div class="user-info">
                        <i class="bi bi-person-circle"></i>

                        @{
                            string? fullName = null;

                            if (User.Identity?.IsAuthenticated == true)
                            {
                                var user = await UserManager.GetUserAsync(User);

                                if (user != null)
                                {
                                    fullName = $"{user.FirstName} {user.LastName}";
                                }
                            }
                        }

                        <span>@(fullName ?? User.Identity?.Name)</span>
                    </div>
                </div>

                <ul class="list-unstyled components">

                    <li>
                        <a asp-controller="Client" asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Client" asp-action="Projects">
                            <i class="bi bi-folder2-open"></i>
                            <span>Projects</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Report" asp-action="Index">
                            <i class="bi bi-bar-chart-line"></i>
                            <span>Reports</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Client" asp-action="Notifications">
                            <i class="bi bi-bell"></i>
                            <span>Notifications</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Ticket" asp-action="Index">
                            <i class="bi bi-ticket-detailed"></i>
                            <span>Tickets</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Client" asp-action="Profile">
                            <i class="bi bi-person-badge"></i>
                            <span>Profile</span>
                        </a>
                    </li>

                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                            <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit()">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Logout</span>
                            </a>
                        </form>
                    </li>

                </ul>
            </nav>

            <!-- Page Content -->
            <div id="content">

                <!-- Top Navigation -->
                <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">

                    <div class="container-fluid d-flex align-items-center flex-nowrap" style="min-width:0;">

                        <button type="button" id="sidebarCollapseShow" class="btn btn-link d-md-none me-2">
                            <i class="bi bi-list"></i>
                        </button>

                        <span class="navbar-text flex-grow-1 text-truncate"
                              style="min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @ViewData["Title"]
                        </span>

                        <div class="d-flex align-items-center ms-auto" style="gap:2rem;">

                            @await Html.PartialAsync("_MessagesBadge")

                            @await Html.PartialAsync("_NotificationsBadgeAll")

                        </div>
                    </div>
                </nav>

                <!-- Main Content -->
                <main role="main" class="content-wrapper">
                    @await Html.PartialAsync("_Alerts")
                    @RenderBody()
                </main>

            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/table-sort.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {

            // Initialize Bootstrap dropdowns
            var dropdownElementList = [].slice.call(document.querySelectorAll('[data-bs-toggle="dropdown"]'))

            var dropdownList = dropdownElementList.map(function (dropdownToggleEl) {
                return new bootstrap.Dropdown(dropdownToggleEl)
            });

            // Sidebar close
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').removeClass('active');
                $('#content').removeClass('active');
            });

            // Sidebar open
            $('#sidebarCollapseShow').on('click', function () {
                $('#sidebar').addClass('active');
                $('#content').addClass('active');
            });

            // Active links
            $('.sidebar ul li a').each(function () {

                if ($(this).attr('href') === window.location.pathname) {

                    $(this).addClass('active');

                    if ($(this).closest('.collapse').length) {

                        $(this).closest('.collapse').addClass('show');

                        $(this).closest('.collapse')
                            .prev('.dropdown-toggle')
                            .attr('aria-expanded', 'true');
                    }
                }
            });

        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>