@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project Management System</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reports-print-media.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/header-dropdown.css" asp-append-version="true" />
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Charts -->
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.41.0/dist/apexcharts.min.js"></script>
    <script src="~/js/scripts.js"></script>

    <style>
        /* =============================================
           DESIGN TOKENS
        ============================================= */
        :root {
            --sidebar-w: 260px;
            --sidebar-bg: #0f1621;
            --sidebar-surface: #192130;
            --sidebar-border: rgba(255,255,255,0.06);
            --sidebar-text: rgba(255,255,255,0.52);
            --sidebar-text-active: #ffffff;
            --sidebar-accent: #3b82f6;
            --sidebar-accent-dim: rgba(59,130,246,0.16);
            --sidebar-hover: rgba(255,255,255,0.05);
            --topbar-h: 60px;
            --body-bg: #f4f5f7;
            --text-1: #111827;
            --text-2: #6b7280;
            --text-3: #9ca3af;
            --r-sm: 6px;
            --r-md: 10px;
            --r-lg: 14px;
            --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
            --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
            --t: 0.18s ease;
            --font: 'DM Sans', sans-serif;
        }

        /* =============================================
           KEYFRAMES
        ============================================= */
        @keyframes sidebarIn   { from { transform: translateX(-100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @keyframes logoIn      { from { opacity: 0; transform: scale(0.85); } to { opacity: 1; transform: scale(1); } }
        @keyframes userCardIn  { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes navItemIn   { from { opacity: 0; transform: translateX(-16px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes topbarIn    { from { opacity: 0; transform: translateY(-100%); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pageIn      { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes alertIn     { from { opacity: 0; transform: translateY(-8px) scaleY(0.94); } to { opacity: 1; transform: translateY(0) scaleY(1); } }
        @keyframes cardIn      { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes badgeBounce { 0%,100% { transform: scale(1); } 40% { transform: scale(1.25) translateY(-3px); } 70% { transform: scale(0.94) translateY(1px); } }
        @keyframes activePulse { 0% { box-shadow: 0 0 0 0 rgba(59,130,246,0.55); } 70% { box-shadow: 0 0 0 7px rgba(59,130,246,0); } 100% { box-shadow: 0 0 0 0 rgba(59,130,246,0); } }
        @keyframes rippleOut   { from { transform: scale(0); opacity: 0.4; } to { transform: scale(5); opacity: 0; } }
        @keyframes shimmer     { 0% { background-position: -250% center; } 100% { background-position: 250% center; } }
        @keyframes iconBounce  { 0%,100% { transform: translateY(0) rotate(0deg); } 30% { transform: translateY(-3px) rotate(-6deg); } 65% { transform: translateY(1px) rotate(3deg); } }
        @keyframes spin        { to { transform: rotate(360deg); } }

        /* =============================================
           RESET & BASE
        ============================================= */
        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: var(--font);
            font-size: 14.5px;
            font-weight: 400;
            color: var(--text-1);
            background: var(--body-bg);
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* =============================================
           SIDEBAR
        ============================================= */
        #sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0;
            z-index: 1000;
            overflow: hidden;
            animation: sidebarIn 0.4s var(--ease-spring) both;
        }

        #sidebar::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--sidebar-accent), #818cf8, #a5b4fc, var(--sidebar-accent));
            background-size: 250% auto;
            animation: shimmer 3.5s linear infinite;
        }

        .sidebar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            height: 64px;
            border-bottom: 1px solid var(--sidebar-border);
            flex-shrink: 0;
        }

        .sidebar-header .navbar-brand { padding: 0; display: flex; align-items: center; }

        .sidebar-header img {
            height: 30px;
            filter: brightness(0) invert(1);
            opacity: 0.9;
            animation: logoIn 0.5s var(--ease-bounce) 0.12s both;
        }

        .sidebar-header .btn-link {
            color: var(--sidebar-text);
            padding: 6px;
            border: none;
            line-height: 1;
            transition: color var(--t), transform 0.15s ease;
        }

        .sidebar-header .btn-link:hover {
            color: var(--sidebar-text-active);
            transform: rotate(90deg);
        }

        .sidebar-user {
            padding: 14px 16px;
            border-bottom: 1px solid var(--sidebar-border);
            flex-shrink: 0;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            background: var(--sidebar-surface);
            border-radius: var(--r-md);
            border: 1px solid var(--sidebar-border);
            animation: userCardIn 0.4s ease 0.28s both;
            transition: border-color var(--t), background var(--t);
        }

        .user-info:hover {
            background: rgba(255,255,255,0.04);
            border-color: rgba(255,255,255,0.1);
        }

        .user-info i {
            font-size: 22px;
            color: var(--sidebar-accent);
            flex-shrink: 0;
            transition: transform 0.3s var(--ease-bounce);
        }

        .user-info:hover i { transform: scale(1.1); }

        .user-info span {
            font-size: 13px;
            font-weight: 500;
            color: var(--sidebar-text-active);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sidebar .list-unstyled {
            padding: 10px 10px 20px;
            margin: 0;
            flex: 1;
            overflow-y: auto;
        }

        .sidebar .list-unstyled::-webkit-scrollbar { width: 3px; }
        .sidebar .list-unstyled::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 4px; }

        .sidebar .list-unstyled li { margin-bottom: 1px; }

        /* Staggered entrance */
        .sidebar .list-unstyled > li:nth-child(1)  { animation: navItemIn 0.35s ease 0.30s both; }
        .sidebar .list-unstyled > li:nth-child(2)  { animation: navItemIn 0.35s ease 0.35s both; }
        .sidebar .list-unstyled > li:nth-child(3)  { animation: navItemIn 0.35s ease 0.40s both; }
        .sidebar .list-unstyled > li:nth-child(4)  { animation: navItemIn 0.35s ease 0.45s both; }
        .sidebar .list-unstyled > li:nth-child(5)  { animation: navItemIn 0.35s ease 0.50s both; }
        .sidebar .list-unstyled > li:nth-child(6)  { animation: navItemIn 0.35s ease 0.55s both; }
        .sidebar .list-unstyled > li:nth-child(7)  { animation: navItemIn 0.35s ease 0.60s both; }
        .sidebar .list-unstyled > li:nth-child(8)  { animation: navItemIn 0.35s ease 0.65s both; }
        .sidebar .list-unstyled > li:nth-child(9)  { animation: navItemIn 0.35s ease 0.70s both; }
        .sidebar .list-unstyled > li:nth-child(10) { animation: navItemIn 0.35s ease 0.75s both; }

        .sidebar ul li a,
        .sidebar ul li form a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 14px;
            border-radius: var(--r-sm);
            color: var(--sidebar-text);
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 400;
            position: relative;
            overflow: hidden;
            white-space: nowrap;
            transition: background var(--t), color var(--t);
        }

        .sidebar ul li a i {
            font-size: 16px;
            width: 18px;
            text-align: center;
            flex-shrink: 0;
            transition: color var(--t);
        }

        .sidebar ul li a:hover {
            background: var(--sidebar-hover);
            color: var(--sidebar-text-active);
        }

        .sidebar ul li a:hover i {
            color: var(--sidebar-accent);
            animation: iconBounce 0.4s ease;
        }

        .sidebar ul li a.active {
            background: var(--sidebar-accent-dim);
            color: var(--sidebar-text-active);
            font-weight: 500;
        }

        .sidebar ul li a.active i { color: var(--sidebar-accent); }

        .sidebar ul li a.active::before {
            content: '';
            position: absolute;
            left: 0; top: 50%;
            transform: translateY(-50%);
            width: 3px; height: 18px;
            background: var(--sidebar-accent);
            border-radius: 0 2px 2px 0;
            animation: activePulse 2s ease-out 0.8s 2;
        }

        .nav-ripple {
            position: absolute;
            border-radius: 50%;
            background: rgba(59,130,246,0.22);
            width: 8px; height: 8px;
            pointer-events: none;
            animation: rippleOut 0.55s ease-out forwards;
        }

        .sidebar a.dropdown-toggle {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 14px;
            border-radius: var(--r-sm);
            color: var(--sidebar-text);
            text-decoration: none;
            font-size: 13.5px;
            cursor: pointer;
            transition: background var(--t), color var(--t);
        }

        .sidebar a.dropdown-toggle i { font-size: 16px; width: 18px; text-align: center; flex-shrink: 0; }

        .sidebar a.dropdown-toggle::after {
            content: '\F282';
            font-family: "bootstrap-icons";
            font-size: 11px;
            margin-left: auto;
            transition: transform 0.22s ease;
        }

        .sidebar a.dropdown-toggle[aria-expanded="true"]::after { transform: rotate(180deg); }

        .sidebar a.dropdown-toggle:hover {
            background: var(--sidebar-hover);
            color: var(--sidebar-text-active);
        }

        .sidebar a.dropdown-toggle:hover i {
            color: var(--sidebar-accent);
            animation: iconBounce 0.4s ease;
        }

        #archiveSubmenu {
            background: rgba(0,0,0,0.18);
            border-radius: var(--r-sm);
            margin: 2px 0;
            padding: 3px 0;
        }

        #archiveSubmenu li a { padding-left: 42px; font-size: 13px; }

        .sidebar #logoutForm a { color: rgba(248,113,113,0.65); }
        .sidebar #logoutForm a:hover { background: rgba(248,113,113,0.07); color: #f87171; }
        .sidebar #logoutForm a:hover i { color: #f87171; }

        .sidebar-logout-sep {
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px solid var(--sidebar-border);
        }

        /* =============================================
           CONTENT
        ============================================= */
        #content {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            transition: margin-left var(--t);
        }

        #content > .navbar {
            height: var(--topbar-h);
            background: #fff !important;
            border-bottom: 1px solid rgba(0,0,0,0.07) !important;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 900;
            animation: topbarIn 0.36s var(--ease-spring) 0.18s both;
        }

        #content > .navbar .container-fluid { padding: 0; gap: 16px; }

        #content > .navbar .navbar-text {
            font-size: 15px;
            font-weight: 500;
            color: var(--text-1);
            letter-spacing: -0.01em;
        }

        #sidebarCollapseShow {
            color: var(--text-2);
            padding: 6px 8px;
            border: none;
            transition: color var(--t), transform 0.2s ease;
        }

        #sidebarCollapseShow:hover { color: var(--text-1); transform: scale(1.1); }

        .content-wrapper {
            padding: 28px;
            flex: 1;
            animation: pageIn 0.44s var(--ease-spring) 0.22s both;
        }

        /* =============================================
           MOBILE
        ============================================= */
        @media (max-width: 767.98px) {
            #sidebar { transform: translateX(-100%); animation: none; }
            #sidebar.active {
                transform: translateX(0);
                animation: sidebarIn 0.32s var(--ease-spring) both;
                box-shadow: 6px 0 32px rgba(0,0,0,0.28);
            }
            #content { margin-left: 0; }
            .content-wrapper { padding: 20px 16px; }
        }

        /* =============================================
           PUBLIC HEADER
        ============================================= */
        .landing-header {
            background: #fff !important;
            border-bottom: 1px solid rgba(0,0,0,0.07) !important;
            box-shadow: none !important;
            height: 64px;
            animation: topbarIn 0.36s var(--ease-spring) both;
        }

        .landing-header .navbar-brand img { height: 32px; }

        .landing-header .nav-link {
            font-family: var(--font);
            font-size: 14px;
            font-weight: 500;
            color: var(--text-2) !important;
            padding: 6px 14px !important;
            border-radius: var(--r-sm);
            transition: color var(--t), background var(--t), transform 0.12s ease;
        }

        .landing-header .nav-link:hover {
            color: var(--text-1) !important;
            background: rgba(0,0,0,0.04);
            transform: translateY(-1px);
        }

        .landing-header .navbar-nav:last-child .nav-link {
            border: 1px solid rgba(0,0,0,0.12);
            color: var(--text-1) !important;
            margin-left: 6px;
            padding: 6px 16px !important;
        }

        .landing-header .navbar-nav:last-child .nav-item:last-child .nav-link {
            background: var(--sidebar-accent);
            border-color: var(--sidebar-accent);
            color: #fff !important;
        }

        .landing-header .navbar-nav:last-child .nav-item:last-child .nav-link:hover {
            background: #2563eb;
            border-color: #2563eb;
            transform: translateY(-1px);
        }

        footer.footer {
            padding: 24px 0;
            font-size: 13px;
            color: var(--text-3);
            border-top: 1px solid rgba(0,0,0,0.07) !important;
            margin-top: 48px;
        }

        /* =============================================
           COMPONENTS
        ============================================= */
        .card {
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: var(--r-lg);
            box-shadow: none;
            animation: cardIn 0.4s var(--ease-spring) both;
        }

        .card:nth-child(1) { animation-delay: 0.10s; }
        .card:nth-child(2) { animation-delay: 0.18s; }
        .card:nth-child(3) { animation-delay: 0.26s; }
        .card:nth-child(4) { animation-delay: 0.34s; }
        .card:nth-child(5) { animation-delay: 0.42s; }

        .card-header {
            background: transparent;
            border-bottom: 1px solid rgba(0,0,0,0.06);
            padding: 16px 20px;
            font-weight: 500;
            font-size: 14.5px;
        }

        .card-body { padding: 20px; }

        .alert {
            border-radius: var(--r-md);
            border: none;
            font-size: 14px;
            padding: 12px 16px;
            animation: alertIn 0.3s var(--ease-spring) both;
            transform-origin: top center;
        }

        .btn {
            font-family: var(--font);
            font-weight: 500;
            border-radius: var(--r-sm);
            font-size: 13.5px;
            padding: 7px 16px;
            transition: all 0.15s ease, transform 0.1s ease;
        }

        .btn:active { transform: scale(0.96); }
        .btn-primary { background: var(--sidebar-accent); border-color: var(--sidebar-accent); }
        .btn-primary:hover { background: #2563eb; border-color: #2563eb; }

        .table { font-size: 13.5px; }
        .table th {
            font-weight: 500;
            font-size: 12px;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--text-3);
            border-bottom-width: 1px;
        }

        .form-control, .form-select {
            border-radius: var(--r-sm);
            border-color: rgba(0,0,0,0.12);
            font-size: 14px;
            font-family: var(--font);
            transition: border-color var(--t), box-shadow var(--t);
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--sidebar-accent);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

        .badge {
            animation: badgeBounce 0.55s var(--ease-bounce) 1.1s both;
            display: inline-block;
        }

        #page-transition-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255,255,255,0);
            pointer-events: none;
            z-index: 9999;
            transition: background 0.18s ease;
        }

        .spin { animation: spin 0.8s linear infinite; display: inline-block; }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="wrapper">
            <!-- Sidebar -->
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-header">
                    <a class="navbar-brand">
                        <img src="~/images/logo-combined2.png" alt="Qonnec" height="40">
                    </a>
                    <button id="sidebarCollapse" class="btn btn-link d-md-none">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="sidebar-user">
                    <div class="user-info">
                        <i class="bi bi-person-circle"></i>
                        @{
                            string? fullName = null;
                            if (User.Identity?.IsAuthenticated == true)
                            {
                                var user = await UserManager.GetUserAsync(User);
                                if (user != null)
                                {
                                    fullName = $"{user.FirstName} {user.LastName}";
                                }
                            }
                        }
                        <span>@(fullName ?? User.Identity?.Name)</span>
                    </div>
                </div>

                <ul class="list-unstyled components">
                    @if (User.IsInRole("Admin"))
                    {
                        <li>
                            <a asp-area="" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-speedometer2"></i>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Admin" asp-action="Projects">
                                <i class="bi bi-folder2-open"></i>
                                <span>Projects</span>
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Report" asp-action="Index">
                                <i class="bi bi-bar-chart-line"></i>
                                <span>Reports</span>
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Admin" asp-action="Inquiries">
                                <i class="bi bi-envelope-open"></i>
                                <span>Inquiries</span>
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Admin" asp-action="Users">
                                <i class="bi bi-people"></i>
                                <span>User Management</span>
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Admin" asp-action="VisualEditor">
                                <i class="bi bi-pencil-square"></i>
                                <span>CMS Visual Live Editor</span>
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-controller="Admin" asp-action="Profile">
                                <i class="bi bi-person-badge"></i>
                                <span>Profile</span>
                            </a>
                        </li>
                        <li>
                            <a href="#archiveSubmenu" data-bs-toggle="collapse" class="dropdown-toggle">
                                <i class="bi bi-archive"></i>
                                <span>Archives</span>
                            </a>
                            <ul class="collapse list-unstyled" id="archiveSubmenu">
                                <li>
                                    <a asp-area="" asp-controller="Admin" asp-action="ArchivedProjects">
                                        <i class="bi bi-folder-x"></i>
                                        <span>Archived Projects</span>
                                    </a>
                                </li>
                                <li>
                                    <a asp-area="" asp-controller="Admin" asp-action="ArchivedTasks">
                                        <i class="bi bi-list-check"></i>
                                        <span>Archived Tasks</span>
                                    </a>
                                </li>
                                <li>
                                    <a asp-area="" asp-controller="Admin" asp-action="ArchivedUsers">
                                        <i class="bi bi-person-dash"></i>
                                        <span>Archived Users</span>
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else if (User.IsInRole("Client"))
                    {
                        <li>
                            <a asp-controller="Client" asp-action="Index">
                                <i class="bi bi-speedometer2"></i>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Client" asp-action="Projects">
                                <i class="bi bi-folder2-open"></i>
                                <span>Projects</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Report" asp-action="Index">
                                <i class="bi bi-bar-chart-line"></i>
                                <span>Reports</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Client" asp-action="Profile">
                                <i class="bi bi-person-badge"></i>
                                <span>Profile</span>
                            </a>
                        </li>
                    }
                    else if (User.IsInRole("Employee"))
                    {
                        <li>
                            <a asp-controller="Employee" asp-action="Index">
                                <i class="bi bi-speedometer2"></i>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Employee" asp-action="Projects">
                                <i class="bi bi-folder2-open"></i>
                                <span>Projects</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Employee" asp-action="Notifications">
                                <i class="bi bi-bell"></i>
                                <span>Notifications</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Employee" asp-action="Profile">
                                <i class="bi bi-person-badge"></i>
                                <span>Profile</span>
                            </a>
                        </li>
                    }
                    else if (User.IsInRole("Project Manager"))
                    {
                        <li>
                            <a asp-controller="ProjectManager" asp-action="Index">
                                <i class="bi bi-speedometer2"></i>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="ProjectManager" asp-action="MyProjects">
                                <i class="bi bi-folder2-open"></i>
                                <span>Projects</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Report" asp-action="Index">
                                <i class="bi bi-bar-chart-line"></i>
                                <span>Reports</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="ProjectManager" asp-action="Profile">
                                <i class="bi bi-person-badge"></i>
                                <span>Profile</span>
                            </a>
                        </li>
                        <li>
                            <a href="#archiveSubmenu" data-bs-toggle="collapse" class="dropdown-toggle">
                                <i class="bi bi-archive"></i>
                                <span>Archives</span>
                            </a>
                            <ul class="collapse list-unstyled" id="archiveSubmenu">
                                <li>
                                    <a asp-controller="ProjectManager" asp-action="ArchivedProjects">
                                        <i class="bi bi-folder-x"></i>
                                        <span>Archived Projects</span>
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="ProjectManager" asp-action="ArchivedTasks">
                                        <i class="bi bi-list-check"></i>
                                        <span>Archived Tasks</span>
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li>
                            <a asp-controller="Admin" asp-action="Tickets">
                                <i class="bi bi-ticket-detailed"></i>
                                <span>Tickets</span>
                            </a>
                        </li>
                    }
                    else if (User.IsInRole("Client"))
                    {
                        <li>
                            <a asp-controller="Ticket" asp-action="Index">
                                <i class="bi bi-ticket-detailed"></i>
                                <span>Tickets</span>
                            </a>
                        </li>
                    }
                    <li class="sidebar-logout-sep">
                        <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                            <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit()">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Logout</span>
                            </a>
                        </form>
                    </li>
                </ul>
            </nav>

            <!-- Page Content -->
            <div id="content">
                <!-- Top Navigation -->
                <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
                    <div class="container-fluid d-flex align-items-center flex-nowrap" style="min-width:0;">
                        <button type="button" id="sidebarCollapseShow" class="btn btn-link d-md-none me-2">
                            <i class="bi bi-list fs-5"></i>
                        </button>
                        <span class="navbar-text flex-grow-1 text-truncate" style="min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @ViewData["Title"]
                        </span>
                        <div class="d-flex align-items-center ms-auto" style="gap: 6px;">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @await Html.PartialAsync("_MessagesBadge")
                                @await Html.PartialAsync("_NotificationsBadgeAll")
                            }
                        </div>
                    </div>
                </nav>

                <!-- Main Content -->
                <main role="main" class="content-wrapper">
                    @await Html.PartialAsync("_Alerts")
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3 landing-header">
                <div class="container">
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo-combined2.png" alt="Qonnec" height="40">
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Services">Services</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                            </li>
                        </ul>
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container">
            <main role="main" class="pb-3">
                @await Html.PartialAsync("_Alerts")
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; @DateTime.Now.Year - Project Management System
            </div>
        </footer>
    }

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/table-sort.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            $(document).ready(function () {

                // Bootstrap dropdowns
                [].slice.call(document.querySelectorAll('[data-bs-toggle="dropdown"]'))
                  .forEach(function (el) { new bootstrap.Dropdown(el); });

                // ── Sidebar toggle ──────────────────────────────
                $('#sidebarCollapse').on('click', function () {
                    $('#sidebar').removeClass('active');
                    $('#content').removeClass('active');
                });

                $('#sidebarCollapseShow').on('click', function () {
                    $('#sidebar').addClass('active');
                    $('#content').addClass('active');
                });

                $(document).on('click', function (e) {
                    if ($(window).width() < 768 &&
                        !$(e.target).closest('#sidebar').length &&
                        !$(e.target).closest('#sidebarCollapseShow').length) {
                        $('#sidebar').removeClass('active');
                        $('#content').removeClass('active');
                    }
                });

                // ── Active nav highlight ────────────────────────
                var currentPath = window.location.pathname;
                $('.sidebar ul li a').each(function () {
                    var href = $(this).attr('href');
                    if (href && href !== 'javascript:void(0)' && currentPath === href) {
                        $(this).addClass('active');
                        if ($(this).closest('.collapse').length) {
                            $(this).closest('.collapse').addClass('show');
                            $(this).closest('.collapse').prev('.dropdown-toggle').attr('aria-expanded', 'true');
                        }
                    }
                });

                // ── Ripple on sidebar nav click ─────────────────
                $('.sidebar ul li a').on('click', function (e) {
                    var $link = $(this);
                    var offset = $link.offset();
                    var $r = $('<span class="nav-ripple">').css({
                        left: e.pageX - offset.left - 4,
                        top:  e.pageY - offset.top  - 4
                    });
                    $link.append($r);
                    setTimeout(function () { $r.remove(); }, 600);
                });

                // ── Page transition fade ────────────────────────
                var $overlay = $('<div id="page-transition-overlay">').appendTo('body');
                $(document).on('click', 'a[href]', function (e) {
                    var href = $(this).attr('href');
                    var skip = /^(https?:\/\/|javascript:|#|mailto:)/.test(href)
                               || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey;
                    if (!skip && href && href !== window.location.href) {
                        e.preventDefault();
                        $overlay.css({ background: 'rgba(255,255,255,0.55)', transition: 'background 0.18s ease' });
                        setTimeout(function () { window.location.href = href; }, 170);
                    }
                });

                // ── Topbar title word-by-word reveal ────────────
                var $title = $('.navbar-text');
                var raw = $title.text().trim();
                if (raw) {
                    $title.html(
                        raw.split(' ').map(function (w, i) {
                            var d = (0.32 + i * 0.06) + 's';
                            return '<span style="display:inline-block;opacity:0;transform:translateY(7px);' +
                                   'transition:opacity .26s ease ' + d + ',transform .26s ease ' + d + '">' +
                                   w + '&nbsp;</span>';
                        }).join('')
                    );
                    setTimeout(function () {
                        $title.find('span').css({ opacity: 1, transform: 'translateY(0)' });
                    }, 40);
                }

                // ── Badge bounce on dynamic insertion ──────────
                var observer = new MutationObserver(function (mutations) {
                    mutations.forEach(function (m) {
                        $(m.addedNodes).find('.badge').addBack('.badge').each(function () {
                            var $b = $(this);
                            $b.css('animation', 'none');
                            requestAnimationFrame(function () {
                                $b.css('animation', 'badgeBounce .55s cubic-bezier(.34,1.56,.64,1) both');
                            });
                        });
                    });
                });
                observer.observe(document.body, { childList: true, subtree: true });

            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
