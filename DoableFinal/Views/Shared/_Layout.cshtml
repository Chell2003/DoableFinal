    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/table-sort.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            $(document).ready(function () {
                var dropdownElementList = [].slice.call(document.querySelectorAll('[data-bs-toggle="dropdown"]'))
                var dropdownList = dropdownElementList.map(function (dropdownToggleEl) {
                    return new bootstrap.Dropdown(dropdownToggleEl)
                });

                $('#sidebarCollapse').on('click', function () {
                    $('#sidebar').removeClass('active');
                    $('#content').removeClass('active');
                });

                $('#sidebarCollapseShow').on('click', function () {
                    $('#sidebar').addClass('active');
                    $('#content').addClass('active');
                });

                // Close sidebar when clicking outside on mobile
                $(document).on('click', function (e) {
                    if ($(window).width() < 768) {
                        if (!$(e.target).closest('#sidebar').length && !$(e.target).closest('#sidebarCollapseShow').length) {
                            $('#sidebar').removeClass('active');
                            $('#content').removeClass('active');
                        }
                    }
                });

                // Highlight active nav item
                var currentPath = window.location.pathname;
                $('.sidebar ul li a').each(function () {
                    var href = $(this).attr('href');
                    if (href && href !== 'javascript:void(0)' && currentPath === href) {
                        $(this).addClass('active');
                        if ($(this).closest('.collapse').length) {
                            $(this).closest('.collapse').addClass('show');
                            $(this).closest('.collapse').prev('.dropdown-toggle').attr('aria-expanded', 'true');
                        }
                    }
                });

                // --- Ripple on sidebar nav clicks ---
                $('.sidebar ul li a').on('click', function (e) {
                    var $link = $(this);
                    var offset = $link.offset();
                    var x = e.pageX - offset.left;
                    var y = e.pageY - offset.top;
                    var $ripple = $('<span class="nav-ripple">').css({ left: x - 4, top: y - 4 });
                    $link.append($ripple);
                    setTimeout(function () { $ripple.remove(); }, 600);
                });

                // --- Page transition fade on internal links ---
                var $overlay = $('<div id="page-transition-overlay">').appendTo('body');
                $(document).on('click', 'a[href]', function (e) {
                    var href = $(this).attr('href');
                    var isExternal = /^(https?:\/\/|javascript:|#|mailto:)/.test(href);
                    var isModified = e.metaKey || e.ctrlKey || e.shiftKey || e.altKey;
                    if (!isExternal && !isModified && href && href !== window.location.href) {
                        e.preventDefault();
                        $overlay.css({ background: 'rgba(255,255,255,0.6)', transition: 'background 0.18s ease' });
                        setTimeout(function () { window.location.href = href; }, 170);
                    }
                });

                // --- Topbar title word-by-word reveal ---
                var $title = $('.navbar-text');
                var titleText = $title.text().trim();
                if (titleText) {
                    var words = titleText.split(' ');
                    $title.html(
                        words.map(function (w, i) {
                            return '<span style="display:inline-block;opacity:0;transform:translateY(6px);transition:opacity 0.25s ease ' + (0.3 + i * 0.06) + 's,transform 0.25s ease ' + (0.3 + i * 0.06) + 's">' + w + '&nbsp;</span>';
                        }).join('')
                    );
                    setTimeout(function () {
                        $title.find('span').css({ opacity: 1, transform: 'translateY(0)' });
                    }, 50);
                }

                // --- Re-trigger badge bounce when new badges appear ---
                var observer = new MutationObserver(function (mutations) {
                    mutations.forEach(function (m) {
                        $(m.addedNodes).find('.badge').addBack('.badge').each(function () {
                            var $b = $(this);
                            $b.css('animation', 'none');
                            setTimeout(function () {
                                $b.css('animation', 'badgeBounce 0.55s cubic-bezier(0.34,1.56,0.64,1) both');
                            }, 10);
                        });
                    });
                });
                observer.observe(document.body, { childList: true, subtree: true });
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
