@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project Management System</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reports-print-media.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing-header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/header-dropdown.css" asp-append-version="true" />
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Charts -->
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.41.0/dist/apexcharts.min.js"></script>
    <script src="~/js/scripts.js"></script>

    <style>
        /* =========================================
           DESIGN TOKENS
        ========================================= */
        :root {
            --sidebar-width: 260px;
            --sidebar-bg: #0f1621;
            --sidebar-surface: #192130;
            --sidebar-border: rgba(255,255,255,0.06);
            --sidebar-text: rgba(255,255,255,0.55);
            --sidebar-text-active: #ffffff;
            --sidebar-accent: #3b82f6;
            --sidebar-accent-glow: rgba(59,130,246,0.18);
            --sidebar-hover: rgba(255,255,255,0.05);

            --topbar-height: 60px;
            --topbar-bg: #ffffff;
            --topbar-border: rgba(0,0,0,0.07);

            --body-bg: #f5f6f8;
            --content-bg: #ffffff;

            --text-primary: #111827;
            --text-secondary: #6b7280;
            --text-muted: #9ca3af;

            --radius-sm: 6px;
            --radius-md: 10px;
            --radius-lg: 14px;

            --transition: 0.18s ease;

            --font-body: 'DM Sans', sans-serif;
            --font-display: 'DM Serif Display', serif;
        }

        /* =========================================
           GLOBAL RESET & BASE
        ========================================= */
        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: var(--font-body);
            font-size: 14.5px;
            font-weight: 400;
            color: var(--text-primary);
            background: var(--body-bg);
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        /* =========================================
           AUTHENTICATED LAYOUT WRAPPER
        ========================================= */
        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* =========================================
           SIDEBAR
        ========================================= */
        #sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            transition: transform var(--transition);
            overflow: hidden;
        }

        /* Subtle top accent line */
        #sidebar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--sidebar-accent), #818cf8);
        }

        /* Logo area */
        .sidebar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            height: 64px;
            border-bottom: 1px solid var(--sidebar-border);
            flex-shrink: 0;
        }

        .sidebar-header .navbar-brand {
            padding: 0;
            display: flex;
            align-items: center;
        }

        .sidebar-header img {
            height: 32px;
            filter: brightness(0) invert(1);
            opacity: 0.92;
        }

        .sidebar-header .btn-link {
            color: var(--sidebar-text);
            padding: 4px;
            line-height: 1;
            border: none;
        }

        .sidebar-header .btn-link:hover { color: var(--sidebar-text-active); }

        /* User info */
        .sidebar-user {
            padding: 16px 20px;
            border-bottom: 1px solid var(--sidebar-border);
            flex-shrink: 0;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            background: var(--sidebar-surface);
            border-radius: var(--radius-md);
            border: 1px solid var(--sidebar-border);
        }

        .user-info i {
            font-size: 22px;
            color: var(--sidebar-accent);
            flex-shrink: 0;
        }

        .user-info span {
            font-size: 13px;
            font-weight: 500;
            color: var(--sidebar-text-active);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Navigation list */
        .sidebar .list-unstyled {
            padding: 12px 12px 20px;
            margin: 0;
            flex: 1;
            overflow-y: auto;
        }

        .sidebar .list-unstyled::-webkit-scrollbar { width: 4px; }
        .sidebar .list-unstyled::-webkit-scrollbar-track { background: transparent; }
        .sidebar .list-unstyled::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

        .sidebar .list-unstyled li {
            margin-bottom: 2px;
        }

        /* Nav links */
        .sidebar ul li a,
        .sidebar ul li form a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 14px;
            border-radius: var(--radius-sm);
            color: var(--sidebar-text);
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 400;
            transition: background var(--transition), color var(--transition);
            position: relative;
            white-space: nowrap;
        }

        .sidebar ul li a i {
            font-size: 16px;
            width: 18px;
            text-align: center;
            flex-shrink: 0;
            transition: color var(--transition);
        }

        .sidebar ul li a:hover {
            background: var(--sidebar-hover);
            color: var(--sidebar-text-active);
        }

        .sidebar ul li a:hover i { color: var(--sidebar-accent); }

        .sidebar ul li a.active {
            background: var(--sidebar-accent-glow);
            color: var(--sidebar-text-active);
            font-weight: 500;
        }

        .sidebar ul li a.active i { color: var(--sidebar-accent); }

        /* Active left bar */
        .sidebar ul li a.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 18px;
            background: var(--sidebar-accent);
            border-radius: 0 2px 2px 0;
        }

        /* Dropdown toggle */
        .sidebar a.dropdown-toggle {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 14px;
            border-radius: var(--radius-sm);
            color: var(--sidebar-text);
            text-decoration: none;
            font-size: 13.5px;
            transition: background var(--transition), color var(--transition);
            cursor: pointer;
            position: relative;
        }

        .sidebar a.dropdown-toggle i { font-size: 16px; width: 18px; text-align: center; flex-shrink: 0; }

        .sidebar a.dropdown-toggle::after {
            content: '\F282';
            font-family: "bootstrap-icons";
            font-size: 11px;
            margin-left: auto;
            transition: transform 0.2s ease;
        }

        .sidebar a.dropdown-toggle[aria-expanded="true"]::after {
            transform: rotate(180deg);
        }

        .sidebar a.dropdown-toggle:hover {
            background: var(--sidebar-hover);
            color: var(--sidebar-text-active);
        }

        /* Submenu */
        #archiveSubmenu {
            background: rgba(0,0,0,0.15);
            border-radius: var(--radius-sm);
            margin: 2px 0;
            padding: 4px 0;
        }

        #archiveSubmenu li a {
            padding-left: 42px;
            font-size: 13px;
        }

        /* Logout */
        .sidebar #logoutForm a {
            color: rgba(248, 113, 113, 0.7);
        }

        .sidebar #logoutForm a:hover {
            background: rgba(248, 113, 113, 0.08);
            color: #f87171;
        }

        .sidebar #logoutForm a:hover i { color: #f87171; }

        /* Section divider */
        .sidebar .nav-section {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.22);
            padding: 12px 14px 4px;
            margin-top: 4px;
        }

        /* =========================================
           MAIN CONTENT AREA
        ========================================= */
        #content {
            margin-left: var(--sidebar-width);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            transition: margin-left var(--transition);
        }

        /* =========================================
           TOP NAVIGATION BAR
        ========================================= */
        #content > .navbar {
            height: var(--topbar-height);
            background: var(--topbar-bg) !important;
            border-bottom: 1px solid var(--topbar-border) !important;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 900;
            box-shadow: 0 1px 0 rgba(0,0,0,0.04);
        }

        #content > .navbar .container-fluid {
            padding: 0;
            gap: 16px;
        }

        #content > .navbar .navbar-text {
            font-size: 15px;
            font-weight: 500;
            color: var(--text-primary);
            letter-spacing: -0.01em;
        }

        #sidebarCollapseShow {
            color: var(--text-secondary);
            padding: 6px 8px;
            border: none;
        }

        #sidebarCollapseShow:hover { color: var(--text-primary); }

        /* =========================================
           CONTENT WRAPPER
        ========================================= */
        .content-wrapper {
            padding: 28px 28px;
            flex: 1;
        }

        /* =========================================
           MOBILE RESPONSIVE
        ========================================= */
        @media (max-width: 767.98px) {
            #sidebar {
                transform: translateX(-100%);
            }

            #sidebar.active {
                transform: translateX(0);
                box-shadow: 4px 0 24px rgba(0,0,0,0.25);
            }

            #content {
                margin-left: 0;
            }

            .content-wrapper {
                padding: 20px 16px;
            }
        }

        /* =========================================
           PUBLIC / UNAUTHENTICATED HEADER
        ========================================= */
        body.landing-header header > .navbar {
            background: #ffffff !important;
            border-bottom: 1px solid rgba(0,0,0,0.07) !important;
            box-shadow: none;
            padding: 0 0;
            height: 64px;
        }

        body.landing-header header .navbar .container {
            height: 64px;
            display: flex;
            align-items: center;
        }

        body.landing-header header .navbar-brand img {
            height: 34px;
        }

        body.landing-header header .nav-link {
            font-family: var(--font-body);
            font-size: 14px;
            font-weight: 500;
            color: var(--text-secondary) !important;
            padding: 6px 14px !important;
            border-radius: var(--radius-sm);
            transition: color var(--transition), background var(--transition);
        }

        body.landing-header header .nav-link:hover {
            color: var(--text-primary) !important;
            background: rgba(0,0,0,0.04);
        }

        /* Login/Register pills */
        body.landing-header header .navbar-nav:last-child .nav-link {
            border: 1px solid rgba(0,0,0,0.12);
            color: var(--text-primary) !important;
            margin-left: 6px;
            padding: 6px 16px !important;
        }

        body.landing-header header .navbar-nav:last-child .nav-item:last-child .nav-link {
            background: var(--sidebar-accent);
            border-color: var(--sidebar-accent);
            color: #ffffff !important;
        }

        body.landing-header header .navbar-nav:last-child .nav-item:last-child .nav-link:hover {
            background: #2563eb;
            border-color: #2563eb;
        }

        /* Public body layout */
        body.landing-header > .container {
            padding-top: 40px;
        }

        /* Footer */
        .footer {
            padding: 24px 0;
            font-size: 13px;
            color: var(--text-muted);
            border-top: 1px solid rgba(0,0,0,0.07) !important;
            margin-top: 48px;
        }

        /* =========================================
           NOTIFICATION / MESSAGE BADGES
        ========================================= */
        .badge-icon-btn {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid transparent;
            transition: background var(--transition), color var(--transition), border-color var(--transition);
            cursor: pointer;
            font-size: 18px;
        }

        .badge-icon-btn:hover {
            background: rgba(0,0,0,0.05);
            color: var(--text-primary);
            border-color: rgba(0,0,0,0.07);
        }

        /* =========================================
           GLOBAL CARD POLISH
        ========================================= */
        .card {
            border: 1px solid rgba(0,0,0,0.07);
            border-radius: var(--radius-lg);
            box-shadow: none;
        }

        .card-header {
            background: transparent;
            border-bottom: 1px solid rgba(0,0,0,0.06);
            padding: 16px 20px;
            font-weight: 500;
            font-size: 14.5px;
        }

        .card-body {
            padding: 20px;
        }

        /* =========================================
           BUTTONS
        ========================================= */
        .btn {
            font-family: var(--font-body);
            font-weight: 500;
            border-radius: var(--radius-sm);
            font-size: 13.5px;
            padding: 7px 16px;
            transition: all var(--transition);
        }

        .btn-primary {
            background: var(--sidebar-accent);
            border-color: var(--sidebar-accent);
        }

        .btn-primary:hover {
            background: #2563eb;
            border-color: #2563eb;
        }

        /* =========================================
           TABLE POLISH
        ========================================= */
        .table {
            font-size: 13.5px;
        }

        .table th {
            font-weight: 500;
            font-size: 12px;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--text-muted);
            border-bottom-width: 1px;
        }

        /* =========================================
           FORM CONTROLS
        ========================================= */
        .form-control, .form-select {
            border-radius: var(--radius-sm);
            border-color: rgba(0,0,0,0.12);
            font-size: 14px;
            font-family: var(--font-body);
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--sidebar-accent);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
        }

        /* =========================================
           ALERT POLISH
        ========================================= */
        .alert {
            border-radius: var(--radius-md);
            border: none;
            font-size: 14px;
            padding: 12px 16px;
        }

        /* =========================================
           KEYFRAME DEFINITIONS
        ========================================= */

        /* Sidebar slides in from the left */
        @keyframes sidebarReveal {
            from { transform: translateX(-100%); opacity: 0; }
            to   { transform: translateX(0);    opacity: 1; }
        }

        /* Logo fades + scales in */
        @keyframes logoIn {
            from { opacity: 0; transform: scale(0.88); }
            to   { opacity: 1; transform: scale(1); }
        }

        /* Nav items slide in from left, staggered */
        @keyframes navItemIn {
            from { opacity: 0; transform: translateX(-14px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        /* User card fades in from below */
        @keyframes userCardIn {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Topbar drops down */
        @keyframes topbarIn {
            from { opacity: 0; transform: translateY(-100%); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Page content fades + rises */
        @keyframes pageIn {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Active indicator pulse glow */
        @keyframes activePulse {
            0%   { box-shadow: 0 0 0 0 rgba(59,130,246,0.5); }
            70%  { box-shadow: 0 0 0 6px rgba(59,130,246,0); }
            100% { box-shadow: 0 0 0 0 rgba(59,130,246,0); }
        }

        /* Top accent bar shimmer */
        @keyframes shimmer {
            0%   { background-position: -200% center; }
            100% { background-position:  200% center; }
        }

        /* Badge bounce for notifications */
        @keyframes badgeBounce {
            0%, 100% { transform: translateY(0) scale(1); }
            30%       { transform: translateY(-4px) scale(1.15); }
            60%       { transform: translateY(2px) scale(0.95); }
        }

        /* Ripple on nav click */
        @keyframes ripple {
            from { transform: scale(0); opacity: 0.35; }
            to   { transform: scale(4); opacity: 0; }
        }

        /* Page-leave flash (route change feedback) */
        @keyframes pageLeave {
            from { opacity: 1; }
            to   { opacity: 0; transform: translateY(-6px); }
        }

        /* Alert slides in from top */
        @keyframes alertSlideIn {
            from { opacity: 0; transform: translateY(-10px) scaleY(0.95); }
            to   { opacity: 1; transform: translateY(0) scaleY(1); }
        }

        /* Card entrance for dynamically-added cards */
        @keyframes cardEntrance {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Spin for loading states */
        @keyframes spinSlow {
            from { transform: rotate(0deg); }
            to   { transform: rotate(360deg); }
        }

        /* =========================================
           ANIMATION APPLICATION
        ========================================= */

        /* — Sidebar — */
        #sidebar {
            animation: sidebarReveal 0.38s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        @media (max-width: 767.98px) {
            #sidebar { animation: none; }
            #sidebar.active { animation: sidebarReveal 0.3s cubic-bezier(0.22, 1, 0.36, 1) both; }
        }

        /* — Logo — */
        .sidebar-header .navbar-brand img {
            animation: logoIn 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s both;
        }

        /* — Top accent shimmer — */
        #sidebar::before {
            background: linear-gradient(
                90deg,
                var(--sidebar-accent),
                #818cf8,
                #a5b4fc,
                var(--sidebar-accent)
            );
            background-size: 200% auto;
            animation: shimmer 3.5s linear infinite;
        }

        /* — User card — */
        .sidebar-user .user-info {
            animation: userCardIn 0.4s ease 0.25s both;
        }

        /* — Nav items — staggered */
        .sidebar .list-unstyled > li:nth-child(1)  { animation: navItemIn 0.35s ease 0.28s both; }
        .sidebar .list-unstyled > li:nth-child(2)  { animation: navItemIn 0.35s ease 0.33s both; }
        .sidebar .list-unstyled > li:nth-child(3)  { animation: navItemIn 0.35s ease 0.38s both; }
        .sidebar .list-unstyled > li:nth-child(4)  { animation: navItemIn 0.35s ease 0.43s both; }
        .sidebar .list-unstyled > li:nth-child(5)  { animation: navItemIn 0.35s ease 0.48s both; }
        .sidebar .list-unstyled > li:nth-child(6)  { animation: navItemIn 0.35s ease 0.53s both; }
        .sidebar .list-unstyled > li:nth-child(7)  { animation: navItemIn 0.35s ease 0.58s both; }
        .sidebar .list-unstyled > li:nth-child(8)  { animation: navItemIn 0.35s ease 0.63s both; }
        .sidebar .list-unstyled > li:nth-child(9)  { animation: navItemIn 0.35s ease 0.68s both; }
        .sidebar .list-unstyled > li:nth-child(10) { animation: navItemIn 0.35s ease 0.73s both; }

        /* — Active indicator pulse — */
        .sidebar ul li a.active::before {
            animation: activePulse 2s ease-out 0.8s 2;
        }

        /* — Nav item hover: icon micro-bounce — */
        .sidebar ul li a:hover i,
        .sidebar a.dropdown-toggle:hover i {
            animation: badgeBounce 0.4s ease;
        }

        /* — Nav item click ripple — */
        .sidebar ul li a {
            overflow: hidden;
        }

        .nav-ripple {
            position: absolute;
            border-radius: 50%;
            background: rgba(59,130,246,0.25);
            width: 8px;
            height: 8px;
            pointer-events: none;
            animation: ripple 0.55s ease-out forwards;
        }

        /* — Topbar — */
        #content > .navbar {
            animation: topbarIn 0.35s cubic-bezier(0.22, 1, 0.36, 1) 0.15s both;
        }

        /* — Main content — */
        .content-wrapper {
            animation: pageIn 0.42s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
        }

        /* — Alerts — */
        .alert {
            animation: alertSlideIn 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
            transform-origin: top center;
        }

        /* — Notification badge bounce on load — */
        .badge {
            animation: badgeBounce 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 1s both;
            display: inline-block;
        }

        /* — Cards appear on load — */
        .card {
            animation: cardEntrance 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        /* Stagger cards if multiple siblings */
        .card:nth-child(1) { animation-delay: 0.1s; }
        .card:nth-child(2) { animation-delay: 0.17s; }
        .card:nth-child(3) { animation-delay: 0.24s; }
        .card:nth-child(4) { animation-delay: 0.31s; }
        .card:nth-child(5) { animation-delay: 0.38s; }

        /* — Buttons: press feedback — */
        .btn:active {
            transform: scale(0.96);
        }

        .btn {
            transition: all 0.15s ease, transform 0.1s ease;
        }

        /* — Public nav links — */
        body.landing-header header .nav-link {
            transition: color var(--transition), background var(--transition), transform 0.12s ease;
        }

        body.landing-header header .nav-link:hover {
            transform: translateY(-1px);
        }

        /* — Page transition overlay — */
        #page-transition-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255,255,255,0);
            pointer-events: none;
            z-index: 9999;
            transition: opacity 0.2s ease;
        }

        /* — Loading spinner utility class — */
        .spin {
            animation: spinSlow 0.8s linear infinite;
            display: inline-block;
        }

        /* Respect reduced-motion preference */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body class="landing-header">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="wrapper">
            <!-- Sidebar -->
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-header">
                    <a class="navbar-brand">
                        <img src="~/images/logo-combined2.png" alt="Qonnec" height="40">
                    </a>
