@using Microsoft.EntityFrameworkCore
@inject DoableFinal.Data.ApplicationDbContext DbContext
@{
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var unreadCount = await DbContext.Notifications.CountAsync(n => n.UserId == userId && !n.IsRead);
    var userRole = User.IsInRole("Admin") ? "Admin" :
                  User.IsInRole("Project Manager") ? "Project Manager" :
                  User.IsInRole("Employee") ? "Employee" :
                  User.IsInRole("Client") ? "Client" : "";
    var controller = userRole.Replace(" ", "");
}

<li class="nav-item">
    <a asp-controller="@controller" asp-action="Notifications"
       class="nav-link position-relative d-flex align-items-center justify-content-center"
       style="width:36px; height:36px; border-radius:8px; color:#495057;"
       title="Notifications">
        <i class="bi bi-bell" style="font-size:1.1rem;"></i>
        @if (unreadCount > 0)
        {
            <span class="position-absolute badge rounded-pill bg-danger"
                  style="top:2px; right:2px; font-size:.6rem; padding:2px 5px; min-width:16px;">
                @unreadCount
                <span class="visually-hidden">unread notifications</span>
            </span>
        }
    </a>
</li>
