@model IEnumerable<DoableFinal.Models.ProjectTask>

@{
    ViewData["Title"] = "Tasks";
    var query = Context.Request.Query["q"].ToString();
    var statusFilter = Context.Request.Query["statusFilter"].ToString();
    var categoryFilter = Context.Request.Query["categoryFilter"].ToString();
    var fromDate = Context.Request.Query["fromDate"].ToString();
    var toDate = Context.Request.Query["toDate"].ToString();
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Tasks</h1>
            <p class="text-muted small mb-0">View and manage all tasks for your projects</p>
        </div>
        <div>
            <a asp-action="CreateTask" class="btn btn-primary">
                <i class="bi bi-plus-square"></i> Create Task
            </a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-funnel"></i> Filters & Search</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3" role="search" aria-label="Task search and filter">
                <div class="col-12 col-md-6">
                    <label for="searchInput" class="form-label">Search</label>
                    <input type="search" id="searchInput" name="q" class="form-control" placeholder="Search by title or project..." value="@query" aria-label="Search tasks" />
                </div>

            <div class="col-12 col-md-2">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select id="statusFilter" name="statusFilter" class="form-select">
                        <option value="">All statuses</option>
                        @foreach (var s in (List<string>)ViewBag.AvailableStatuses)
                        {
                            if (statusFilter == s || ViewBag.StatusFilter == s)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-md-3">
                        <label for="categoryFilter" class="form-label">Category</label>

                        <input type="text"
                               id="categoryFilter"
                               name="categoryFilter"
                               class="form-control"
                               placeholder="e.g. Bug Fix"
                               value="@categoryFilter"
                               list="catOptions"/>

                        <datalist id="catOptions">
                            <option value="Additional Feature"></option>
                            <option value="Bug Fix"></option>
                            <option value="New Module"></option>
                            <option value="Maintenance"></option>
                            <option value="Research"></option>
                            <option value="Client Request"></option>
                            <option value="Internal Project"></option>
                        </datalist>
                    </div>
              <div class="col-12 col-md-2">
                    <label for="applyBtn" class="form-label">&nbsp;</label>
                    <button id="applyBtn" class="btn btn-primary w-100" type="submit">
                        <i class="bi bi-search"></i> Apply Filters
                    </button>
                </div>

                <div class="col-12">
                    <hr class="my-2" />
                </div>

                <div class="col-12 col-md-4">
                    <label for="fromDate" class="form-label"><i class="bi bi-calendar-event"></i> From Date</label>
                    <input type="date" id="fromDate" name="fromDate" class="form-control" value="@fromDate" aria-label="From date" />
                </div>

                <div class="col-12 col-md-4">
                    <label for="toDate" class="form-label"><i class="bi bi-calendar-event"></i> To Date</label>
                    <input type="date" id="toDate" name="toDate" class="form-control" value="@toDate" aria-label="To date" />
                </div>

                <div class="col-12 col-md-4">
                    <label for="applyDateBtn" class="form-label">&nbsp;</label>
                    <button id="applyDateBtn" class="btn btn-outline-primary w-100" type="submit">
                        <i class="bi bi-calendar3"></i> Apply Date Range
                    </button>
                </div>

                <div class="col-12 text-end">
                    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Tasks", "ProjectManager")">
                        <i class="bi bi-x-circle"></i> Reset All Filters
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 table-fit-screen">
                   <thead class="table-light">
                        <tr>
                            <th style="width:14%;">Ref #</th>
                            <th style="width:22%;">Title</th>
                            <th style="width:18%;" class="col-hide-sm">Project</th>
                            <th style="width:14%;">Status</th>
                            <th style="width:12%;">Priority</th>
                            <th style="width:12%;">Due Date</th>
                            <th class="actions-col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox"></i> No tasks found
                                </td>
                            </tr>
                        }
                        @foreach (var task in Model)
                        {
                            <tr>
                                <td data-label="Ref #"><code class="small text-muted">@(task.ReferenceNumber ?? "—")</code></td>
                                <td data-label="Title">@task.Title</td>
                                <td data-label="Project" class="col-hide-sm">@task.Project.Name</td>
                                <td data-label="Status">
                                    <span class="badge bg-@(task.Status switch {
                                        "Not Started" => "secondary",
                                        "In Progress" => "primary",
                                        "On Hold" => "warning",
                                        "Completed" => "success",
                                        _ => "secondary"
                                    })">@task.Status</span>
                                </td>
                                <td data-label="Priority">
                                    <span class="badge bg-@(task.Priority switch {
                                        "Low" => "info",
                                        "Medium" => "warning",
                                        "High" => "danger",
                                        _ => "secondary"
                                    })">@task.Priority</span>
                                </td>
                                <td data-label="Due Date">@task.DueDate.ToString("MMM dd, yyyy")</td>
                                <td data-label="Actions" class="actions-col">
                                <div class="btn-group">
                                    <a asp-controller="ProjectManager"
                                       asp-action="TaskDetails"
                                       asp-route-id="@task.Id"
                                       class="btn btn-sm btn-outline-primary"
                                       title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </div>
                            </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
