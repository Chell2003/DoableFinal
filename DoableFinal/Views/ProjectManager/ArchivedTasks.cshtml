@model IEnumerable<DoableFinal.Models.ProjectTask>

@{
    ViewData["Title"] = "Archived Tasks";
    var query = Context.Request.Query["q"].ToString();
    var fromDate = Context.Request.Query["fromDate"].ToString();
    var toDate = Context.Request.Query["toDate"].ToString();
}

@* Show TempData flash messages (Success / Error) so redirects that set TempData display them immediately *@




<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Archived Tasks</h1>
            <p class="text-muted small mb-0">View and manage archived tasks</p>
        </div>
      
        <div>
             <a asp-controller="ProjectManager"
                           asp-action="Tasks"
                           class="btn btn-secondary btn-sm me-2">
                            <i class="fas fa-tasks"></i> Back to Tasks
                        </a>
        <span class="badge bg-secondary fs-6">@(Model?.Count() ?? 0) Archived</span>
    </div>
</div>
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-funnel"></i> Filters & Search</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3" role="search" aria-label="Archived task search and filter">
                <div class="col-md-9">
                    <label for="searchInput" class="form-label">Search</label>
                    <input type="search" id="searchInput" name="q" class="form-control" placeholder="Search by task title or project..." value="@query" aria-label="Search archived tasks" />
                </div>

                <div class="col-md-3">
                    <label for="applyBtn" class="form-label">&nbsp;</label>
                    <button id="applyBtn" class="btn btn-primary w-100" type="submit">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>

                <div class="col-12">
                    <hr class="my-2" />
                </div>

                <div class="col-md-4">
                    <label for="fromDate" class="form-label"><i class="bi bi-calendar-event"></i> From Date</label>
                    <input type="date" id="fromDate" name="fromDate" class="form-control" value="@fromDate" aria-label="From date" />
                </div>

                <div class="col-md-4">
                    <label for="toDate" class="form-label"><i class="bi bi-calendar-event"></i> To Date</label>
                    <input type="date" id="toDate" name="toDate" class="form-control" value="@toDate" aria-label="To date" />
                </div>

                <div class="col-md-4">
                    <label for="applyDateBtn" class="form-label">&nbsp;</label>
                    <button id="applyDateBtn" class="btn btn-outline-primary w-100" type="submit">
                        <i class="bi bi-calendar3"></i> Apply Date Range
                    </button>
                </div>

                <div class="col-12 text-end">
                    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("ArchivedTasks", "ProjectManager")">
                        <i class="bi bi-x-circle"></i> Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" style="width: 25%;">Task Title</th>
                            <th scope="col" style="width: 20%;">Project</th>
                            <th scope="col" style="width: 18%;">Status</th>
                            <th scope="col" style="width: 15%;">Archived At</th>
                            <th scope="col" class="text-end" style="width: 22%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox"></i> No archived tasks found
                                </td>
                            </tr>
                        }
                        @foreach (var task in Model)
                        {
               <tr>
    <td>
        <strong>@task.Title</strong>
    </td>

    <td>
        <small>@task.Project.Name</small>
    </td>

    <td>
        <span class="badge bg-@(task.Status switch {
            "Not Started" => "secondary",
            "In Progress" => "primary",
            "On Hold" => "warning",
            "Completed" => "success",
            _ => "secondary"
        })">
            @task.Status
        </span>
    </td>

    <td>
        <small class="text-muted">
            @task.ArchivedAt?.ToString("MMM dd, yyyy")
        </small>
    </td>

    <td class="text-end">
        <div class="d-inline-flex align-items-center gap-1">
            <a asp-action="TaskDetails"
               asp-route-id="@task.Id"
               class="btn btn-sm btn-outline-info"
               title="View Details">
                <i class="bi bi-eye"></i>
            </a>

            <form asp-action="UnarchiveTask"
                  asp-route-id="@task.Id"
                  method="post"
                  class="d-inline">
                @Html.AntiForgeryToken()

                <button type="submit"
                        class="btn btn-sm btn-outline-success"
                        title="Unarchive Task"
                        onclick="return confirm('Are you sure you want to unarchive this task?')">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </button>
            </form>
        </div>
    </td>
</tr>
            }
        </tbody>
    </table>
</div>
