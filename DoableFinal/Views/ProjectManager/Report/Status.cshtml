@model DoableFinal.ViewModels.StatusReportViewModel

@{
    ViewData["Title"] = "Status Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string PriorityColor(string p) => p switch {
        "High" or "Critical" => "danger",
        "Medium"             => "warning",
        "Low"                => "info",
        _                    => "secondary"
    };

    var allTasks = Model.CompletedTasks.Concat(Model.InProgressTasks).Concat(Model.UpcomingTasks).ToList();
    var tasksByCategory = allTasks
        .GroupBy(t => string.IsNullOrEmpty(t.Category) ? "Uncategorized" : t.Category)
        .OrderBy(g => g.Key == "Uncategorized" ? "zzz" : g.Key)
        .ToList();

    // Filter state
    var filterPriority   = Context.Request.Query["priority"].ToString();
    var filterCategory   = Context.Request.Query["category"].ToString();
    var filterStatus     = Context.Request.Query["status"].ToString();
    var filterSearch     = Context.Request.Query["search"].ToString();

    var allPriorities = allTasks.Select(t => t.Priority).Distinct().OrderBy(x => x).ToList();
    var allCategories = allTasks.Select(t => string.IsNullOrEmpty(t.Category) ? "Uncategorized" : t.Category).Distinct().OrderBy(x => x).ToList();

    Func<TaskStatusItem, bool> taskFilter = t => {
        if (!string.IsNullOrEmpty(filterPriority) && t.Priority != filterPriority) return false;
        if (!string.IsNullOrEmpty(filterCategory)) {
            var cat = string.IsNullOrEmpty(t.Category) ? "Uncategorized" : t.Category;
            if (cat != filterCategory) return false;
        }
        if (!string.IsNullOrEmpty(filterSearch) && !t.Title.Contains(filterSearch, StringComparison.OrdinalIgnoreCase)) return false;
        return true;
    };

    var filteredCompleted   = Model.CompletedTasks.Where(taskFilter).ToList();
    var filteredInProgress  = Model.InProgressTasks.Where(taskFilter).ToList();
    var filteredUpcoming    = Model.UpcomingTasks.Where(taskFilter).ToList();
}

<style>
    .rpt-header {
        background: linear-gradient(135deg, #1e3a5f 0%, #2d6a9f 100%);
        border-radius: 12px; padding: 1.5rem 2rem; color:#fff; margin-bottom:1.5rem;
    }
    .rpt-kpi { background:#fff; border-radius:10px; padding:1rem 1.25rem; border-left:4px solid; height:100%; }
    .rpt-kpi .num { font-size:1.8rem; font-weight:800; line-height:1.1; }
    .rpt-kpi .lbl { font-size:.72rem; text-transform:uppercase; letter-spacing:.06em; color:#6c757d; }
    .filter-bar { background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:1rem 1.25rem; margin-bottom:1.5rem; }
    .filter-bar label { font-size:.78rem; font-weight:600; color:#374151; }
    .cat-chip { display:inline-block; padding:2px 10px; border-radius:20px; font-size:.72rem; font-weight:600; background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; }
    .section-card { border:none; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,.06); margin-bottom:1.25rem; overflow:hidden; }
    .section-card .sc-header { padding:.65rem 1.1rem; font-size:.85rem; font-weight:700; display:flex; align-items:center; gap:.5rem; }
    .progress-slim { height:8px; border-radius:4px; background:#e9ecef; overflow:hidden; }
    .progress-slim .fill { height:100%; border-radius:4px; }
    .cat-group-row { background:#f1f5f9; font-weight:700; font-size:.78rem; text-transform:uppercase; letter-spacing:.05em; }
    @@media print { .no-print{display:none!important;} }
</style>

<div class="container-fluid px-4">
    <!-- Header -->
    <div class="rpt-header no-print">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <div style="font-size:.78rem; opacity:.7; margin-bottom:.25rem;">
                    <a href="@Url.Action("Index")" style="color:rgba(255,255,255,.8); text-decoration:none;">Reports</a> / Status Report
                </div>
                <h2 class="fw-bold mb-1" style="font-size:1.4rem;">📋 Status Report</h2>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="fw-semibold" style="font-size:1rem;">@Model.ProjectName</span>
                    @if (!string.IsNullOrEmpty(Model.ProjectCategory))
                    {
                        <span class="badge" style="background:rgba(255,255,255,.2); color:#fff; font-size:.72rem;">
                            <i class="bi bi-tag me-1"></i>@Model.ProjectCategory
                        </span>
                    }
                    @{
                        var sc = Model.ProjectStatus switch { "Completed"=>"success","In Progress"=>"primary","On Hold"=>"warning",_=>"secondary" };
                    }
                    @if (!string.IsNullOrEmpty(Model.ProjectStatus))
                    {
                        <span class="badge bg-@sc">@Model.ProjectStatus</span>
                    }
                </div>
                <div style="font-size:.75rem; opacity:.65; margin-top:.3rem;">Generated @Model.GeneratedDate.ToString("MMMM dd, yyyy 'at' hh:mm tt") UTC</div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="@Url.Action("StatusPrint", new { id = Model.ProjectId })" class="btn btn-light btn-sm" target="_blank">
                    <i class="fas fa-print me-1"></i> Print View
                </a>
                <a href="@Url.Action("Index")" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>
    </div>

    <!-- KPI tiles -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="rpt-kpi" style="border-color:#10b981;">
                <div class="num text-success">@Model.CompletedTasks.Count</div>
                <div class="lbl">Completed</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rpt-kpi" style="border-color:#3b82f6;">
                <div class="num text-primary">@Model.InProgressTasks.Count</div>
                <div class="lbl">In Progress</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rpt-kpi" style="border-color:#f59e0b;">
                <div class="num text-warning">@Model.UpcomingTasks.Count</div>
                <div class="lbl">Upcoming</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="rpt-kpi" style="border-color:#8b5cf6;">
                <div class="num" style="color:#8b5cf6;">@Math.Round(Model.CompletionPercentage,0)%</div>
                <div class="lbl">Completion</div>
            </div>
        </div>
    </div>

    <!-- Progress bar -->
    <div class="mb-4">
        <div class="d-flex justify-content-between mb-1">
            <span class="fw-semibold small">Overall Progress</span>
            <span class="fw-bold small text-success">@Math.Round(Model.CompletionPercentage,1)%</span>
        </div>
        <div class="progress-slim"><div class="fill bg-success" style="width:@Model.CompletionPercentage%;"></div></div>
        <small class="text-muted">@Model.CompletedTasks.Count of @Model.TotalTasks tasks completed</small>
    </div>

    <!-- Category summary -->
    @if (tasksByCategory.Count > 1)
    {
        <div class="section-card no-print mb-4">
            <div class="sc-header" style="background:#f8fafc; border-bottom:1px solid #e2e8f0;">
                <i class="bi bi-tags text-primary"></i> Tasks by Category
            </div>
            <div class="p-3">
                <div class="row g-2">
                    @foreach (var cat in tasksByCategory)
                    {
                        var done = cat.Count(t => t.Status == "Completed");
                        var pct = cat.Count() > 0 ? (int)Math.Round((double)done / cat.Count() * 100) : 0;
                        <div class="col-md-6 col-lg-4">
                            <div style="border:1px solid #e2e8f0; border-radius:8px; padding:.6rem .75rem;">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="cat-chip">@cat.Key</span>
                                    <small class="text-muted fw-semibold">@done/@cat.Count()</small>
                                </div>
                                <div class="progress-slim"><div class="fill bg-primary" style="width:@pct%;"></div></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Filter bar -->
    <div class="filter-bar no-print">
        <form method="get" class="row g-2 align-items-end">
            <input type="hidden" name="id" value="@Model.ProjectId" />
            <div class="col-md-3">
                <label>Search Task</label>
                <input type="search" name="search" class="form-control form-control-sm" placeholder="Task title…" value="@filterSearch" />
            </div>
            <div class="col-md-2">
                <label>Priority</label>
                <select name="priority" class="form-select form-select-sm">
                    <option value="">All Priorities</option>
                    @foreach (var p in allPriorities)
                    { <option value="@p" selected="@(filterPriority==p?"selected":null)">@p</option> }
                </select>
            </div>
            <div class="col-md-3">
                <label>Category</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">All Categories</option>
                    @foreach (var c in allCategories)
                    { <option value="@c" selected="@(filterCategory==c?"selected":null)">@c</option> }
                </select>
            </div>
            <div class="col-md-2">
                <label>Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    <option value="Completed" selected="@(filterStatus=="Completed"?"selected":null)">Completed</option>
                    <option value="In Progress" selected="@(filterStatus=="In Progress"?"selected":null)">In Progress</option>
                    <option value="Not Started" selected="@(filterStatus=="Not Started"?"selected":null)">Not Started</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button class="btn btn-primary btn-sm flex-grow-1" type="submit"><i class="fas fa-search"></i> Filter</button>
                <a href="@Url.Action("Status", new {id=Model.ProjectId})" class="btn btn-outline-secondary btn-sm">✕</a>
            </div>
        </form>
    </div>

    <!-- Completed Tasks -->
    @if ((string.IsNullOrEmpty(filterStatus) || filterStatus == "Completed") && filteredCompleted.Any())
    {
        <div class="section-card">
            <div class="sc-header" style="background:#10b981; color:#fff;">
                <i class="fas fa-check-circle"></i> Completed Tasks (@filteredCompleted.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Task</th><th>Category</th><th>Priority</th><th>Due</th><th>Completed</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var task in filteredCompleted.OrderByDescending(t => t.CompletedAt))
                        {
                            <tr>
                                <td class="fw-semibold">@task.Title</td>
                                <td>@if (!string.IsNullOrEmpty(task.Category)){<span class="cat-chip">@task.Category</span>}else{<span class="text-muted">—</span>}</td>
                                <td><span class="badge bg-@PriorityColor(task.Priority)">@task.Priority</span></td>
                                <td><small>@task.DueDate.ToString("MMM dd, yyyy")</small></td>
                                <td><small class="text-success">@(task.CompletedAt?.ToString("MMM dd, yyyy") ?? "—")</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- In Progress Tasks -->
    @if ((string.IsNullOrEmpty(filterStatus) || filterStatus == "In Progress") && filteredInProgress.Any())
    {
        <div class="section-card">
            <div class="sc-header" style="background:#3b82f6; color:#fff;">
                <i class="fas fa-spinner"></i> In Progress (@filteredInProgress.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Task</th><th>Category</th><th>Priority</th><th>Due</th><th>Schedule</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var task in filteredInProgress.OrderBy(t => t.DueDate))
                        {
                            var overdue = task.DueDate < DateTime.UtcNow;
                            <tr class="@(overdue?"table-danger":"")">
                                <td class="fw-semibold">@task.Title</td>
                                <td>@if (!string.IsNullOrEmpty(task.Category)){<span class="cat-chip">@task.Category</span>}else{<span class="text-muted">—</span>}</td>
                                <td><span class="badge bg-@PriorityColor(task.Priority)">@task.Priority</span></td>
                                <td><small>@task.DueDate.ToString("MMM dd, yyyy")</small></td>
                                <td>@if(overdue){<span class="badge bg-danger">Overdue</span>}else{<span class="badge bg-success">On Schedule</span>}</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Upcoming Tasks -->
    @if ((string.IsNullOrEmpty(filterStatus) || filterStatus == "Not Started") && filteredUpcoming.Any())
    {
        <div class="section-card">
            <div class="sc-header" style="background:#f59e0b; color:#fff;">
                <i class="fas fa-hourglass-start"></i> Upcoming / Not Started (@filteredUpcoming.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Task</th><th>Category</th><th>Priority</th><th>Due</th><th>Days Until Due</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var task in filteredUpcoming.OrderBy(t => t.DueDate))
                        {
                            var days = (int)(task.DueDate - DateTime.UtcNow).TotalDays;
                            var urgency = days < 7 ? "text-danger fw-bold" : days < 14 ? "text-warning fw-semibold" : "text-muted";
                            <tr>
                                <td class="fw-semibold">@task.Title</td>
                                <td>@if (!string.IsNullOrEmpty(task.Category)){<span class="cat-chip">@task.Category</span>}else{<span class="text-muted">—</span>}</td>
                                <td><span class="badge bg-@PriorityColor(task.Priority)">@task.Priority</span></td>
                                <td><small>@task.DueDate.ToString("MMM dd, yyyy")</small></td>
                                <td><span class="@urgency">@days days</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (!filteredCompleted.Any() && !filteredInProgress.Any() && !filteredUpcoming.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-folder-open fa-3x mb-3 d-block opacity-40"></i>
            <h5>No tasks match your filters.</h5>
            <a href="@Url.Action("Status", new {id=Model.ProjectId})" class="btn btn-outline-secondary btn-sm mt-2">Clear Filters</a>
        </div>
    }
</div>
